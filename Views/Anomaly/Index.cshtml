@{
    ViewData["Title"] = "Phát Hiện Bất Thường";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
        }

        /* ── Header ── */
        .ai-header {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            color: white;
            padding: 2rem 2.5rem;
            border-radius: 16px;
            margin-bottom: 1.5rem;
            position: relative;
            overflow: hidden;
        }
        .ai-header::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at 80% 50%, rgba(99,179,237,.15) 0%, transparent 60%);
        }
        .ai-header h1 { font-size: 1.6rem; font-weight: 700; margin: 0; }
        .ai-header p  { margin: .4rem 0 0; opacity: .75; font-size: .9rem; }
        .pulse-dot {
            display: inline-block; width: 10px; height: 10px;
            background: #48bb78; border-radius: 50%; margin-right: 8px;
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0%,100% { box-shadow: 0 0 0 0 rgba(72,187,120,.6); }
            50%      { box-shadow: 0 0 0 8px rgba(72,187,120,0); }
        }

        /* ── Stat bar ── */
        .stat-bar {
            display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;
        }
        .stat-chip {
            background: white; border-radius: 12px;
            padding: .75rem 1.25rem; flex: 1; min-width: 140px;
            box-shadow: 0 2px 8px rgba(0,0,0,.07);
            display: flex; align-items: center; gap: .75rem;
        }
        .stat-chip .icon { font-size: 1.6rem; }
        .stat-chip .num  { font-size: 1.5rem; font-weight: 700; line-height: 1; }
        .stat-chip .lbl  { font-size: .75rem; color: #718096; margin-top: 2px; }

        /* ── Loading ── */
        #loadingBlock {
            text-align: center; padding: 4rem 2rem;
            background: white; border-radius: 16px;
        }
        .spinner-ring {
            width: 56px; height: 56px;
            border: 5px solid #e2e8f0;
            border-top-color: #4299e1;
            border-radius: 50%;
            animation: spin .8s linear infinite;
            margin: 0 auto 1rem;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* ── Empty state ── */
        #emptyBlock {
            display: none; text-align: center; padding: 4rem 2rem;
            background: white; border-radius: 16px;
        }
        #emptyBlock .big-icon { font-size: 3.5rem; margin-bottom: 1rem; }

        /* ── Card ── */
        .anomaly-card {
            background: white; border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,.08);
            margin-bottom: 1rem; overflow: hidden;
            border-left: 5px solid #cbd5e0;
            transition: transform .15s, box-shadow .15s;
            animation: fadeUp .35s ease both;
        }
        .anomaly-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,.12);
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .anomaly-card.critical { border-left-color: #fc4d6d; }
        .anomaly-card.warning  { border-left-color: #f6ad55; }

        .card-body-inner { padding: 1.1rem 1.4rem; }

        /* Badge type */
        .badge-type {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 3px 10px; border-radius: 20px; font-size: .72rem;
            font-weight: 600; letter-spacing: .3px; margin-bottom: .5rem;
        }
        .badge-spike    { background: #fff5f5; color: #c53030; }
        .badge-frequency{ background: #fffbeb; color: #b7791f; }
        .badge-severity { background: #ebf8ff; color: #2b6cb0; }
        .badge-sev-critical { background: #fff5f5; color: #9b2335; font-size: .7rem; }
        .badge-sev-warning  { background: #fffaf0; color: #975a16; font-size: .7rem; }

        /* Insight text */
        .insight-text {
            font-size: .95rem; color: #2d3748; line-height: 1.7;
            margin: .4rem 0 .6rem;
        }

        /* Meta footer */
        .card-meta {
            display: flex; gap: 1rem; flex-wrap: wrap;
            font-size: .78rem; color: #a0aec0; padding-top: .6rem;
            border-top: 1px solid #f7fafc; margin-top: .4rem;
        }
        .card-meta span i { margin-right: 4px; }

        /* Filter tabs */
        .filter-tabs { display: flex; gap: .5rem; margin-bottom: 1rem; flex-wrap: wrap; }
        .filter-tab {
            padding: .4rem 1rem; border-radius: 20px; border: 1.5px solid #e2e8f0;
            background: white; font-size: .82rem; cursor: pointer; font-weight: 500;
            transition: all .15s; color: #4a5568;
        }
        .filter-tab:hover { border-color: #4299e1; color: #2b6cb0; }
        .filter-tab.active { background: #4299e1; color: white; border-color: #4299e1; }

        /* Refresh btn */
        .btn-refresh {
            background: white; border: 1.5px solid #e2e8f0;
            padding: .4rem 1rem; border-radius: 8px;
            font-size: .82rem; color: #4a5568; cursor: pointer;
            transition: all .15s;
        }
        .btn-refresh:hover { border-color: #4299e1; color: #2b6cb0; }
        .btn-refresh.spinning i { animation: spin .6s linear infinite; }

        /* Error block */
        #errorBlock {
            display: none;
            background: #fff5f5; border: 1px solid #fc8181;
            border-radius: 12px; padding: 1.5rem; text-align: center; color: #c53030;
        }

        /* Timestamp */
        #lastUpdated { font-size: .78rem; color: #a0aec0; }
    </style>
</head>
<body>
<div class="container-fluid mt-3 pb-5" style="max-width:960px">

    <!-- Nav breadcrumb nhỏ -->
    <nav class="mb-3" style="font-size:.85rem; color:#718096">
        <a href="/Status/DowntimeList" style="color:#4299e1;text-decoration:none">
            <i class="fas fa-list-alt me-1"></i>Danh sách Downtime
        </a>
        <span class="mx-2">/</span>
        <a href="/Status/ReportDowntime" style="color:#4299e1;text-decoration:none">
            <i class="fas fa-chart-bar me-1"></i>Báo cáo
        </a>
        <span class="mx-2">/</span>
        <span><i class="fas fa-brain me-1"></i>Phát hiện bất thường</span>
    </nav>

    <!-- Header -->
    <div class="ai-header">
        <div class="position-relative">
            <h1><i class="fas fa-brain me-2"></i><span data-i18n="anomaly.pageTitle">Phát Hiện Bất Thường</span></h1>
            <p>
                <span class="pulse-dot"></span>
                <span data-i18n="anomaly.subtitle">Phân tích tự động dựa trên lịch sử 5 tháng — so sánh Z-score, tần suất và mức độ nghiêm trọng</span>
            </p>
        </div>
    </div>

    <!-- Stat bar -->
    <div class="stat-bar" id="statBar" style="display:none!important">
        <div class="stat-chip">
            <div class="icon">🔴</div>
            <div><div class="num" id="statCritical">0</div><div class="lbl" data-i18n="anomaly.critical">Nghiêm trọng</div></div>
        </div>
        <div class="stat-chip">
            <div class="icon">🟠</div>
            <div><div class="num" id="statWarning">0</div><div class="lbl" data-i18n="anomaly.warning">Cảnh báo</div></div>
        </div>
        <div class="stat-chip">
            <div class="icon">📊</div>
            <div><div class="num" id="statTotal">0</div><div class="lbl" data-i18n="anomaly.totalDetected">Tổng phát hiện</div></div>
        </div>
        <div class="stat-chip" style="flex:2">
            <div class="icon">🕐</div>
            <div><div class="num" style="font-size:1rem" id="statTime">--:--</div><div class="lbl" data-i18n="common.lastUpdated">Cập nhật lần cuối</div></div>
        </div>
    </div>

    <!-- Controls -->
    <div class="d-flex justify-content-between align-items-center mb-2" id="controlBar" style="display:none!important">
        <div class="filter-tabs">
            <button class="filter-tab active" onclick="filterCards('all', this)" data-i18n="common.all">Tất cả</button>
            <button class="filter-tab" onclick="filterCards('Spike', this)">🔴 <span data-i18n="anomaly.spike">Spike</span></button>
            <button class="filter-tab" onclick="filterCards('Frequency', this)">🟠 <span data-i18n="anomaly.frequency">Tần suất</span></button>
            <button class="filter-tab" onclick="filterCards('Severity', this)">🔵 <span data-i18n="anomaly.severity">Mức độ</span></button>
        </div>
        <button class="btn-refresh" id="refreshBtn" onclick="loadAnomalies()">
            <i class="fas fa-sync-alt me-1"></i><span data-i18n="common.refresh">Làm mới</span>
        </button>
    </div>

    <!-- Loading -->
    <div id="loadingBlock">
        <div class="spinner-ring"></div>
        <div style="color:#718096" data-i18n="anomaly.analyzing">Đang phân tích dữ liệu lịch sử...</div>
        <div style="font-size:.8rem;color:#a0aec0;margin-top:.4rem" data-i18n="anomaly.analyzingDetail">So sánh Z-score · Tần suất · Mức độ nghiêm trọng</div>
    </div>

    <!-- Error -->
    <div id="errorBlock">
        <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
        <div id="errorMsg" data-i18n="common.errorLoad">Không thể tải dữ liệu.</div>
        <button class="btn-refresh mt-2" onclick="loadAnomalies()" data-i18n="common.retry">Thử lại</button>
    </div>

    <!-- Empty -->
    <div id="emptyBlock">
        <div class="big-icon">✅</div>
        <h5 style="color:#2d3748" data-i18n="anomaly.noAnomalies">Không phát hiện bất thường hôm nay</h5>
        <p style="color:#718096" data-i18n="anomaly.noAnomaliesDetail">Tất cả operation đang hoạt động trong ngưỡng bình thường so với lịch sử.</p>
        <div id="lastUpdated"></div>
    </div>

    <!-- Cards container -->
    <div id="cardsContainer"></div>

</div>

<script>
    let allData = [];

     // ✅ Lấy PathBase tự động từ server - fix lỗi 404 khi chạy dưới /downtime
    const pathBase = '@Context.Request.PathBase'.replace(/\/$/, '');

    async function loadAnomalies() {
        // Reset UI
        document.getElementById('loadingBlock').style.display = 'block';
        document.getElementById('errorBlock').style.display   = 'none';
        document.getElementById('emptyBlock').style.display   = 'none';
        document.getElementById('cardsContainer').innerHTML   = '';
        document.getElementById('statBar').style.display      = 'none';
        document.getElementById('controlBar').style.display   = 'none';

        const btn = document.getElementById('refreshBtn');
        if (btn) btn.classList.add('spinning');

        try {
            const res  = await fetch('/Anomaly/CheckToday');
            const json = await res.json();

            document.getElementById('loadingBlock').style.display = 'none';
            if (btn) btn.classList.remove('spinning');

            if (!json.success) {
                document.getElementById('errorMsg').textContent = json.message || window.i18nT('common.unknownError');
                document.getElementById('errorBlock').style.display = 'block';
                return;
            }

            allData = json.data || [];

            if (allData.length === 0) {
                document.getElementById('emptyBlock').style.display = 'block';
                document.getElementById('lastUpdated').textContent =
                    window.i18nT('common.checkedAt') + ': ' + new Date().toLocaleTimeString();
                return;
            }

            // Stat bar
            const nCritical = allData.filter(d => d.severity === 'Critical').length;
            const nWarning  = allData.filter(d => d.severity === 'Warning').length;
            document.getElementById('statCritical').textContent = nCritical;
            document.getElementById('statWarning').textContent  = nWarning;
            document.getElementById('statTotal').textContent    = allData.length;
            document.getElementById('statTime').textContent     = new Date().toLocaleTimeString();
            document.getElementById('statBar').style.display    = 'flex';
            document.getElementById('controlBar').style.display = 'flex';

            renderCards(allData);

        } catch (err) {
            document.getElementById('loadingBlock').style.display = 'none';
            document.getElementById('errorMsg').textContent = window.i18nT('common.connectionError') + ': ' + err.message;
            document.getElementById('errorBlock').style.display = 'block';
            if (btn) btn.classList.remove('spinning');
        }
    }

    function renderCards(data) {
        const container = document.getElementById('cardsContainer');
        container.innerHTML = '';

        data.forEach((item, idx) => {
            const isCritical = item.severity === 'Critical';

            const typeLabel = {
                Spike:     '🔴 ' + window.i18nT('anomaly.spike'),
                Frequency: '🟠 ' + window.i18nT('anomaly.frequency'),
                Severity:  '🔵 ' + window.i18nT('anomaly.severity')
            };
            const typeClass = { Spike: 'badge-spike', Frequency: 'badge-frequency', Severity: 'badge-severity' };
            const sevLabel  = isCritical ? '🚨 ' + window.i18nT('anomaly.critical') : '⚠️ ' + window.i18nT('anomaly.warning');
            const sevClass  = isCritical ? 'badge-sev-critical' : 'badge-sev-warning';

            const card = document.createElement('div');
            card.className = `anomaly-card ${item.severity.toLowerCase()}`;
            card.dataset.type = item.type;
            card.style.animationDelay = (idx * 0.06) + 's';

            card.innerHTML = `
                <div class="card-body-inner">
                    <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                        <div>
                            <span class="badge-type ${typeClass[item.type]}">${typeLabel[item.type] || item.type}</span>
                            <span class="badge-type ${sevClass} ms-1">${sevLabel}</span>
                        </div>
                        <small style="color:#a0aec0;white-space:nowrap">${item.detectedAt}</small>
                    </div>
                    <div class="insight-text">${item.insightText}</div>
                    <div class="card-meta">
                        <span><i class="fas fa-cog"></i><span title="${window.i18nT('anomaly.machine')}">${item.operation}</span></span>
                        <span><i class="fas fa-tag"></i>${item.issCode} — ${item.errorName}</span>
                    </div>
                </div>`;

            container.appendChild(card);
        });
    }

    function filterCards(type, btn) {
        document.querySelectorAll('.filter-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filtered = type === 'all' ? allData : allData.filter(d => d.type === type);
        renderCards(filtered);
    }

    // ── Auto refresh mỗi 2 phút ──────────────────────────────────────────────
    const REFRESH_INTERVAL = 2 * 60 * 1000;
    let countdown = REFRESH_INTERVAL / 1000;
    let prevCount = 0;

    // Countdown hiển thị trên nút refresh
    function updateCountdown() {
        const btn = document.getElementById('refreshBtn');
        if (!btn) return;
        const m = Math.floor(countdown / 60);
        const s = countdown % 60;
        btn.innerHTML = `<i class="fas fa-sync-alt me-1"></i>${window.i18nT('common.refresh')} (${m}:${s.toString().padStart(2,'0')})`;
        countdown--;
        if (countdown < 0) countdown = REFRESH_INTERVAL / 1000;
    }

    // Toast thông báo khi có alert mới
    function showNewAlertToast(n) {
        const toast = document.createElement('div');
        toast.style.cssText = `
            position:fixed;bottom:24px;right:24px;z-index:9999;
            background:#fc4d6d;color:white;padding:14px 20px;
            border-radius:12px;font-size:14px;font-weight:600;
            box-shadow:0 8px 24px rgba(252,77,109,.4);
            animation:slideUp .3s ease;`;
        toast.innerHTML = `🚨 ${window.i18nT('anomaly.newAnomaliesDetected').replace('{n}', n)}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }

    // Silent refresh — không hiện spinner, chỉ update nếu có thay đổi
    async function silentRefresh() {
        try {
            const res  = await fetch('/Anomaly/CheckToday');
            const json = await res.json();
            if (!json.success) return;

            const newCount = json.count || 0;

            if (newCount > prevCount) {
                showNewAlertToast(newCount - prevCount);
                allData = json.data || [];
                renderCards(allData);
                document.getElementById('statCritical').textContent = allData.filter(d => d.severity === 'Critical').length;
                document.getElementById('statWarning').textContent  = allData.filter(d => d.severity === 'Warning').length;
                document.getElementById('statTotal').textContent    = newCount;
                document.getElementById('statTime').textContent     = new Date().toLocaleTimeString();
                if (newCount > 0) {
                    document.getElementById('statBar').style.display    = 'flex';
                    document.getElementById('controlBar').style.display = 'flex';
                    document.getElementById('emptyBlock').style.display = 'none';
                }
            }

            prevCount = newCount;
            countdown = REFRESH_INTERVAL / 1000;
        } catch (_) { /* silent fail */ }
    }

    // Khởi động
    loadAnomalies();
    setTimeout(() => { prevCount = allData.length; }, 3000);

    // Chạy mỗi giây để update countdown
    setInterval(updateCountdown, 1000);

    // Silent refresh mỗi 2 phút
    setInterval(silentRefresh, REFRESH_INTERVAL);
</script>

<style>
@@keyframes slideUp {
    from { opacity:0; transform:translateY(12px); }
    to   { opacity:1; transform:translateY(0); }
}
</style>
</body>
</html>
