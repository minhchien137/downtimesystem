@{
    var userRole = Context.Session.GetString("UserRole") ?? "";
    var userName = Context.Session.GetString("UserName") ?? "";
    bool isAdmin      = userRole == "Admin";
    bool isTechnical  = userRole == "Technical";
    bool isProduction = userRole == "Production";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sigma Worldwide ⚙️</title>
    <link rel="icon" type="image/png" href="~/images/downtime.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MachineStatusUpdate.styles.css" asp-append-version="true" />
    <style>
        /* ── Role badge in navbar ── */
        .role-badge-nav {
            display: inline-block;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            padding: 3px 9px;
            border-radius: 20px;
            vertical-align: middle;
            margin-left: 6px;
        }
        .role-admin      { background: #C8102E; color: #fff; }
        .role-technical  { background: #FF8C00; color: #fff; }
        .role-production { background: #1565C0; color: #fff; }

        .navbar-brand-text {
            font-weight: 700;
            color: #C8102E !important;
            font-size: 15px;
        }
        .nav-logout {
            background: #C8102E;
            color: #fff !important;
            border-radius: 6px;
            padding: 6px 14px !important;
            font-size: 13px;
            transition: background .2s;
        }
        .nav-logout:hover { background: #9B0B22; }

        /* ── Bell notification (Production only) ── */
        .bell-wrapper {
            position: relative;
            display: inline-flex;
            align-items: center;
        }
        .bell-btn {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 20px;
            padding: 4px 8px;
            border-radius: 8px;
            transition: background .18s;
            position: relative;
            line-height: 1;
        }
        .bell-btn:hover { background: #f3f4f6; }
        .bell-badge {
            display: none;
            position: absolute;
            top: 0px;
            right: 2px;
            background: #ef4444;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            border-radius: 99px;
            min-width: 16px;
            height: 16px;
            padding: 0 4px;
            line-height: 16px;
            text-align: center;
            pointer-events: none;
        }
        .bell-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 340px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            box-shadow: 0 12px 40px rgba(0,0,0,.14);
            z-index: 9999;
            overflow: hidden;
        }
        .bell-dropdown.open { display: block; }
        .bell-drop-header {
            padding: 12px 16px;
            font-weight: 700;
            font-size: 14px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #f8fafc;
        }
        .bell-drop-clear {
            font-size: 12px;
            color: #6b7280;
            background: none;
            border: none;
            cursor: pointer;
            padding: 2px 6px;
            border-radius: 6px;
        }
        .bell-drop-clear:hover { background: #e5e7eb; color: #111; }
        .bell-drop-list {
            max-height: 360px;
            overflow-y: auto;
        }
        .bell-drop-empty {
            padding: 28px 16px;
            text-align: center;
            color: #9ca3af;
            font-size: 13px;
        }
        .bell-notif-item {
            padding: 11px 16px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 13px;
        }
        .bell-notif-item:last-child { border-bottom: none; }
        .bell-notif-item.accept-item { border-left: 4px solid #22c55e; }
        .bell-notif-item.wait-item   { border-left: 4px solid #f59e0b; }
        .bell-notif-title { font-weight: 700; margin-bottom: 3px; }
        .bell-notif-title.accept { color: #166534; }
        .bell-notif-title.wait   { color: #92400e; }
        .bell-notif-body { color: #374151; line-height: 1.5; }
        .bell-notif-time { color: #9ca3af; font-size: 11px; margin-top: 4px; }
        @@keyframes bellShake {
            0%,100% { transform: rotate(0); }
            15%      { transform: rotate(15deg); }
            30%      { transform: rotate(-13deg); }
            45%      { transform: rotate(10deg); }
            60%      { transform: rotate(-8deg); }
            75%      { transform: rotate(5deg); }
        }
        .bell-btn.shake { animation: bellShake 0.6s ease; }
    </style>
</head>

<body>
    @if (!string.IsNullOrEmpty(userRole))
    {
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="切换导航">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @if (isProduction)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark custom-highlight" asp-controller="Status" asp-action="CreateDownTime">
                                📝 录入停机时间
                            </a>
                        </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-dark custom-highlight" asp-controller="Status" asp-action="DowntimeList">
                                📈 停机时间历史
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark custom-highlight" asp-controller="Status" asp-action="ReportDowntime">
                                📊 停机时间报告
                            </a>
                        </li>

                        @if (isAdmin)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark custom-highlight" asp-controller="Status" asp-action="AdminNotifications">
                                🔔 通知仪表板
                                <span id="navAdminBadge" style="display:none;background:#7c3aed;color:#fff;font-size:10px;font-weight:700;border-radius:99px;padding:1px 6px;margin-left:4px;vertical-align:middle;"></span>
                            </a>
                        </li>
                        }
                        else if (isTechnical)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark custom-highlight" asp-controller="Status" asp-action="NotificationDashboard">
                                🔔 通知仪表板
                            </a>
                        </li>
                        }

                        @if (isProduction)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark custom-highlight" asp-controller="Status" asp-action="ProductionNotifications">
                                📬 我的通知
                                <span id="navProdBadge" style="display:none;background:#ef4444;color:#fff;font-size:10px;font-weight:700;border-radius:99px;padding:1px 6px;margin-left:4px;vertical-align:middle;"></span>
                            </a>
                        </li>
                        }

                        @if (isAdmin)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark custom-highlight" asp-controller="Status" asp-action="AdminPanel">
                                🛡 管理面板
                            </a>
                        </li>
                        }

                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">
                        <li class="nav-item">
                            <div class="bell-wrapper" id="bellWrapper">
                                <button class="bell-btn" id="bellBtn" onclick="toggleBellDropdown(event)" title="通知">
                                    🔔
                                    <span class="bell-badge" id="bellBadge">0</span>
                                </button>
                                <div class="bell-dropdown" id="bellDropdown">
                                    <div class="bell-drop-header">
                                        @if (isProduction) { <span>📬 技术团队响应</span> }
                                        @if (isTechnical)  { <span>🛑 生产团队通知</span> }
                                        @if (isAdmin)      { <span>📋 全部通知</span> }
                                        <button class="bell-drop-clear" onclick="clearBellNotifs()">清空全部</button>
                                    </div>
                                    <div class="bell-drop-list" id="bellList">
                                        <div class="bell-drop-empty" id="bellEmpty">暂无通知。</div>
                                    </div>
                                </div>
                            </div>
                        </li>
                        <li class="nav-item">
                            <span class="nav-link text-muted" style="font-size:13px; cursor:default;">
                                👤 @userName
                                @if (isAdmin)      { <span class="role-badge-nav role-admin">管理员</span> }
                                @if (isTechnical)  { <span class="role-badge-nav role-technical">技术员</span> }
                                @if (isProduction) { <span class="role-badge-nav role-production">生产</span> }
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-logout" asp-controller="Account" asp-action="Logout">
                                ⏻ 退出 / Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container"></div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (!string.IsNullOrEmpty(userRole))
    {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
    (function() {
        "use strict";
        const pathBase   = '@Context.Request.PathBase'.replace(/\/$/, '');
        const myUsername = '@userName';
        const myRole     = '@userRole';
        const bellBtn    = document.getElementById('bellBtn');
        const bellBadge  = document.getElementById('bellBadge');
        const bellList   = document.getElementById('bellList');
        const bellDrop   = document.getElementById('bellDropdown');

        if (!myUsername) return;

        // ─── 渲染单条通知 ──────────────────────────────
        function renderItem(n) {
            const isRead    = n.isRead;
            const type      = n.notifType;
            const isAccept  = n.techAction === 'ACCEPT';
            const isWait    = n.techAction === 'WAIT';
            const readStyle = isRead ? 'opacity:0.6;' : '';

            let borderColor = '#ef4444';
            let icon = '🛑';
            if (type === 'TECH_RESPONSE') { borderColor = isAccept ? '#22c55e' : '#f59e0b'; icon = isAccept ? '✅' : '⏳'; }
            if (type === 'RUN')           { borderColor = '#3b82f6'; icon = '✅'; }
            if (type === 'FIX_COMPLETE')  { borderColor = '#0d6efd'; icon = '🔧'; }

            // Badge nguồn (chỉ hiển thị với Admin)
            const sourceBadge = myRole === 'Admin'
                ? `<span style="font-size:10px;font-weight:700;padding:1px 7px;border-radius:99px;margin-left:6px;
                    background:${(type==='STOP'||type==='RUN') ? '#f3e8ff' : '#e0f2fe'};
                    color:${(type==='STOP'||type==='RUN') ? '#7c3aed' : '#0369a1'};">
                    ${(type==='STOP'||type==='RUN') ? '🏭 Prod' : '🔧 Tech'}
                   </span>`
                : '';

            const unreadDot = !isRead
                ? `<span style="display:inline-block;width:8px;height:8px;background:#ef4444;border-radius:50%;margin-left:6px;vertical-align:middle;"></span>`
                : '';

            return `
                <div class="bell-notif-item" data-id="${n.id}"
                     style="border-left:4px solid ${borderColor}; ${readStyle} cursor:pointer;"
                     onclick="markOneRead(${n.id}, this)">
                    <div class="bell-notif-title" style="color:#1e293b;">
                        ${icon} ${n.title} ${sourceBadge} ${unreadDot}
                    </div>
                    ${n.body ? `<div class="bell-notif-body">${n.body}</div>` : ''}
                    <div class="bell-notif-time">🕐 ${n.createdAt}${n.techName ? ` &nbsp;·&nbsp; 👤 ${n.techName}` : ''}</div>
                </div>`;
        }

        // ─── 从数据库加载通知 ───────────────────────────────
        async function loadNotifications() {
            try {
                const res  = await fetch(`${pathBase}/Status/GetMyNotifications`);
                const data = await res.json();
                if (!data.success) return;

                bellList.innerHTML = '';

                if (!data.notifications || data.notifications.length === 0) {
                    bellList.innerHTML = '<div class="bell-drop-empty" id="bellEmpty">暂无通知。</div>';
                } else {
                    data.notifications.forEach(n => {
                        bellList.insertAdjacentHTML('beforeend', renderItem(n));
                    });
                }

                const count = data.unreadCount || 0;
                if (count > 0) {
                    bellBadge.textContent   = count > 9 ? '9+' : String(count);
                    bellBadge.style.display = 'block';
                } else {
                    bellBadge.style.display = 'none';
                }

                // Badge trên nav "我的通知" (Production)
                const navProdBadge = document.getElementById('navProdBadge');
                if (navProdBadge) {
                    navProdBadge.textContent   = count > 9 ? '9+' : String(count);
                    navProdBadge.style.display = count > 0 ? 'inline' : 'none';
                }

                // Badge trên nav "通知仪表板" (Admin)
                const navAdminBadge = document.getElementById('navAdminBadge');
                if (navAdminBadge) {
                    navAdminBadge.textContent   = count > 9 ? '9+' : String(count);
                    navAdminBadge.style.display = count > 0 ? 'inline' : 'none';
                }

            } catch(e) {
                console.warn('loadNotifications error:', e);
            }
        }

        function addRealTimeItem() {
            if (bellBtn) {
                bellBtn.classList.remove('shake');
                void bellBtn.offsetWidth;
                bellBtn.classList.add('shake');
                setTimeout(() => bellBtn.classList.remove('shake'), 700);
            }
            loadNotifications();
        }

        window.markOneRead = async function(id, el) {
            if (el.style.opacity === '0.6') return;
            try {
                await fetch(`${pathBase}/Status/MarkNotificationRead`, {
                    method : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body   : JSON.stringify({ id })
                });
                el.style.opacity = '0.6';
                const dot = el.querySelector('span[style*="border-radius:50%"]');
                if (dot) dot.remove();
                loadNotifications();
            } catch(e) {}
        };

        window.toggleBellDropdown = function(e) {
            e.stopPropagation();
            const isOpen = bellDrop.classList.toggle('open');
            if (isOpen) markAllRead();
        };

        async function markAllRead() {
            try {
                await fetch(`${pathBase}/Status/MarkAllNotificationsRead`, { method: 'POST' });
                loadNotifications();
            } catch(e) {}
        }

        document.addEventListener('click', function(e) {
            const wrapper = document.getElementById('bellWrapper');
            if (wrapper && !wrapper.contains(e.target)) bellDrop.classList.remove('open');
        });

        window.clearBellNotifs = function(e) {
            if (e) e.stopPropagation();
            bellList.innerHTML = '<div class="bell-drop-empty" id="bellEmpty">暂无通知。</div>';
            bellBadge.style.display = 'none';
            markAllRead();
        };

        // ─── SignalR ──────────────────────────────────────────────────
        const conn = new signalR.HubConnectionBuilder()
            .withUrl(`${pathBase}/downtimeHub`)
            .withAutomaticReconnect([2000, 5000, 10000])
            .configureLogging(signalR.LogLevel.Warning)
            .build();

        if (myRole === 'Production' || myRole === 'Admin') {
            conn.on("ReceiveTechResponse", () => addRealTimeItem());
            conn.on("ReceiveFixComplete",  () => addRealTimeItem());
        }
        if (myRole === 'Technical' || myRole === 'Admin') {
            conn.on("ReceiveStopNotification", () => addRealTimeItem());
            conn.on("ReceiveRunNotification",  () => addRealTimeItem());
        }

        async function startConn() {
            try {
                await conn.start();
                if (myRole === 'Production' || myRole === 'Admin')
                    await conn.invoke("JoinOperatorGroup", myUsername);
                if (myRole === 'Technical' || myRole === 'Admin')
                    await conn.invoke("JoinTechnicianGroup");
            } catch(e) {
                setTimeout(startConn, 5000);
            }
        }

        loadNotifications();
        startConn();

    })();
    </script>
    }
</body>
</html>
