@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Downtime System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --red:       #C8102E;
            --red-dark:  #9B0B22;
            --red-light: #E8294A;
            --white:     #FFFFFF;
            --off-white: #F7F5F3;
            --gray-100:  #F0EEEC;
            --gray-300:  #C4BFBB;
            --gray-500:  #7A746F;
            --text:      #1A1614;
        }

        html, body {
            height: 100%;
            font-family: 'DM Sans', sans-serif;
            background: var(--off-white);
            overflow: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(200,16,46,.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(200,16,46,.06) 1px, transparent 1px);
            background-size: 48px 48px;
            pointer-events: none;
        }

        .page { display: flex; height: 100vh; }

        .panel-left {
            flex: 0 0 46%;
            background: var(--red);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 52px 56px;
            overflow: hidden;
        }
        .panel-left::before {
            content: '';
            position: absolute; top: -120px; right: -120px;
            width: 440px; height: 440px; border-radius: 50%;
            background: rgba(255,255,255,.07);
        }
        .panel-left::after {
            content: '';
            position: absolute; bottom: -80px; left: -80px;
            width: 300px; height: 300px; border-radius: 50%;
            background: rgba(255,255,255,.05);
        }

        .brand { position: relative; z-index: 1; }
        .brand-mark {
            display: inline-block;
            background: var(--white); color: var(--red);
            font-family: 'Bebas Neue', sans-serif;
            font-size: 13px; letter-spacing: 3px;
            padding: 6px 14px; border-radius: 3px; margin-bottom: 28px;
        }
        .brand-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(48px, 5.5vw, 72px);
            color: var(--white); line-height: 1.0; letter-spacing: 1px;
        }
        .brand-subtitle {
            margin-top: 18px; font-size: 14px;
            color: rgba(255,255,255,.65); font-weight: 300;
            line-height: 1.7; max-width: 300px;
        }

        .status-row {
            position: relative; z-index: 1;
            display: flex; flex-direction: column; gap: 12px;
        }
        .status-pill {
            display: flex; align-items: center; gap: 10px;
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: 50px; padding: 10px 18px;
            color: var(--white); font-size: 13px; font-weight: 500;
            backdrop-filter: blur(8px); transition: background .2s;
        }
        .status-pill .dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: #4AE06A; box-shadow: 0 0 6px #4AE06A; flex-shrink: 0;
        }
        .role-badge {
            display: inline-block; background: rgba(255,255,255,.15);
            border-radius: 4px; padding: 2px 8px;
            font-size: 11px; letter-spacing: 1px; font-weight: 600; margin-left: auto;
        }

        .panel-right {
            flex: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 48px; position: relative;
        }

        .login-box { width: 100%; max-width: 400px; }

        .login-heading {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 42px; color: var(--text);
            letter-spacing: 1px; margin-bottom: 4px;
        }
        .login-sub {
            font-size: 14px; color: var(--gray-500);
            margin-bottom: 40px; font-weight: 300;
        }

        .field { margin-bottom: 22px; }
        .field label {
            display: block; font-size: 11px; font-weight: 600;
            letter-spacing: 1.5px; text-transform: uppercase;
            color: var(--gray-500); margin-bottom: 8px;
        }
        .field input, .field select {
            width: 100%; padding: 13px 16px;
            border: 1.5px solid var(--gray-300); border-radius: 8px;
            font-family: 'DM Sans', sans-serif; font-size: 15px;
            color: var(--text); background: var(--white); outline: none;
            transition: border-color .2s, box-shadow .2s;
            appearance: none; -webkit-appearance: none;
        }
        .field input:focus, .field select:focus {
            border-color: var(--red);
            box-shadow: 0 0 0 3px rgba(200,16,46,.12);
        }
        .field .input-wrap { position: relative; }
        .field .input-wrap .icon {
            position: absolute; right: 14px; top: 50%;
            transform: translateY(-50%); pointer-events: none;
            color: var(--gray-300); font-size: 16px;
        }

        .error-msg {
            background: #FFF0F2; border: 1px solid #FFC0C9;
            border-left: 4px solid var(--red); border-radius: 6px;
            padding: 12px 16px; font-size: 13px; color: var(--red-dark);
            margin-bottom: 22px; display: flex; align-items: center; gap: 8px;
        }

        .btn-login {
            width: 100%; padding: 15px; background: var(--red);
            color: var(--white); border: none; border-radius: 8px;
            font-family: 'Bebas Neue', sans-serif; font-size: 20px;
            letter-spacing: 2px; cursor: pointer;
            position: relative; overflow: hidden;
            transition: background .2s, transform .1s;
        }
        .btn-login::after {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 60%);
        }
        .btn-login:hover  { background: var(--red-dark); }
        .btn-login:active { transform: scale(.98); }

        .footer-note {
            margin-top: 20px; font-size: 12px;
            color: var(--gray-300); text-align: center;
        }

        /* ── Language switcher ── */
        .lang-switcher {
            display: flex; align-items: center; gap: 8px;
            justify-content: center; margin-top: 16px;
        }
        .lang-flag {
            width: 28px; height: 20px; cursor: pointer;
            border-radius: 3px; object-fit: cover;
            transition: all .2s; opacity: .45;
        }
        .lang-flag:hover { opacity: .8; }

        @@keyframes slideInLeft {
            from { opacity:0; transform: translateX(-30px); }
            to   { opacity:1; transform: translateX(0); }
        }
        @@keyframes slideInRight {
            from { opacity:0; transform: translateX(30px); }
            to   { opacity:1; transform: translateX(0); }
        }
        .panel-left  { animation: slideInLeft  .55s cubic-bezier(.22,1,.36,1) both; }
        .panel-right { animation: slideInRight .55s cubic-bezier(.22,1,.36,1) .1s both; }

        @@media (max-width: 768px) {
            .panel-left  { display: none; }
            .panel-right { padding: 32px 24px; }
        }
    </style>
</head>
<body>
<div class="page">

    <!-- ───────── LEFT PANEL ───────── -->
    <div class="panel-left">
        <div class="brand">
            <div class="brand-mark" data-i18n="login.brand">SIGMA WORLDWIDE</div>
            <h1 class="brand-title">
                <span data-i18n="login.systemLine1">Machine</span><br>
                <span data-i18n="login.systemLine2">Downtime</span><br>
                <span data-i18n="login.systemLine3">System</span>
            </h1>
            <p class="brand-subtitle" data-i18n="login.tagline">
                The system is used to manage equipment downtime during the production process.
            </p>
        </div>
        <div class="status-row">
            <div class="status-pill">
                <span class="dot"></span>
                <span data-i18n="login.statusProd">Real-time production tracking</span>
                <span class="role-badge">PROD</span>
            </div>
            <div class="status-pill">
                <span class="dot"></span>
                <span data-i18n="login.statusTech">Technical response management</span>
                <span class="role-badge">TECH</span>
            </div>
            <div class="status-pill">
                <span class="dot"></span>
                <span data-i18n="login.statusReport">Downtime analytics &amp; reporting</span>
                <span class="role-badge">RPT</span>
            </div>
        </div>
    </div>

    <!-- ───────── RIGHT PANEL ───────── -->
    <div class="panel-right">
        <div class="login-box">
            <h2 class="login-heading" data-i18n="login.signIn">Sign in</h2>
            <p class="login-sub" data-i18n="login.signInPrompt">Please enter your credentials to continue</p>

            @if (!string.IsNullOrEmpty(ViewBag.Error as string))
            {
                <div class="error-msg">
                    <span>⚠</span> @ViewBag.Error
                </div>
            }

            <form method="post" action="/downtime/Account/Login">
                @Html.AntiForgeryToken()

                <div class="field">
                    <label data-i18n="login.username">Username</label>
                    <div class="input-wrap">
                        <input type="text" name="username"
                               placeholder="Enter username..."
                               data-i18n-ph="login.usernamePH"
                               autocomplete="username" required />
                        <span class="icon">👤</span>
                    </div>
                </div>

                <div class="field">
                    <label data-i18n="login.password">Password</label>
                    <div class="input-wrap">
                        <input type="password" name="password" id="passwordInput"
                               placeholder="Enter password..."
                               data-i18n-ph="login.passwordPH"
                               autocomplete="current-password" required />
                        <span class="icon" id="togglePassword" onclick="togglePwd()"
                              style="pointer-events:all;cursor:pointer;user-select:none;">👁️</span>
                    </div>
                </div>

                <button type="submit" class="btn-login" data-i18n="login.loginBtn">Login →</button>
            </form>

            <p class="footer-note">© @DateTime.Now.Year <span data-i18n="login.footer">Sigma Worldwide · Downtime System</span></p>

            <!-- ── Language switcher ── -->
            <div class="lang-switcher">
                <img src="~/images/en.png" alt="English"
                     class="lang-flag" data-lang="en"
                     onclick="changeLang('en')"
                     title="English" />
                <img src="~/images/cn.png" alt="中文"
                     class="lang-flag" data-lang="cn"
                     onclick="changeLang('cn')"
                     title="中文" />
            </div>
        </div>
    </div>

</div>
</body>
<script src="~/js/i18n-init.js"></script>
<script>
    function togglePwd() {
        const input = document.getElementById('passwordInput');
        const icon  = document.getElementById('togglePassword');
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = '👁️';
        } else {
            input.type = 'password';
            icon.textContent = '🔒';
        }
    }
</script>
</html>
