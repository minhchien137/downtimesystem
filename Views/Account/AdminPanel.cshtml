@{
    ViewData["Title"] = "Admin Panel";
    var userRole = Context.Session.GetString("UserRole") ?? "";
    if (userRole != "Admin") {
        Context.Response.Redirect("/Account/Login");
        return;
    }
}

<style>
    :root {
        --red:      #C8102E;
        --red-dark: #9B0B22;
        --white:    #FFFFFF;
        --bg:       #F8F5F5;
        --border:   #E8DEDE;
        --text:     #1A1614;
        --muted:    #7A6F6F;
        --success:  #16A34A;
        --warn:     #D97706;
    }

    body { background: var(--bg); }

    /* ── Page header ── */
    .admin-header {
        background: var(--red);
        color: #fff;
        padding: 20px 28px;
        border-radius: 12px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 6px 20px rgba(200,16,46,.25);
    }
    .admin-header h1 { margin: 0; font-size: 22px; font-weight: 700; }
    .admin-header p  { margin: 4px 0 0; font-size: 13px; opacity: .75; }
    .admin-badge {
        background: rgba(255,255,255,.2);
        border: 1px solid rgba(255,255,255,.3);
        border-radius: 6px;
        padding: 6px 14px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 1px;
    }

    /* ── Main tabs ── */
    .main-tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 20px;
        border-bottom: 2px solid var(--border);
        padding-bottom: 0;
    }
    .main-tab {
        padding: 10px 22px;
        border-radius: 8px 8px 0 0;
        border: 1.5px solid transparent;
        border-bottom: none;
        background: transparent;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
        position: relative;
        bottom: -2px;
    }
    .main-tab:hover { color: var(--red); background: #fff5f6; }
    .main-tab.active {
        background: #fff;
        color: var(--red);
        border-color: var(--border);
        border-bottom-color: #fff;
    }

    /* ── Tab panels ── */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Filter bar ── */
    .filter-bar {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 16px 20px;
        margin-bottom: 20px;
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
    }
    .filter-bar label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: 5px;
    }
    .filter-bar input, .filter-bar select {
        padding: 9px 12px;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: 14px;
        outline: none;
        transition: border-color .2s;
    }
    .filter-bar input:focus, .filter-bar select:focus { border-color: var(--red); }

    /* ── Toolbar (Add button row) ── */
    .toolbar {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 12px;
    }

    /* ── Buttons ── */
    .btn-search {
        background: var(--red); color: #fff;
        border: none; border-radius: 7px;
        padding: 10px 20px; font-weight: 600; font-size: 14px;
        cursor: pointer; transition: background .2s;
    }
    .btn-search:hover { background: var(--red-dark); }
    .btn-add {
        background: #16a34a; color: #fff;
        border: none; border-radius: 7px;
        padding: 9px 18px; font-weight: 600; font-size: 13px;
        cursor: pointer; transition: background .2s;
    }
    .btn-add:hover { background: #15803d; }
    .btn-edit {
        background: #FFF4E5; color: #B45309;
        border: 1px solid #FDE68A; border-radius: 6px;
        padding: 4px 10px; font-size: 12px; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-edit:hover { background: #FDE68A; }
    .btn-del {
        background: #FFE5E8; color: var(--red);
        border: 1px solid #FECDD3; border-radius: 6px;
        padding: 4px 10px; font-size: 12px; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-del:hover { background: #FECDD3; }
    .btn-reset {
        background: #EFF6FF; color: #1D4ED8;
        border: 1px solid #BFDBFE; border-radius: 6px;
        padding: 4px 10px; font-size: 12px; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-reset:hover { background: #BFDBFE; }
    .btn-save {
        background: var(--red); color: #fff;
        border: none; border-radius: 8px;
        padding: 10px 24px; font-weight: 700; font-size: 14px;
        cursor: pointer; transition: background .2s;
    }
    .btn-save:hover { background: var(--red-dark); }
    .btn-cancel {
        background: #F0EEEC; color: var(--text);
        border: none; border-radius: 8px;
        padding: 10px 20px; font-weight: 600; font-size: 14px; cursor: pointer;
    }

    /* ── Table ── */
    .table-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.04);
    }
    .table-card table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .table-card thead { background: #111; color: #fff; border-top: 3px solid var(--red); }
    .table-card thead th {
        padding: 11px 12px; text-align: left; font-weight: 600;
        font-size: 11px; letter-spacing: .8px; text-transform: uppercase; white-space: nowrap;
    }
    .table-card tbody tr { border-bottom: 1px solid #F3EDED; transition: background .15s; }
    .table-card tbody tr:hover { background: #FFF5F6; }
    .table-card tbody td {
        padding: 9px 12px; color: var(--text);
        max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    /* Badges */
    .badge { display: inline-block; padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-stop     { background: #FFE5E8; color: #C8102E; }
    .badge-run      { background: #E5F5EA; color: #15803D; }
    .badge-response { background: #FFF4E5; color: #B45309; }
    .badge-admin    { background: #EDE9FE; color: #5B21B6; }
    .badge-tech     { background: #DBEAFE; color: #1E40AF; }
    .badge-prod     { background: #D1FAE5; color: #065F46; }

    /* Pagination */
    .pager {
        padding: 14px 18px; display: flex; align-items: center;
        gap: 6px; justify-content: flex-end;
        border-top: 1px solid var(--border); font-size: 13px;
    }
    .pager-btn {
        border: 1.5px solid var(--border); background: #fff;
        border-radius: 7px; padding: 5px 12px; cursor: pointer;
        font-size: 13px; transition: all .15s;
    }
    .pager-btn:hover, .pager-btn.active { background: var(--red); color: #fff; border-color: var(--red); }

    /* ── Modal shared ── */
    .modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,.35); z-index: 1000;
        align-items: center; justify-content: center;
    }
    .modal-overlay.active { display: flex; }
    .modal-box {
        background: #fff; border-radius: 14px;
        width: min(680px, 95vw); max-height: 90vh; overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }
    .modal-box.sm { width: min(440px, 95vw); }
    .modal-head {
        background: var(--red); color: #fff; padding: 16px 22px;
        display: flex; align-items: center; justify-content: space-between;
        border-radius: 14px 14px 0 0;
    }
    .modal-head h3 { margin: 0; font-size: 16px; font-weight: 700; }
    .modal-close {
        background: rgba(255,255,255,.2); border: none; color: #fff;
        width: 28px; height: 28px; border-radius: 50%; cursor: pointer;
        font-size: 16px; line-height: 28px; text-align: center;
    }
    .modal-body {
        padding: 22px; display: grid;
        grid-template-columns: 1fr 1fr; gap: 14px;
    }
    .modal-body.single-col { grid-template-columns: 1fr; }
    .modal-field label {
        font-size: 11px; font-weight: 600; letter-spacing: 1px;
        text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 5px;
    }
    .modal-field input, .modal-field select, .modal-field textarea {
        width: 100%; padding: 9px 12px; border: 1.5px solid var(--border);
        border-radius: 7px; font-size: 14px; outline: none;
        transition: border-color .2s; font-family: inherit; box-sizing: border-box;
    }
    .modal-field input:focus, .modal-field select:focus, .modal-field textarea:focus {
        border-color: var(--red); box-shadow: 0 0 0 3px rgba(200,16,46,.1);
    }
    .modal-field.span2 { grid-column: span 2; }
    .modal-footer {
        padding: 16px 22px; border-top: 1px solid var(--border);
        display: flex; gap: 10px; justify-content: flex-end;
    }

    /* Confirm */
    .confirm-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,.45); z-index: 1100;
        align-items: center; justify-content: center;
    }
    .confirm-overlay.active { display: flex; }
    .confirm-box {
        background: #fff; border-radius: 12px; padding: 28px;
        width: min(380px, 92vw); text-align: center;
        box-shadow: 0 16px 48px rgba(0,0,0,.2);
    }
    .confirm-icon { font-size: 40px; margin-bottom: 12px; }
    .confirm-box h4 { font-weight: 700; margin-bottom: 6px; color: var(--red); }
    .confirm-box p  { font-size: 14px; color: var(--muted); margin-bottom: 20px; }
    .confirm-btns { display: flex; gap: 10px; justify-content: center; }

    /* Toast */
    #adminToast {
        position: fixed; bottom: 24px; right: 24px;
        background: #111; color: #fff; padding: 12px 20px;
        border-radius: 10px; font-size: 14px; font-weight: 500;
        opacity: 0; transition: opacity .3s; pointer-events: none;
        z-index: 9999; border-left: 4px solid var(--red);
    }
    #adminToast.show { opacity: 1; }
</style>

<!-- ── Page header ── -->
<div class="admin-header">
    <div>
        <h1>🛡 Admin Panel</h1>
        <p>Downtime · Employee · Account Management</p>
    </div>
    <span class="admin-badge">🔐 ADMIN ONLY</span>
</div>

<!-- ── Main Tabs ── -->
<div class="main-tabs">
    <button class="main-tab active" onclick="switchTab('downtime', this)">📋 Downtime</button>
    <button class="main-tab"        onclick="switchTab('employee', this)">👤 Employee</button>
    <button class="main-tab"        onclick="switchTab('account',  this)">🔑 Account</button>
</div>

<!-- ══════════════════════════════════════════════════════════
     TAB 1 — DOWNTIME RECORDS
     ══════════════════════════════════════════════════════════ -->
<div class="tab-panel active" id="tab-downtime">

    <div class="filter-bar">
        <div>
            <label>Operation</label>
            <input type="text" id="fOp" placeholder="e.g. SM-01" style="width:140px" />
        </div>
        <div>
            <label>State</label>
            <select id="fState" style="width:130px">
                <option value="">All States</option>
                <option value="STOP">STOP</option>
                <option value="RESPONSE">RESPONSE</option>
                <option value="RUN">RUN</option>
            </select>
        </div>
        <div>
            <label>From</label>
            <input type="date" id="fFrom" />
        </div>
        <div>
            <label>To</label>
            <input type="date" id="fTo" />
        </div>
        <button class="btn-search" onclick="loadRecords(1)">🔍 Search</button>
        <button class="btn-search" style="background:#7A6F6F;" onclick="clearFilters()">↺ Reset</button>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>ID</th><th>State</th><th>Operation</th><th>Employee</th>
                    <th>Machine</th><th>Location</th><th>Reason</th><th>Effect</th>
                    <th>Station</th><th>Description</th><th>Datetime</th>
                    <th style="text-align:center">Action</th>
                </tr>
            </thead>
            <tbody id="recordsTbody">
                <tr><td colspan="12" style="text-align:center;padding:30px;color:#aaa;">Loading...</td></tr>
            </tbody>
        </table>
        <div class="pager" id="pagerBar"></div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     TAB 2 — EMPLOYEE MANAGEMENT
     ══════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="tab-employee">

    <div class="filter-bar">
        <div>
            <label>Employee ID</label>
            <input type="text" id="eSearch" placeholder="Employee ID or Name" style="width:220px"
                   oninput="filterEmployees()" />
        </div>
        <button class="btn-search" onclick="filterEmployees()">🔍 Search</button>
        <button class="btn-search" style="background:#7A6F6F;" onclick="document.getElementById('eSearch').value='';filterEmployees()">↺ Reset</button>
    </div>

    <div class="toolbar">
        <button class="btn-add" onclick="openEmpModal()">➕ Add Employee</button>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Employee ID</th>
                    <th>Chinese Name</th>
                    <th>English Name</th>
                    <th style="text-align:center">Action</th>
                </tr>
            </thead>
            <tbody id="empTbody">
                <tr><td colspan="5" style="text-align:center;padding:30px;color:#aaa;">Loading...</td></tr>
            </tbody>
        </table>
        <div class="pager" id="empPagerBar"></div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     TAB 3 — ACCOUNT MANAGEMENT
     ══════════════════════════════════════════════════════════ -->
<div class="tab-panel" id="tab-account">

    <div class="filter-bar">
        <div>
            <label>Username</label>
            <input type="text" id="aSearch" placeholder="Username or Role" style="width:220px"
                   oninput="filterAccounts()" />
        </div>
        <button class="btn-search" onclick="filterAccounts()">🔍 Search</button>
        <button class="btn-search" style="background:#7A6F6F;" onclick="document.getElementById('aSearch').value='';filterAccounts()">↺ Reset</button>
    </div>

    <div class="toolbar">
        <button class="btn-add" onclick="openAccModal()">➕ Add Account</button>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Password</th>
                    <th>Role</th>
                    <th style="text-align:center">Action</th>
                </tr>
            </thead>
            <tbody id="accTbody">
                <tr><td colspan="5" style="text-align:center;padding:30px;color:#aaa;">Loading...</td></tr>
            </tbody>
        </table>
        <div class="pager" id="accPagerBar"></div>
    </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     MODALS — DOWNTIME EDIT
     ══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="editModal">
    <div class="modal-box">
        <div class="modal-head">
            <h3>✏️ Edit Record — ID: <span id="modalId">-</span></h3>
            <button class="modal-close" onclick="closeEdit()">✕</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="editId" />
            <div class="modal-field"><label>Employee Code</label><input type="text" id="editEmpCode" /></div>
            <div class="modal-field"><label>Employee Name</label><input type="text" id="editEmpName" /></div>
            <div class="modal-field"><label>Machine Code</label><input type="text" id="editMachine" /></div>
            <div class="modal-field"><label>Location</label><input type="text" id="editLocation" /></div>
            <div class="modal-field"><label>Operation</label><input type="text" id="editOperation" /></div>
            <div class="modal-field">
                <label>State</label>
                <select id="editState">
                    <option value="STOP">STOP</option>
                    <option value="RESPONSE">RESPONSE</option>
                    <option value="RUN">RUN</option>
                </select>
            </div>
            <div class="modal-field"><label>Reason</label><input type="text" id="editReason" /></div>
            <div class="modal-field"><label>Effect</label><input type="text" id="editEffect" /></div>
            <div class="modal-field"><label>Station</label><input type="text" id="editStation" /></div>
            <div class="modal-field"><label>Action</label><input type="text" id="editAction" /></div>
            <div class="modal-field"><label>Root Cause</label><input type="text" id="editRootCause" /></div>
            <div class="modal-field"><label>Spare Parts</label><input type="text" id="editSpareParts" /></div>
            <div class="modal-field"><label>Estimate Time</label><input type="text" id="editEstimate" /></div>
            <div class="modal-field"><label>Datetime</label><input type="datetime-local" id="editDatetime" /></div>
            <div class="modal-field span2"><label>Description</label><textarea id="editDesc" rows="3"></textarea></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeEdit()">Cancel</button>
            <button class="btn-save"   onclick="saveEdit()">Save</button>
        </div>
    </div>
</div>

<!-- MODALS — EMPLOYEE -->
<div class="modal-overlay" id="empModal">
    <div class="modal-box sm">
        <div class="modal-head">
            <h3 id="empModalTitle">👤 Add Employee</h3>
            <button class="modal-close" onclick="closeEmpModal()">✕</button>
        </div>
        <div class="modal-body single-col">
            <input type="hidden" id="empId" />
            <div class="modal-field"><label>Employee ID <span style="color:red">*</span></label><input type="text" id="empEmpID" /></div>
            <div class="modal-field"><label>Chinese Name</label><input type="text" id="empChinese" /></div>
            <div class="modal-field"><label>English Name</label><input type="text" id="empEnglish" /></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeEmpModal()">Cancel</button>
            <button class="btn-save"   onclick="saveEmployee()">💾 Save</button>
        </div>
    </div>
</div>

<!-- MODALS — ACCOUNT -->
<div class="modal-overlay" id="accModal">
    <div class="modal-box sm">
        <div class="modal-head">
            <h3 id="accModalTitle">🔑 Add Account</h3>
            <button class="modal-close" onclick="closeAccModal()">✕</button>
        </div>
        <div class="modal-body single-col">
            <input type="hidden" id="accId" />
            <div class="modal-field"><label>Username <span style="color:red">*</span></label><input type="text" id="accUsername" /></div>
            <div class="modal-field">
                <label>Password <span style="color:red">*</span></label>
                <input type="text" id="accPassword" placeholder="Enter password" />
            </div>
            <div class="modal-field">
                <label>Role <span style="color:red">*</span></label>
                <select id="accRole">
                    <option value="Production">Production</option>
                    <option value="Technical">Technical</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeAccModal()">Cancel</button>
            <button class="btn-save"   onclick="saveAccount()">💾 Save</button>
        </div>
    </div>
</div>

<!-- MODALS — RESET PASSWORD -->
<div class="modal-overlay" id="resetPwModal">
    <div class="modal-box sm">
        <div class="modal-head" style="background:#1D4ED8;">
            <h3>🔒 Reset Password</h3>
            <button class="modal-close" onclick="closeResetPw()">✕</button>
        </div>
        <div class="modal-body single-col">
            <input type="hidden" id="resetPwId" />
            <div style="background:#EFF6FF;border:1px solid #BFDBFE;border-radius:8px;padding:12px 14px;margin-bottom:4px;">
                <div style="font-size:12px;color:#1D4ED8;font-weight:600;margin-bottom:2px;">👤 Account</div>
                <div id="resetPwUsername" style="font-size:16px;font-weight:700;color:#1e3a8a;"></div>
            </div>
            <div class="modal-field">
                <label>New Password <span style="color:red">*</span></label>
                <div style="position:relative;">
                    <input type="text" id="resetPwNew" placeholder="Enter new password"
                           style="padding-right:80px;" />
                    <button type="button" onclick="genPassword()"
                            style="position:absolute;right:6px;top:50%;transform:translateY(-50%);
                                   background:#e0f2fe;border:1px solid #bae6fd;border-radius:5px;
                                   padding:3px 8px;font-size:11px;font-weight:600;color:#0369a1;cursor:pointer;">
                        🎲 Generate
                    </button>
                </div>
            </div>
            <div style="font-size:11px;color:var(--muted);margin-top:-6px;">
                💡 Tip: Click 🎲 to generate a random password.
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeResetPw()">Cancel</button>
            <button class="btn-save" style="background:#1D4ED8;" onclick="confirmResetPw()">🔒 Confirm Reset</button>
        </div>
    </div>
</div>


<div class="confirm-overlay" id="confirmModal">
    <div class="confirm-box">
        <div class="confirm-icon">🗑</div>
        <h4>Confirm Delete</h4>
        <p>This action cannot be undone.<br>ID: <strong id="confirmId">-</strong></p>
        <div class="confirm-btns">
            <button class="btn-cancel" onclick="closeConfirm()">Cancel</button>
            <button class="btn-del" style="padding:10px 20px;font-size:14px;" onclick="confirmDelete()">Confirm Delete</button>
        </div>
    </div>
</div>

<div id="adminToast"></div>

<script>
"use strict";

const pathBase = '@Context.Request.PathBase'.replace(/\/$/, '');

// ════════════════════════════════════════
// TAB SWITCHING
// ════════════════════════════════════════
function switchTab(name, btn) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.main-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');

    if (name === 'employee' && !empLoaded) loadEmployees();
    if (name === 'account'  && !accLoaded) loadAccounts();
}

// ════════════════════════════════════════
// HELPERS
// ════════════════════════════════════════
function getToken() {
    const el = document.querySelector('input[name="__RequestVerificationToken"]');
    return el ? el.value : '';
}

function showToast(msg) {
    const t = document.getElementById('adminToast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
}

let pendingDelete = { id: null, type: null };

function openConfirm(id, type) {
    pendingDelete = { id, type };
    document.getElementById('confirmId').textContent = id;
    document.getElementById('confirmModal').classList.add('active');
}
function closeConfirm() {
    pendingDelete = { id: null, type: null };
    document.getElementById('confirmModal').classList.remove('active');
}
async function confirmDelete() {
    const { id, type } = pendingDelete;
    if (!id || !type) return;

    const urlMap = {
        downtime: `${pathBase}/Status/AdminDeleteRecord`,
        employee: `${pathBase}/Status/AdminDeleteEmployee`,
        account:  `${pathBase}/Status/AdminDeleteAccount`,
    };

    try {
        const res  = await fetch(urlMap[type], {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify({ id })
        });
        const data = await res.json();
        if (data.success) {
            closeConfirm();
            showToast('🗑 Deleted');
            if (type === 'downtime') loadRecords(currentPage);
            if (type === 'employee') loadEmployees();
            if (type === 'account')  loadAccounts();
        } else {
            showToast('⚠ ' + (data.message || 'Delete failed'));
        }
    } catch { showToast('⚠ Request failed'); }
}

// ════════════════════════════════════════
// TAB 1 — DOWNTIME RECORDS
// ════════════════════════════════════════
let currentPage = 1;

async function loadRecords(page = 1) {
    currentPage = page;
    const op    = document.getElementById('fOp').value.trim();
    const state = document.getElementById('fState').value;
    const from  = document.getElementById('fFrom').value;
    const to    = document.getElementById('fTo').value;

    const params = new URLSearchParams({ page, pageSize: 20 });
    if (op)    params.append('operation', op);
    if (state) params.append('state',     state);
    if (from)  params.append('fromDate',  from);
    if (to)    params.append('toDate',    to);

    try {
        const res  = await fetch(`${pathBase}/Status/AdminGetRecords?${params}`);
        const data = await res.json();
        renderTable(data.records || []);
        renderPager(data.totalPages, page, 'pagerBar', loadRecords);
    } catch { showToast('⚠ Load failed'); }
}

function renderTable(rows) {
    const tbody = document.getElementById('recordsTbody');
    if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="12" style="text-align:center;padding:30px;color:#aaa;">No records found</td></tr>';
        return;
    }
    tbody.innerHTML = rows.map(r => {
        const bc = r.state === 'STOP' ? 'badge-stop' : r.state === 'RUN' ? 'badge-run' : 'badge-response';
        const dt = r.datetime ? new Date(r.datetime).toLocaleString('zh-CN') : '-';
        return `<tr>
            <td><strong>#${r.id}</strong></td>
            <td><span class="badge ${bc}">${r.state||'-'}</span></td>
            <td title="${r.operation||''}">${r.operation||'-'}</td>
            <td>${r.employeeName||'-'}</td>
            <td>${r.machineCode||'-'}</td>
            <td>${r.location||'-'}</td>
            <td>${r.reason||'-'}</td>
            <td>${r.effect||'-'}</td>
            <td>${r.station||'-'}</td>
            <td title="${r.description||''}">${(r.description||'-').substring(0,30)}${(r.description||'').length>30?'…':''}</td>
            <td style="white-space:nowrap">${dt}</td>
            <td style="text-align:center;white-space:nowrap">
                <button class="btn-edit" onclick='openEdit(${JSON.stringify(r)})'>✏ Edit</button>
                <button class="btn-del"  onclick="openConfirm(${r.id},'downtime')" style="margin-left:4px">🗑 Del</button>
            </td>
        </tr>`;
    }).join('');
}

function renderPager(totalPages, current, barId, loadFn) {
    const bar = document.getElementById(barId);
    if (totalPages <= 1) { bar.innerHTML = ''; return; }
    let html = `<span style="color:var(--muted);margin-right:8px;">No. ${current} / ${totalPages} pages</span>`;
    for (let i = 1; i <= totalPages; i++) {
        html += `<button class="pager-btn${i===current?' active':''}" onclick="(${loadFn.name})(${i})">${i}</button>`;
    }
    bar.innerHTML = html;
}

function openEdit(r) {
    document.getElementById('modalId').textContent       = r.id;
    document.getElementById('editId').value              = r.id;
    document.getElementById('editEmpCode').value         = r.employeeCode  || '';
    document.getElementById('editEmpName').value         = r.employeeName  || '';
    document.getElementById('editMachine').value         = r.machineCode   || '';
    document.getElementById('editLocation').value        = r.location      || '';
    document.getElementById('editOperation').value       = r.operation     || '';
    document.getElementById('editState').value           = r.state         || 'STOP';
    document.getElementById('editReason').value          = r.reason        || '';
    document.getElementById('editEffect').value          = r.effect        || '';
    document.getElementById('editStation').value         = r.station       || '';
    document.getElementById('editAction').value          = r.action        || '';
    document.getElementById('editRootCause').value       = r.rootCause     || '';
    document.getElementById('editSpareParts').value      = r.spareParts    || '';
    document.getElementById('editEstimate').value        = r.estimateTime  || '';
    document.getElementById('editDesc').value            = r.description   || '';
    if (r.datetime) {
        const dt  = new Date(r.datetime);
        const pad = n => String(n).padStart(2,'0');
        document.getElementById('editDatetime').value =
            `${dt.getFullYear()}-${pad(dt.getMonth()+1)}-${pad(dt.getDate())}T${pad(dt.getHours())}:${pad(dt.getMinutes())}`;
    } else {
        document.getElementById('editDatetime').value = '';
    }
    document.getElementById('editModal').classList.add('active');
}
function closeEdit() { document.getElementById('editModal').classList.remove('active'); }

async function saveEdit() {
    const payload = {
        id:           parseInt(document.getElementById('editId').value),
        employeeCode: document.getElementById('editEmpCode').value,
        employeeName: document.getElementById('editEmpName').value,
        machineCode:  document.getElementById('editMachine').value,
        location:     document.getElementById('editLocation').value,
        operation:    document.getElementById('editOperation').value,
        state:        document.getElementById('editState').value,
        reason:       document.getElementById('editReason').value,
        effect:       document.getElementById('editEffect').value,
        station:      document.getElementById('editStation').value,
        action:       document.getElementById('editAction').value,
        rootCause:    document.getElementById('editRootCause').value,
        spareParts:   document.getElementById('editSpareParts').value,
        estimateTime: document.getElementById('editEstimate').value,
        description:  document.getElementById('editDesc').value,
        datetime:     document.getElementById('editDatetime').value || null,
    };
    try {
        const res  = await fetch(`${pathBase}/Status/AdminUpdateRecord`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) { closeEdit(); showToast('✅ Saved'); loadRecords(currentPage); }
        else showToast('⚠ ' + (data.message || 'Save failed'));
    } catch { showToast('⚠ Request failed'); }
}

function clearFilters() {
    document.getElementById('fOp').value    = '';
    document.getElementById('fState').value = '';
    document.getElementById('fFrom').value  = '';
    document.getElementById('fTo').value    = '';
    loadRecords(1);
}

// ════════════════════════════════════════
// TAB 2 — EMPLOYEE MANAGEMENT
// ════════════════════════════════════════
let empLoaded = false;
let allEmployees = [];
let empCurrentPage = 1;
const EMP_PAGE_SIZE = 15;

async function loadEmployees() {
    empLoaded = true;
    try {
        const res  = await fetch(`${pathBase}/Status/AdminGetEmployees`);
        const data = await res.json();
        allEmployees = data.employees || [];
        renderEmployees(allEmployees, 1);
    } catch { showToast('⚠ Load failed'); }
}

function filterEmployees() {
    const q = document.getElementById('eSearch').value.trim().toLowerCase();
    const filtered = q
        ? allEmployees.filter(e =>
            (e.employeeID   ||'').toLowerCase().includes(q) ||
            (e.chineseName  ||'').toLowerCase().includes(q) ||
            (e.englishName  ||'').toLowerCase().includes(q))
        : allEmployees;
    renderEmployees(filtered, 1);
}

function renderEmployees(list, page) {
    empCurrentPage = page;
    const totalPages = Math.max(1, Math.ceil(list.length / EMP_PAGE_SIZE));
    const slice = list.slice((page-1)*EMP_PAGE_SIZE, page*EMP_PAGE_SIZE);
    const tbody = document.getElementById('empTbody');

    if (!slice.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:30px;color:#aaa;">No records found</td></tr>';
        document.getElementById('empPagerBar').innerHTML = '';
        return;
    }
    tbody.innerHTML = slice.map(e => `<tr>
        <td><strong>#${e.id}</strong></td>
        <td>${e.employeeID  || '-'}</td>
        <td>${e.chineseName || '-'}</td>
        <td>${e.englishName || '-'}</td>
        <td style="text-align:center;white-space:nowrap">
            <button class="btn-edit" onclick='openEmpModal(${JSON.stringify(e)})'>✏ Edit</button>
            <button class="btn-del"  onclick="openConfirm(${e.id},'employee')" style="margin-left:4px">🗑 Del</button>
        </td>
    </tr>`).join('');

    // Pager
    const bar = document.getElementById('empPagerBar');
    if (totalPages <= 1) { bar.innerHTML = ''; return; }
    let html = `<span style="color:var(--muted);margin-right:8px;">No. ${page} / ${totalPages} pages</span>`;
    for (let i = 1; i <= totalPages; i++) {
        html += `<button class="pager-btn${i===page?' active':''}" onclick="_empGoPage(${i})">${i}</button>`;
    }
    bar.innerHTML = html;
    // store current list for pagination
    bar._list = list;
}

function _empGoPage(p) {
    const q = document.getElementById('eSearch').value.trim().toLowerCase();
    const filtered = q
        ? allEmployees.filter(e =>
            (e.employeeID  ||'').toLowerCase().includes(q) ||
            (e.chineseName ||'').toLowerCase().includes(q) ||
            (e.englishName ||'').toLowerCase().includes(q))
        : allEmployees;
    renderEmployees(filtered, p);
}

function openEmpModal(e = null) {
    document.getElementById('empModalTitle').textContent = e
        ? '✏️ 编辑员工 / Edit Employee'
        : '👤 添加员工 / Add Employee';
    document.getElementById('empId').value      = e ? e.id          : '';
    document.getElementById('empEmpID').value   = e ? e.employeeID  : '';
    document.getElementById('empChinese').value = e ? e.chineseName : '';
    document.getElementById('empEnglish').value = e ? e.englishName : '';
    document.getElementById('empModal').classList.add('active');
}
function closeEmpModal() { document.getElementById('empModal').classList.remove('active'); }

async function saveEmployee() {
    const empID = document.getElementById('empEmpID').value.trim();
    if (!empID) { showToast('⚠ Employee ID is required'); return; }

    const payload = {
        id:          parseInt(document.getElementById('empId').value) || 0,
        employeeID:  empID,
        chineseName: document.getElementById('empChinese').value.trim(),
        englishName: document.getElementById('empEnglish').value.trim(),
    };
    try {
        const res  = await fetch(`${pathBase}/Status/AdminSaveEmployee`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) { closeEmpModal(); showToast('✅ Saved'); loadEmployees(); }
        else showToast('⚠ ' + (data.message || 'Save failed'));
    } catch { showToast('⚠ Request failed'); }
}

// ════════════════════════════════════════
// TAB 3 — ACCOUNT MANAGEMENT
// ════════════════════════════════════════
let accLoaded = false;
let allAccounts = [];
let accCurrentPage = 1;
const ACC_PAGE_SIZE = 15;

async function loadAccounts() {
    accLoaded = true;
    try {
        const res  = await fetch(`${pathBase}/Status/AdminGetAccounts`);
        const data = await res.json();
        allAccounts = data.accounts || [];
        renderAccounts(allAccounts, 1);
    } catch { showToast('⚠ Load failed'); }
}

function filterAccounts() {
    const q = document.getElementById('aSearch').value.trim().toLowerCase();
    const filtered = q
        ? allAccounts.filter(a =>
            (a.username||'').toLowerCase().includes(q) ||
            (a.role    ||'').toLowerCase().includes(q))
        : allAccounts;
    renderAccounts(filtered, 1);
}

function renderAccounts(list, page) {
    accCurrentPage = page;
    const totalPages = Math.max(1, Math.ceil(list.length / ACC_PAGE_SIZE));
    const slice = list.slice((page-1)*ACC_PAGE_SIZE, page*ACC_PAGE_SIZE);
    const tbody = document.getElementById('accTbody');

    if (!slice.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:30px;color:#aaa;">No records found</td></tr>';
        document.getElementById('accPagerBar').innerHTML = '';
        return;
    }

    const roleColor = { Admin: 'badge-admin', Technical: 'badge-tech', Production: 'badge-prod' };
    tbody.innerHTML = slice.map(a => `<tr>
        <td><strong>#${a.id}</strong></td>
        <td><strong>${a.username}</strong></td>
        <td><span style="font-family:monospace;letter-spacing:2px;color:#999">${'●'.repeat(Math.min(a.password.length,8))}</span>
            <span style="font-size:11px;color:#aaa;margin-left:6px">(${a.password.length} chars)</span></td>
        <td><span class="badge ${roleColor[a.role]||'badge-prod'}">${a.role}</span></td>
        <td style="text-align:center;white-space:nowrap">
            <button class="btn-edit"  onclick='openAccModal(${JSON.stringify(a)})'>✏ Edit</button>
            <button class="btn-reset" onclick="openResetPw(${a.id}, '${a.username.replace(/'/g,"\\'")}')" style="margin-left:4px">🔒 Reset</button>
            <button class="btn-del"   onclick="openConfirm(${a.id},'account')" style="margin-left:4px">🗑 Del</button>
        </td>
    </tr>`).join('');

    // Pager
    const bar = document.getElementById('accPagerBar');
    if (totalPages <= 1) { bar.innerHTML = ''; return; }
    let html = `<span style="color:var(--muted);margin-right:8px;">No. ${page} / ${totalPages} pages</span>`;
    for (let i = 1; i <= totalPages; i++) {
        html += `<button class="pager-btn${i===page?' active':''}" onclick="_accGoPage(${i})">${i}</button>`;
    }
    bar.innerHTML = html;
}

function _accGoPage(p) {
    const q = document.getElementById('aSearch').value.trim().toLowerCase();
    const filtered = q
        ? allAccounts.filter(a =>
            (a.username||'').toLowerCase().includes(q) ||
            (a.role    ||'').toLowerCase().includes(q))
        : allAccounts;
    renderAccounts(filtered, p);
}

function openAccModal(a = null) {
    document.getElementById('accModalTitle').textContent = a
        ? '✏️ Edit Account'
        : '🔑 Add Account';
    document.getElementById('accId').value       = a ? a.id       : '';
    document.getElementById('accUsername').value = a ? a.username : '';
    document.getElementById('accPassword').value = a ? a.password : '';
    document.getElementById('accRole').value     = a ? a.role     : 'Production';
    document.getElementById('accModal').classList.add('active');
}
function closeAccModal() { document.getElementById('accModal').classList.remove('active'); }

async function saveAccount() {
    const username = document.getElementById('accUsername').value.trim();
    const password = document.getElementById('accPassword').value.trim();
    if (!username || !password) { showToast('⚠ Username and password cannot be empty'); return; }

    const payload = {
        id:       parseInt(document.getElementById('accId').value) || 0,
        username,
        password,
        role:     document.getElementById('accRole').value,
    };
    try {
        const res  = await fetch(`${pathBase}/Status/AdminSaveAccount`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) { closeAccModal(); showToast('✅ Saved'); loadAccounts(); }
        else showToast('⚠ ' + (data.message || 'Save failed'));
    } catch { showToast('⚠ Request failed'); }
}

// ════════════════════════════════════════
// RESET PASSWORD
// ════════════════════════════════════════
function openResetPw(id, username) {
    document.getElementById('resetPwId').value       = id;
    document.getElementById('resetPwUsername').textContent = username;
    document.getElementById('resetPwNew').value      = '';
    document.getElementById('resetPwModal').classList.add('active');
    setTimeout(() => document.getElementById('resetPwNew').focus(), 100);
}
function closeResetPw() {
    document.getElementById('resetPwModal').classList.remove('active');
}

function genPassword() {
    const chars = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
    let pw = '';
    for (let i = 0; i < 8; i++) pw += chars[Math.floor(Math.random() * chars.length)];
    document.getElementById('resetPwNew').value = pw;
}

async function confirmResetPw() {
    const id  = parseInt(document.getElementById('resetPwId').value);
    const pw  = document.getElementById('resetPwNew').value.trim();
    if (!pw) { showToast('⚠ Please enter a new password'); return; }

    try {
        const res  = await fetch(`${pathBase}/Status/AdminResetPassword`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify({ id, newPassword: pw })
        });
        const data = await res.json();
        if (data.success) {
            closeResetPw();
            showToast('✅ Password reset successfully');
            loadAccounts(); // refresh để cập nhật hiển thị char count
        } else {
            showToast('⚠ ' + (data.message || 'Reset failed'));
        }
    } catch { showToast('⚠ Request failed'); }
}

// ── Init ──
window.addEventListener('DOMContentLoaded', () => loadRecords(1));
</script>

