@model List<MachineStatusUpdate.Models.SVN_Notification>
@{
    ViewData["Title"] = "📬 Production Notifications";
    var username = Context.Session.GetString("UserName") ?? "";
}

<style>
    :root {
        --border:   #e5e7eb;
        --text:     #111827;
        --muted:    #6b7280;
        --bg:       #f9fafb;
        --card-bg:  #ffffff;
    }

    .pn-header {
        background: #111;
        border-top: 4px solid #0d6efd;
        padding: 16px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        border-radius: 10px;
        margin-bottom: 20px;
    }
    .pn-header h1 { margin: 0; color: #fff; font-size: 20px; font-weight: 700; }
    .pn-header .sub { color: #999; font-size: 13px; margin-top: 3px; }

    .pn-body { max-width: 900px; margin: 0 auto; }

    /* Summary */
    .pn-summary {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 20px;
    }
    .pn-sum-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
    }
    .pn-sum-icon { font-size: 26px; }
    .pn-sum-label { font-size: 11px; color: var(--muted); font-weight: 600; text-transform: uppercase; }
    .pn-sum-val { font-size: 26px; font-weight: 800; line-height: 1.1; }
    .val-total    { color: #6366f1; }
    .val-accept   { color: #16a34a; }
    .val-wait     { color: #d97706; }
    .val-fix      { color: #0d6efd; }

    /* Filter tabs */
    .pn-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .pn-tab {
        padding: 7px 16px;
        border-radius: 99px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
        color: var(--muted);
    }
    .pn-tab:hover { border-color: #0d6efd; color: #0d6efd; }
    .pn-tab.active { background: #0d6efd; color: #fff; border-color: #0d6efd; }

    /* Notification list */
    .pn-list { display: flex; flex-direction: column; gap: 10px; }

    .pn-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 16px 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        border-left: 5px solid #e5e7eb;
        position: relative;
        transition: box-shadow .2s;
    }
    .pn-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); }
    .pn-card.unread {
        background: #fef9c3 !important;
        border-left-width: 6px !important;
        box-shadow: 0 0 0 2px rgba(251,191,36,.35), 0 2px 8px rgba(0,0,0,.06);
    }

    /* Mark-read button on each card */
    .pn-mark-read-btn {
        background: none;
        border: 1.5px solid #d1d5db;
        border-radius: 6px;
        cursor: pointer;
        font-size: 11px;
        font-weight: 700;
        color: #6b7280;
        padding: 3px 9px;
        transition: all .15s;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .pn-mark-read-btn:hover { background: #dcfce7; border-color: #22c55e; color: #166534; }

    /* Highlight animation khi navigate từ bell */
    @@keyframes pnHighlight {
        0%   { box-shadow: 0 0 0 4px rgba(59,130,246,.6), 0 4px 20px rgba(59,130,246,.3); }
        70%  { box-shadow: 0 0 0 4px rgba(59,130,246,.6), 0 4px 20px rgba(59,130,246,.3); }
        100% { box-shadow: 0 2px 8px rgba(0,0,0,.04); }
    }
    .pn-card.highlighted {
        animation: pnHighlight 2.5s ease forwards;
        outline: 2px solid #3b82f6;
    }

    .pn-card.type-accept   { border-left-color: #22c55e; }
    .pn-card.type-wait     { border-left-color: #f59e0b; }
    .pn-card.type-fix      { border-left-color: #0d6efd; }
    .pn-card.type-stop     { border-left-color: #ef4444; }
    .pn-card.type-run      { border-left-color: #22c55e; }

    .pn-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 8px;
    }
    .pn-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 99px;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
    }
    .badge-accept { background: #dcfce7; color: #166534; }
    .badge-wait   { background: #fef3c7; color: #92400e; }
    .badge-fix    { background: #dbeafe; color: #1e40af; }
    .badge-stop   { background: #fee2e2; color: #991b1b; }
    .badge-run    { background: #dcfce7; color: #166634; }
    .badge-dri    { background: #f5f3ff; color: #6d28d9; }

    .pn-card.type-dri { border-left-color: #7c3aed; }

    .btn-call-dri {
        background: linear-gradient(135deg, #7c3aed, #a855f7);
        color: #fff; border: none; border-radius: 9px;
        padding: 10px 24px; font-size: 14px; font-weight: 700; cursor: pointer;
        display: inline-flex; align-items: center; gap: 7px;
        box-shadow: 0 3px 12px rgba(124,58,237,.35); transition: all .18s;
    }
    .btn-call-dri:hover  { filter: brightness(1.08); transform: translateY(-1px); }
    .btn-call-dri:active { transform: translateY(1px); }
    .btn-call-dri:disabled { opacity: .55; cursor: not-allowed; transform: none; }
    .dri-called-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; background: #f5f3ff; color: #6d28d9;
        border-radius: 9px; font-size: 13px; font-weight: 700;
        border: 1px solid #ddd6fe;
    }
    .badge-stop   { background: #fee2e2; color: #991b1b; }
    .badge-run    { background: #dcfce7; color: #166534; }

    .pn-time { font-size: 12px; color: var(--muted); }

    .pn-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
    }
    .pn-body-text {
        font-size: 13px;
        color: #374151;
        line-height: 1.5;
        margin-bottom: 6px;
    }
    .pn-meta {
        font-size: 11px;
        color: var(--muted);
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }
    .pn-unread-dot {
        display: inline-block;
        width: 8px; height: 8px;
        background: #ef4444;
        border-radius: 50%;
        margin-left: 6px;
        vertical-align: middle;
        flex-shrink: 0;
    }

    .pn-run-action {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
    }
    .btn-pn-run {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: #fff;
        border: none;
        border-radius: 9px;
        padding: 10px 28px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        box-shadow: 0 3px 12px rgba(34,197,94,.35);
        transition: all .18s;
    }
    .btn-pn-run:hover  { filter: brightness(1.08); transform: translateY(-1px); }
    .btn-pn-run:active { transform: translateY(1px); }
    .btn-pn-run:disabled { opacity: .55; cursor: not-allowed; transform: none; }
    .run-done-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: #dcfce7;
        color: #166534;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        border: 1px solid #bbf7d0;
    }
        text-align: center;
        padding: 60px 20px;
        color: var(--muted);
        font-size: 15px;
    }
    .pn-empty .empty-icon { font-size: 48px; display: block; margin-bottom: 12px; }

    /* ── Pagination ── */
    .pn-pagination-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
    }
    .pn-page-info {
        font-size: 13px;
        color: var(--muted);
    }
    .pn-page-info strong { color: var(--text); }
    .pn-page-btns {
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .pn-page-btn {
        min-width: 34px;
        height: 34px;
        padding: 0 10px;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        color: var(--text);
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .pn-page-btn:hover:not(:disabled) { border-color: #0d6efd; color: #0d6efd; background: #eff6ff; }
    .pn-page-btn.active { background: #0d6efd; color: #fff; border-color: #0d6efd; }
    .pn-page-btn:disabled { opacity: .4; cursor: not-allowed; }
    .pn-page-dots {
        min-width: 34px;
        text-align: center;
        font-size: 13px;
        color: var(--muted);
        letter-spacing: 2px;
    }

    /* Page size selector */
    .pn-pagesize {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--muted);
    }
    .pn-pagesize select {
        border: 1.5px solid var(--border);
        border-radius: 6px;
        padding: 4px 8px;
        font-size: 13px;
        color: var(--text);
        cursor: pointer;
        outline: none;
    }
    .pn-pagesize select:focus { border-color: #0d6efd; }

    /* Delete button */
    .pn-delete-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: #d1d5db;
        font-size: 16px;
        line-height: 1;
        padding: 2px 5px;
        border-radius: 5px;
        transition: color .15s, background .15s;
        flex-shrink: 0;
    }
    .pn-delete-btn:hover { color: #ef4444; background: #fee2e2; }

    /* Date filter bar */
    .pn-date-filter {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 14px;
        padding: 12px 16px;
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 10px;
    }
    .pn-date-filter label { font-size: 13px; font-weight: 600; color: var(--muted); white-space: nowrap; }
    .pn-date-filter input[type="date"] {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: 6px 10px;
        font-size: 13px;
        color: var(--text);
        outline: none;
        cursor: pointer;
    }
    .pn-date-filter input[type="date"]:focus { border-color: #0d6efd; }
    .pn-filter-btn {
        padding: 7px 16px;
        border-radius: 8px;
        border: none;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: filter .15s;
    }
    .pn-filter-btn:hover { filter: brightness(1.08); }
    .pn-filter-btn.apply { background: #0d6efd; color: #fff; }
    .pn-filter-btn.clear { background: #f3f4f6; color: #374151; border: 1.5px solid var(--border); }

    @@media (max-width: 600px) {
        .pn-summary { grid-template-columns: 1fr 1fr; }
        .pn-pagination-wrap { flex-direction: column; align-items: flex-start; }
        .pn-date-filter { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="pn-header">
    <div>
        <h1 data-i18n="prodNotifs.pageTitle">📬 Production Notifications</h1>
        <div class="sub" data-i18n="prodNotifs.subtitle">All notifications of Production</div>
    </div>
    <span style="background:#1e40af;color:#fff;padding:6px 14px;border-radius:99px;font-size:13px;font-weight:600;">
        👤 @username
    </span>
</div>

<div class="pn-body">

    @{
        var total   = Model.Count;
        var accepts = Model.Count(n => n.TechAction == "ACCEPT");
        var waits   = Model.Count(n => n.TechAction == "WAIT");
        var fixes   = Model.Count(n => n.NotifType == "FIX_COMPLETE");
    }

    <!-- Summary -->
    <div class="pn-summary">
        <div class="pn-sum-card">
            <div class="pn-sum-icon">📋</div>
            <div>
                <div class="pn-sum-label" data-i18n="prodNotifs.totalNotifs">Total Notifications</div>
                <div class="pn-sum-val val-total">@total</div>
            </div>
        </div>
        <div class="pn-sum-card">
            <div class="pn-sum-icon">✅</div>
            <div>
                <div class="pn-sum-label" data-i18n="prodNotifs.accepted">Accepted</div>
                <div class="pn-sum-val val-accept">@accepts</div>
            </div>
        </div>
        <div class="pn-sum-card">
            <div class="pn-sum-icon">⏳</div>
            <div>
                <div class="pn-sum-label" data-i18n="prodNotifs.waiting">Waiting</div>
                <div class="pn-sum-val val-wait">@waits</div>
            </div>
        </div>
        <div class="pn-sum-card">
            <div class="pn-sum-icon">🔧</div>
            <div>
                <div class="pn-sum-label" data-i18n="prodNotifs.fixComplete">Fix Complete</div>
                <div class="pn-sum-val val-fix">@fixes</div>
            </div>
        </div>
    </div>

    <!-- Date filter bar -->
    <div class="pn-date-filter">
        <label>📅 <span data-i18n="common.date">Date</span>:</label>
        <input type="date" id="filterFrom">
        <span style="color:#6b7280;font-size:13px;">—</span>
        <input type="date" id="filterTo">
        <button class="pn-filter-btn apply" onclick="applyDateFilter()">🔍 <span data-i18n="common.filter">Filter</span></button>
        <button class="pn-filter-btn clear" onclick="clearDateFilter()">✕ <span data-i18n="common.clear">Clear</span></button>
        <span id="dateFilterInfo" style="font-size:12px;color:#6b7280;margin-left:4px;"></span>
    </div>

    <!-- Filter tabs -->
    <div class="pn-tabs">
        <button class="pn-tab active" onclick="setFilter('ALL', this)" data-i18n="prodNotifs.allTab">All (@total)</button>
        <button class="pn-tab" onclick="setFilter('ACCEPT', this)" data-i18n="prodNotifs.acceptTab">✅ Accepted (@accepts)</button>
        <button class="pn-tab" onclick="setFilter('WAIT', this)" data-i18n="prodNotifs.waitTab">⏳ Waiting (@waits)</button>
        <button class="pn-tab" onclick="setFilter('FIX_COMPLETE', this)" data-i18n="prodNotifs.fixTab">🔧 Fix Complete (@fixes)</button>
    </div>

    <!-- Notification cards -->
    <div class="pn-list" id="pnList">
        @if (!Model.Any())
        {
            <div class="pn-empty">
                <span class="empty-icon">📭</span>
                <span data-i18n="prodNotifs.noNotifs">No notifications for the selected filter.</span><br>
                <small style="font-size:13px;margin-top:6px;display:block;">
                    When technicians respond to your downtime calls, notifications will appear here.
                </small>
            </div>
        }
        else
        {
            foreach (var n in Model)
            {
                var isAccept   = n.TechAction == "ACCEPT";
                var isWait     = n.TechAction == "WAIT";
                var isFix      = n.NotifType == "FIX_COMPLETE";
                var isRun      = n.NotifType == "RUN";
                var isCallDRI  = n.NotifType == "CALL_DRI_REQUEST";

                string typeClass = isFix     ? "type-fix"
                                 : isCallDRI ? "type-dri"
                                 : isAccept  ? "type-accept"
                                 : isWait    ? "type-wait"
                                 : isRun     ? "type-run"
                                 : "type-stop";

                string badgeClass = isFix     ? "badge-fix"
                                  : isCallDRI ? "badge-dri"
                                  : isAccept  ? "badge-accept"
                                  : isWait    ? "badge-wait"
                                  : isRun     ? "badge-run"
                                  : "badge-stop";

                string icon = isFix     ? "🔧 Fixed"
                            : isCallDRI ? "🏢 Call Relevant Dept"
                            : isAccept  ? "✅ Accepted"
                            : isWait    ? "⏳ Waiting"
                            : isRun     ? "▶ Running"
                            : "🛑 Downtime Notification";

                string dataFilter = isFix     ? "FIX_COMPLETE"
                                  : isCallDRI ? "CALL_DRI"
                                  : isAccept  ? "ACCEPT"
                                  : isWait    ? "WAIT"
                                  : "OTHER";

                <div class="pn-card @typeClass @(!n.IsRead ? "unread" : "")" data-filter="@dataFilter" data-date="@n.CreatedAt.ToString("yyyy-MM-dd")" data-id="@n.Id" id="pn-card-@n.Id">
                    <div class="pn-card-top">
                        <span class="pn-badge @badgeClass">@icon</span>
                        <div style="display:flex;align-items:center;gap:8px;">
                            @if (!n.IsRead)
                            {
                                <button class="pn-mark-read-btn" onclick="markProdCardRead(this, @n.Id)" title="Mark as read">✓ Mark read</button>
                                <span class="pn-unread-dot" title="Unread"></span>
                            }
                            <span class="pn-time">🕐 @n.CreatedAt.ToString("HH:mm")</span>
                            <button class="pn-delete-btn" onclick="deleteNotif(this, @n.Id)" title="Delete this notification">🗑</button>
                        </div>
                    </div>
                    <div class="pn-title">@n.Title</div>
                    @if (!string.IsNullOrEmpty(n.Body))
                    {
                        <div class="pn-body-text">@n.Body</div>
                    }
                    <div class="pn-meta">
                        @if (!string.IsNullOrEmpty(n.MachineCode))
                        {
                            <span>🔩 <span data-i18n="prodNotifs.machine">Machine</span>: <strong>@n.MachineCode</strong></span>
                        }
                        @if (!string.IsNullOrEmpty(n.Operation))
                        {
                            <span>📍 <span data-i18n="prodNotifs.line">Line</span>: <strong>@n.Operation</strong></span>
                        }
                        @if (!string.IsNullOrEmpty(n.TechName))
                        {
                            <span>👨‍🔧 <span data-i18n="prodNotifs.employee">Employee</span>: <strong>@n.TechName</strong></span>
                        }
                    </div>
                    @if (isFix)
                    {
                        var prodRunMap = ViewBag.ProdRunMap as Dictionary<int, bool>;
                        var alreadyRun = prodRunMap != null && prodRunMap.TryGetValue(n.Id, out var ran) && ran;
                        <div class="pn-run-action" id="run-action-@n.Id">
                            @if (alreadyRun)
                            {
                                <span class="run-done-badge" data-i18n="prodNotifs.runningMsg">▶ Running / Machine is Running ✓</span>
                            }
                            else
                            {
                                <button class="btn-pn-run"
                                        onclick="prodRunMachine(this, '@n.MachineCode', '@n.Operation', '@n.Id', '@n.TechName')"
                                        title="Confirm machine is restored and record run"
                                        data-i18n="prodNotifs.runMachine">
                                    ▶ Run Machine
                                </button>
                            }
                        </div>
                    }
                    @if (isCallDRI)
                    {
                        var driCalledMap = ViewBag.DRICalledMap as Dictionary<int, bool>;
                        var alreadyCalled = driCalledMap != null && driCalledMap.TryGetValue(n.Id, out var called) && called;
                        <div class="pn-run-action" id="dri-action-@n.Id">
                            @if (alreadyCalled)
                            {
                                <span class="dri-called-badge">🏢 DRI department has been notified ✓</span>
                            }
                            else
                            {
                                <button class="btn-call-dri"
                                        onclick="prodCallDRI(this, @(n.TechResponseId ?? 0), '@n.MachineCode', @n.Id)"
                                        title="Call PDE/QUAL/FAC/IT department"
                                        data-i18n="prodNotifs.callDRI">
                                    📞 Call DRI
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>

    <!-- Pagination controls -->
    <div class="pn-pagination-wrap" id="paginationWrap" style="display:none;">
        <div class="pn-page-info" id="pageInfo"></div>
        <div class="pn-page-btns" id="pageBtns"></div>
        <div class="pn-pagesize">
            <span data-i18n="common.pageSize">Page</span>:
            <select id="pageSizeSelect" onchange="changePageSize(this.value)">
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
        </div>
    </div>

</div>

<script>

// ════ SOUND & BELL cho Production ════
let prodAudioCtx = null;
let prodUnreadCount = 0;

function ensureProdAudio() {
    if (prodAudioCtx) return prodAudioCtx;
    try {
        prodAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
        if (prodAudioCtx.state === 'suspended') prodAudioCtx.resume();
    } catch(e) {}
    return prodAudioCtx;
}
['click','touchstart','keydown'].forEach(e =>
    document.addEventListener(e, () => ensureProdAudio(), { once: false, passive: true })
);

function playProdSound() {
    const ctx = ensureProdAudio();
    if (!ctx) return;
    if (ctx.state === 'suspended') ctx.resume();
    [[0, 660],[0.25, 880]].forEach(([offset, freq]) => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine'; osc.frequency.value = freq;
        const t = ctx.currentTime + offset;
        gain.gain.setValueAtTime(0.5, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.3);
        osc.start(t); osc.stop(t + 0.35);
    });
}

function updateBell(count) {
    const badge = document.getElementById('bellBadge');
    if (!badge) return;
    if (count > 0) {
        badge.textContent = count > 9 ? '9+' : count;
        badge.style.display = 'inline-flex';
    } else {
        badge.style.display = 'none';
    }
}

function showProdToast(msg, type) {
    let toast = document.getElementById('prodToast');
    if (!toast) {
        toast = document.createElement('div');
        toast.id = 'prodToast';
        document.body.appendChild(toast);
    }
    const colors = {
        accept: ['#16a34a','#22c55e'],
        reject: ['#b91c1c','#ef4444'],
        fix:    ['#0d6efd','#3b82f6']
    };
    const [bg, border] = colors[type] || colors.accept;
    toast.style.cssText = `
        position:fixed;bottom:24px;right:24px;z-index:99999;
        max-width:380px;padding:14px 18px;border-radius:12px;
        font-size:13px;font-weight:600;color:#fff;
        box-shadow:0 8px 28px rgba(0,0,0,.25);
        border-left:5px solid ${border};background:${bg};
        animation:prodToastIn .25s ease;
    `;
    toast.textContent = msg;
    clearTimeout(toast._t);
    toast._t = setTimeout(() => toast.remove(), 6000);
}

// Thêm CSS animation 1 lần
if (!document.getElementById('prodToastStyle')) {
    const s = document.createElement('style');
    s.id = 'prodToastStyle';
    s.textContent = `@@keyframes prodToastIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}`;
    document.head.appendChild(s);
}

// ════ SignalR listeners ════
if (typeof connection !== 'undefined') {
    connection.on("ReceiveTechResponse", function(data) {
        playProdSound();
        prodUnreadCount++;
        updateBell(prodUnreadCount);
        showProdToast(
            data.action === 'ACCEPT'
                ? `✅ ${window.i18nT('prodNotifs.employee')} [${data.techName}] ${window.i18nT('prodNotifs.techResponse')} ${data.machineCode}`
                : `⏳ [${data.techName}] ${window.i18nT('prodNotifs.waiting')}`,
            'accept'
        );
    });

    connection.on("ReceiveTechReject", function(data) {
        playProdSound();
        prodUnreadCount++;
        updateBell(prodUnreadCount);
        showProdToast(
            `❌ [${data.techName}] — ${window.i18nT('prodNotifs.machine')}: ${data.machineCode}`
            + (data.rejectReason ? ` | ${data.rejectReason}` : ''),
            'reject'
        );
    });

    connection.on("ReceiveFixComplete", function(data) {
        playProdSound();
        prodUnreadCount++;
        updateBell(prodUnreadCount);
        showProdToast(`🔧 ${window.i18nT('prodNotifs.machine')} ${data.machineCode} — ${window.i18nT('prodNotifs.fixComplete')}!`, 'fix');
    });

    // PIE xác nhận không phải E&F → Prod nhận yêu cầu call DRI
    connection.on("ReceiveCallDRIRequest", function(data) {
        playProdSound();
        prodUnreadCount++;
        updateBell(prodUnreadCount);
        showProdToast(`🏢 ${window.i18nT('prodNotifs.machine')} ${data.machineCode} — PIE: Not E&F issue. ${window.i18nT('prodNotifs.callDRI')}!`, 'fix');
    });
}

// ════ PROD bấm "Call DRI" ════
async function prodCallDRI(btn, techResponseId, machineCode, notifId) {
    if (!techResponseId) { alert('Cannot find tech response ID!'); return; }

    btn.disabled  = true;
    btn.innerHTML = `⏳ ${window.i18nT('common.loading') || 'Calling...'}`;

    try {
        const res  = await fetch('/downtime/Status/ProdCallDRI', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ techResponseId })
        });
        const data = await res.json();
        if (data.success) {
            const actionDiv = document.getElementById(`dri-action-${notifId}`);
            if (actionDiv) {
                actionDiv.innerHTML = `<span class="dri-called-badge">🏢 DRI department has been notified ✓</span>`;
            }
            showProdToast(`🏢 ${window.i18nT('prodNotifs.callDRI')} — ${window.i18nT('prodNotifs.machine')}: ${machineCode}!`, 'fix');
        } else {
            btn.disabled  = false;
            btn.innerHTML = `📞 ${window.i18nT('prodNotifs.callDRI') || 'Call DRI'}`;
            showProdToast('❌ ' + (data.message || 'Error'), 'reject');
        }
    } catch(e) {
        btn.disabled  = false;
        btn.innerHTML = `📞 ${window.i18nT('prodNotifs.callDRI') || 'Call DRI'}`;
        showProdToast(`❌ ${window.i18nT('common.connectionError') || 'Connection error'}`, 'reject');
    }
}

// ════ Xóa thông báo ════
async function deleteNotif(btn, id) {
    if (!confirm(`${window.i18nT('common.confirmDelete') || 'Delete this notification?'}`)) return;
    btn.disabled = true;
    btn.textContent = '…';
    try {
        const res  = await fetch('/downtime/Status/DeleteMyNotification', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ id })
        });
        const json = await res.json();
        if (json.success) {
            const card = btn.closest('.pn-card');
            card.style.transition = 'opacity .2s, transform .2s';
            card.style.opacity    = '0';
            card.style.transform  = 'translateX(30px)';
            // Sync bell ngay lập tức
            if (typeof window.loadNotifications === 'function') window.loadNotifications();
            setTimeout(() => {
                card.remove();
                if (!document.querySelector('#pnList .pn-card')) {
                    document.getElementById('pnList').innerHTML =
                        `<div class="pn-empty"><span class="empty-icon">📭</span>${window.i18nT('prodNotifs.noNotifs') || 'No notifications for the selected filter.'}</div>`;
                }
                if (typeof window._pnRender === 'function') window._pnRender();
            }, 220);
        } else {
            btn.disabled = false;
            btn.textContent = '🗑';
            alert(json.message || `${window.i18nT('common.deleteFailed') || 'Delete failed'}`);
        }
    } catch(e) {
        btn.disabled = false;
        btn.textContent = '🗑';
        alert(`${window.i18nT('common.deleteFailed') || 'Delete failed'}`);
    }
}

// ════ Date filter ════
function applyDateFilter() {
    const from = document.getElementById('filterFrom').value; // "yyyy-MM-dd"
    const to   = document.getElementById('filterTo').value;
    const info = document.getElementById('dateFilterInfo');
    let shown = 0, hidden = 0;

    document.querySelectorAll('#pnList .pn-card').forEach(card => {
        const d = card.dataset.date || '';
        let visible = true;
        if (from && d < from) visible = false;
        if (to   && d > to)   visible = false;
        card.dataset.dateHidden = visible ? '0' : '1';
        // chỉ ẩn nếu đang display != none từ filter tab
        if (!visible) { card.style.display = 'none'; hidden++; }
        else shown++;
    });

    if (from || to) {
        info.textContent = `${window.i18nT('common.showing') || 'Showing'} ${shown}, ${window.i18nT('common.hidden') || 'hidden'} ${hidden}`;
    } else {
        info.textContent = '';
    }
}

function clearDateFilter() {
    document.getElementById('filterFrom').value = '';
    document.getElementById('filterTo').value   = '';
    document.getElementById('dateFilterInfo').textContent = '';
    document.querySelectorAll('#pnList .pn-card').forEach(c => {
        c.dataset.dateHidden = '0';
        // Cho pagination tự xử lý display — chỉ bỏ force-hide
        c.style.display = '';
    });
    // Re-trigger pagination render
    if (typeof window._pnRender === 'function') window._pnRender();
}

// ════ Mark single prod card as read ════
async function markProdCardRead(btn, id) {
    try {
        await fetch('/Status/MarkNotificationRead', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ id })
        });
    } catch(e) {}
    const card = btn.closest('.pn-card');
    card.classList.remove('unread');
    // Remove dot and button
    const dot = card.querySelector('.pn-unread-dot');
    if (dot) dot.remove();
    btn.remove();
    // Reload bell badge in layout
    if (typeof window.loadNotifications === 'function') window.loadNotifications();
}

// ════ Scroll & highlight card từ bell click ════
window.scrollToProdCard = function(id) {
    const card = document.getElementById('pn-card-' + id);
    if (!card) return;
    // Nếu card đang ẩn (pagination), đổi về trang có card đó
    if (card.style.display === 'none') {
        // Bỏ filter, show all rồi render lại
        window.setFilter('ALL', document.querySelector('.pn-tab'));
        if (typeof window._pnRender === 'function') window._pnRender();
    }
    setTimeout(() => {
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        card.classList.add('highlighted');
        setTimeout(() => card.classList.remove('highlighted'), 3000);
    }, 150);
};

// ════ Xử lý ?highlight=<id> khi navigate từ bell ════
(function() {
    const params = new URLSearchParams(window.location.search);
    const hid = params.get('highlight');
    if (hid) {
        // Đợi render xong rồi scroll
        setTimeout(() => window.scrollToProdCard(parseInt(hid)), 400);
        // Clean URL
        const url = new URL(window.location.href);
        url.searchParams.delete('highlight');
        history.replaceState(null, '', url.toString());
    }
})();


(function () {
    // ── State ──
    let currentFilter = 'ALL';
    let currentPage   = 1;
    let pageSize      = 10;

    // ── Helpers ──
    function getAllCards() {
        return Array.from(document.querySelectorAll('#pnList .pn-card'));
    }

    function getVisibleCards() {
        return getAllCards().filter(c =>
            (currentFilter === 'ALL' || c.dataset.filter === currentFilter)
            && c.dataset.dateHidden !== '1'
        );
    }

    // ── Render ──
    function render() {
        const cards   = getVisibleCards();
        const total   = cards.length;
        const pages   = Math.max(1, Math.ceil(total / pageSize));
        if (currentPage > pages) currentPage = pages;

        const start = (currentPage - 1) * pageSize;
        const end   = start + pageSize;

        // Show / hide all cards
        getAllCards().forEach(c => c.style.display = 'none');
        cards.forEach((c, i) => {
            c.style.display = (i >= start && i < end) ? '' : 'none';
        });

        // Pagination controls
        const wrap = document.getElementById('paginationWrap');
        if (total === 0) { wrap.style.display = 'none'; return; }
        wrap.style.display = total <= pageSize ? 'none' : 'flex';

        // Info text
        const showing = Math.min(end, total);
        document.getElementById('pageInfo').innerHTML =
            `${window.i18nT('common.showing') || 'Showing'} <strong>${start + 1}–${showing}</strong> / <strong>${total}</strong>`;

        // Page buttons
        renderPageBtns(pages);
    }

    function renderPageBtns(pages) {
        const container = document.getElementById('pageBtns');
        container.innerHTML = '';

        function btn(label, page, active, disabled) {
            const b = document.createElement('button');
            b.className = 'pn-page-btn' + (active ? ' active' : '');
            b.textContent = label;
            b.disabled = disabled;
            if (!disabled && !active) b.onclick = () => goToPage(page);
            container.appendChild(b);
        }

        function dots() {
            const d = document.createElement('span');
            d.className = 'pn-page-dots';
            d.textContent = '…';
            container.appendChild(d);
        }

        // Prev
        btn('‹', currentPage - 1, false, currentPage === 1);

        // Page numbers with smart ellipsis
        const delta = 1;
        const range = [];
        for (let p = 1; p <= pages; p++) {
            if (p === 1 || p === pages ||
                (p >= currentPage - delta && p <= currentPage + delta)) {
                range.push(p);
            }
        }

        let prev = 0;
        range.forEach(p => {
            if (p - prev > 1) dots();
            btn(p, p, p === currentPage, false);
            prev = p;
        });

        // Next
        btn('›', currentPage + 1, false, currentPage === pages);
    }

    // ── Public API ──
    window.setFilter = function (type, tabEl) {
        currentFilter = type;
        currentPage   = 1;

        document.querySelectorAll('.pn-tab').forEach(t => t.classList.remove('active'));
        tabEl.classList.add('active');

        render();
    };

    window.changePageSize = function (val) {
        pageSize    = parseInt(val, 10);
        currentPage = 1;
        render();
    };

    function goToPage(p) {
        currentPage = p;
        render();
        document.getElementById('pnList').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ── Init ──
    window._pnRender = render;
    render();
})();

// ════ PROD bấm Run từ FIX_COMPLETE notification ════
async function prodRunMachine(btn, machineCode, operation, notifId, techName) {
    if (!machineCode) { alert('Cannot find machine code!'); return; }

    btn.disabled  = true;
    btn.innerHTML = `⏳ ${window.i18nT('common.loading') || 'Processing...'}`;

    try {
        const fd = new FormData();
        fd.append('State',       'RUN');
        fd.append('MachineCode', machineCode);
        fd.append('Operation',   operation || '');
        fd.append('Action',      '');

        // Lấy thông tin từ STOP record gốc — Employee + các field kỹ thuật Tech đã điền
        // Đồng thời lấy tên Tech thực sự từ TechResponse
        let actualTechName = techName; // fallback
        try {
            const stopRes  = await fetch(`/downtime/Status/GetLatestStopByMachine?machineNo=${encodeURIComponent(machineCode)}`);
            const stopData = await stopRes.json();
            if (stopData.exists) {
                fd.append('EmployeeCode', stopData.data?.employeeCode || '');
                fd.append('EmployeeName', stopData.data?.employeeName || '');
                fd.append('Location',     stopData.data?.opValue      || '');
                fd.append('Reason',       stopData.data?.reason       || '');
                fd.append('Effect',       stopData.data?.effect       || '');
                fd.append('RootCause',    stopData.data?.rootCause    || '');
                fd.append('SpareParts',   stopData.data?.spareParts   || '');
            }
            // Lấy tên Tech PIE từ TechResponse (EmployeeName của RESPONSE record)
            const techRes  = await fetch(`/downtime/Status/GetTechNameByMachine?machineNo=${encodeURIComponent(machineCode)}`);
            const techData = await techRes.json();
            if (techData.techName) actualTechName = techData.techName;
        } catch (e) { console.warn('GetLatestStopByMachine failed:', e); }

        const res  = await fetch('/downtime/Status/CreateDownTime', { method: 'POST', body: fd });
        const data = await res.json();

        if (data?.success) {
            const actionDiv = document.getElementById('run-action-' + notifId);
            if (actionDiv) {
                actionDiv.innerHTML = `<span class="run-done-badge">${window.i18nT('prodNotifs.runningMsg') || '▶ Machine is Running ✓'}</span>`;
            }
            showProdToast(`✅ ${window.i18nT('prodNotifs.runningMsg') || 'Production resumed'}!`, 'fix');
        } else {
            btn.disabled  = false;
            btn.innerHTML = `▶ ${window.i18nT('prodNotifs.runMachine') || 'Run Machine'}`;
            showProdToast('❌ ' + (data?.message || `${window.i18nT('common.error') || 'Error'}`), 'reject');
        }
    } catch (err) {
        console.error('prodRunMachine error:', err);
        btn.disabled  = false;
        btn.innerHTML = `▶ ${window.i18nT('prodNotifs.runMachine') || 'Run Machine'}`;
        showProdToast(`❌ ${window.i18nT('common.connectionError') || 'Connection error'}!`, 'reject');
    }
}

