    /* ============ Load trạng thái operation ============ */
    async function onOperationChanged() {
        updateDatetimeRange();
        setReasonEnabled(true);
        setEstimateEnabled(true);

        const op = (opEl?.value || '').trim();
        if (!op) return;

        try {
            const url = `${pathBase}/Status/GetLatestDowntimeForOperation?operation=${encodeURIComponent(op)}`;
            const res  = await fetch(url);
            if (!res.ok) { showToast('无法检查最新状态！', 'error', 2400); return; }
            const data = await res.json();

            if (!data?.exists) {
                if (timeLabel) timeLabel.textContent = '停止开始时间 (Stop start time)';
                setReasonEnabled(true);
                setEstimateEnabled(true);
                if (IssCodeEl) { IssCodeEl.selectedIndex = 0; syncSelectColor(IssCodeEl); }
                return;
            }

            const stateNorm = String(data.state || '').trim().toUpperCase();

            if (stateNorm === 'RUN') {
                if (timeLabel) timeLabel.textContent = '停止开始时间 (Stop start time)';
                setReasonEnabled(true);
                setEstimateEnabled(true);
            } else if (stateNorm === 'STOP') {
                if (timeLabel) timeLabel.textContent = '停止结束时间 (Stop end time)';
                const oldDesc = (data.issCode || '').trim();
                if (IssCodeEl) {
                    let opt = Array.from(IssCodeEl.options).find(o => o.value === oldDesc);
                    if (!opt) {
                        const temp = document.createElement('option');
                        temp.value = temp.textContent = oldDesc || '(空白)';
                        temp.dataset.temp = '1';
                        IssCodeEl.appendChild(temp);
                    }
                    IssCodeEl.value = oldDesc;
                    syncSelectColor(IssCodeEl);
                }
                setReasonEnabled(false);
                setEstimateEnabled(false);
            } else {
                setReasonEnabled(true);
                setEstimateEnabled(true);
            }
        } catch (e) {
            console.error(e);
            showToast('状态查询错误！ (Error checking status!)', 'error', 2400);
        }
    }

    /* ======== Image upload ======== */
    let selectedFileDT = null;

    function handleImageSelectDT(file) {
        if (!file) return;
        const allowed = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/bmp'];
        if (!allowed.includes(file.type)) {
            showToast('只允许上传图片格式：JPG、PNG、GIF、BMP', 'error', 3000);
            return;
        }
        if (file.size > 5 * 1024 * 1024) {
            showToast('图片大小不能超过5MB', 'error', 3000);
            return;
        }
        selectedFileDT = file;
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('previewImgDT').src = e.target.result;
            document.getElementById('fileInfoDT').textContent =
                `${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
            document.getElementById('imagePreviewDT').style.display   = 'block';
            document.getElementById('imageUploadAreaDT').style.display = 'none';
        };
        reader.readAsDataURL(file);
    }

    function removeImageDT() {
        selectedFileDT = null;
        const input = document.getElementById('imageInputDT');
        if (input) input.value = '';
        document.getElementById('imagePreviewDT').style.display    = 'none';
        document.getElementById('imageUploadAreaDT').style.display  = 'block';
