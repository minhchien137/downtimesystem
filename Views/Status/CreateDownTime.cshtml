    /* =============================== Searchable Machine Dropdown ====================================== */
    const machineTrigger     = document.getElementById('machineTrigger');
    const machineDropdown    = document.getElementById('machineDropdown');
    const machineSearchInput = document.getElementById('machineSearchInput');
    const machineOptionList  = document.getElementById('machineOptionList');
    const machineTriggerText = document.getElementById('machineTriggerText');
    const machineValueInput  = document.getElementById('MachineNo');

    let machineFocusedIndex = -1;

    function getVisibleMachineOptions() {
        return Array.from(machineOptionList.querySelectorAll('.select-search-option:not([style*="display: none"])'));
    }

    function toggleMachineDropdown() {
        machineDropdown.classList.contains('open') ? closeMachineDropdown() : openMachineDropdown();
    }

    function openMachineDropdown() {
        machineDropdown.classList.add('open');
        machineTrigger.classList.add('open');
        machineTrigger.setAttribute('aria-expanded', 'true');
        machineSearchInput.value = '';
        filterMachineOptions('');
        machineFocusedIndex = -1;
        setTimeout(() => machineSearchInput.focus(), 30);
    }

    function closeMachineDropdown() {
        machineDropdown.classList.remove('open');
        machineTrigger.classList.remove('open');
        machineTrigger.setAttribute('aria-expanded', 'false');
        machineFocusedIndex = -1;
    }

    function filterMachineOptions(query) {
        const q = query.trim().toLowerCase();
        const opts = machineOptionList.querySelectorAll('.select-search-option');
        let visibleCount = 0;

        opts.forEach(opt => {
            const label = (opt.dataset.label || '').toLowerCase();
            const value = (opt.dataset.value || '').toLowerCase();
            const isPlaceholder = opt.classList.contains('placeholder-opt');

            if (isPlaceholder) { opt.style.display = q ? 'none' : ''; return; }

            const match = !q || label.includes(q) || value.includes(q);
            opt.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        let emptyEl = machineOptionList.querySelector('.select-search-empty');
        if (visibleCount === 0) {
            if (!emptyEl) {
                emptyEl = document.createElement('div');
                emptyEl.className = 'select-search-empty';
                emptyEl.textContent = window.i18nT('common.noData');
                machineOptionList.appendChild(emptyEl);
            }
        } else if (emptyEl) {
            emptyEl.remove();
        }

        machineFocusedIndex = -1;
        updateFocusedMachineOption();
    }

    function updateFocusedMachineOption() {
        const visible = getVisibleMachineOptions();
        visible.forEach((opt, i) => {
            opt.classList.toggle('focused', i === machineFocusedIndex);
            if (i === machineFocusedIndex) opt.scrollIntoView({ block: 'nearest' });
        });
    }

    /* ── selectMachineOption với auto-fill từ Stop gần nhất ── */
    async function selectMachineOption(opt) {
        const value = opt.dataset.value || '';
        const label = opt.dataset.label || '';
        const isPlaceholder = opt.classList.contains('placeholder-opt');

        machineValueInput.value = value;

        if (isPlaceholder || !value) {
            machineTriggerText.textContent = window.i18nT('createDowntime.selectMachine');
            machineTriggerText.classList.remove('has-value');
        } else {
            machineTriggerText.textContent = label;
            machineTriggerText.classList.add('has-value');
        }

        machineOptionList.querySelectorAll('.select-search-option').forEach(o =>
            o.classList.toggle('selected', o === opt)
        );

        closeMachineDropdown();
        machineTrigger.focus();

        // ── Auto-fill từ lần Stop gần nhất theo Machine ──
        if (value) {
            try {
                const url = `${pathBase}/Status/GetLatestStopByMachine?machineNo=${encodeURIComponent(value)}`;
                const res  = await fetch(url);
                if (!res.ok) return;
                const json = await res.json();
                if (!json.exists) return;

                const d = json.data;

                // ✅ Auto-fill Employee — dùng employeeCode từ response
                if (d.svnCode || d.employeeCode) {
                    const empCode = (d.svnCode || d.employeeCode || '').trim();
                    employeeCodeEl.value = empCode;
                    const empOpt = Array.from(empOptionList.querySelectorAll('.select-search-option'))
                        .find(o => (o.dataset.value || '').toLowerCase() === empCode.toLowerCase());
                    if (empOpt) {
                        employeeNameEl.value = empOpt.dataset.chinese || empCode;
                        empTriggerText.textContent = empOpt.dataset.label || empCode;
                        empTriggerText.classList.add('has-value');
                        empOptionList.querySelectorAll('.select-search-option').forEach(o =>
                            o.classList.toggle('selected', o === empOpt));
                    } else if (d.employeeName) {
                        // Nếu không tìm thấy trong dropdown, điền tên trực tiếp
                        employeeNameEl.value = d.employeeName;
                        empTriggerText.textContent = `${empCode} - ${d.employeeName}`;
                        empTriggerText.classList.add('has-value');
                    }
                }

                // Operation (生产线 — native select)
                if (d.operation && opEl) {
                    let found = Array.from(opEl.options).find(o => o.value === d.operation);
                    if (!found) {
                        const newOpt = document.createElement("option");
                        newOpt.value = d.operation;
                        newOpt.textContent = d.operation;
                        newOpt.dataset.dynamic = "1";
                        opEl.appendChild(newOpt);
                    }
                    opEl.value = d.operation;
                    syncSelectColor(opEl);
                    await onOperationChanged();
                }

                // Location (搜索下拉 OperationValue)
                if (d.opValue) {
                    const locOpt = Array.from(opOptionList.querySelectorAll('.select-search-option'))
                        .find(o => o.dataset.value === d.opValue);
                    if (locOpt) {
                        opValueInput.value = d.opValue;
                        opTriggerText.textContent = locOpt.dataset.label || d.opValue;
                        opTriggerText.classList.add('has-value');
                        opOptionList.querySelectorAll('.select-search-option').forEach(o =>
                            o.classList.toggle('selected', o === locOpt));
                    }
                }

                // Reason (ISS Code)
                if (d.reason && IssCodeEl) {
                    const found = Array.from(IssCodeEl.options).find(o => o.value === d.reason);
                    if (found) { IssCodeEl.value = d.reason; syncSelectColor(IssCodeEl); }
                }

                // Effect
                if (d.effect && effectEl) {
                    const found = Array.from(effectEl.options).find(o => o.value === d.effect);
                    if (found) {
                        effectEl.value = d.effect;
                        syncSelectColor(effectEl);
                    }
                }

                showToast('已自动填写上次停机信息 (Auto-filled from last stop)', 'success', 2200);

            } catch (e) {
                console.error('Auto-fill error:', e);
            }
        }

        // ── Kiểm tra trạng thái máy để enable/disable nút Run ──
        await checkRunButtonStatus(value);
    }

    /* ============ Kiểm tra nút Run: chỉ cho phép Run khi máy đang STOP và Tech đã ACCEPT ============ */
    async function checkRunButtonStatus(machineNo) {
        if (!btnRun) return;

        if (!machineNo) {
            // Chưa chọn máy → disable Run (không có gì để Run)
            btnRun.disabled = true;
            btnRun.title    = '请先选择设备编号 / Please select a machine first';
            btnRun.style.opacity = '0.5';
            return;
        }

        try {
            const res  = await fetch(`${pathBase}/Status/GetMachineRunStatus?machineNo=${encodeURIComponent(machineNo)}`);
            if (!res.ok) return;
            const json = await res.json();

            if (json.currentState === 'RUN') {
                // Tech đã sửa xong và tạo RUN → Prod không cần nhấn Run nữa
                btnRun.disabled = true;
                btnRun.title    = '✅ 设备已恢复运行 / Machine already running (repaired by technician)';
                btnRun.style.opacity = '0.5';
            } else if (!json.isStop) {
                // Không có bản ghi STOP nào (máy đang bình thường / chưa Stop) → không cho Run
                btnRun.disabled = true;
                btnRun.title    = '⚠ 设备尚未停机，无需运行 / Machine is not in STOP state';
                btnRun.style.opacity = '0.5';
            } else if (json.isStop && !json.techAccepted) {
                // Máy đang STOP nhưng Tech chưa ACCEPT → lock Run
                btnRun.disabled = true;
                btnRun.title    = '⏳ 请等待技术员接受后才能运行 / Please wait for technician to accept before running';
                btnRun.style.opacity = '0.5';
            } else {
                // Máy đang STOP và Tech đã ACCEPT → Prod được phép Run
                btnRun.disabled = false;
                btnRun.title    = '';
                btnRun.style.opacity = '';
            }
        } catch(e) {
            console.error('checkRunButtonStatus error:', e);
        }
    }

    function resetMachineDropdown() {
        machineValueInput.value = '';
        machineTriggerText.textContent = window.i18nT('createDowntime.selectMachine');
        machineTriggerText.classList.remove('has-value');
        machineOptionList.querySelectorAll('.select-search-option').forEach(o =>
            o.classList.remove('selected')
        );
    }

    function handleMachineTriggerKey(e) {
        if (['Enter', ' ', 'ArrowDown', 'ArrowUp'].includes(e.key)) {
            e.preventDefault();
            if (!machineDropdown.classList.contains('open')) {
                openMachineDropdown();
            } else if (e.key === 'ArrowDown') {
                machineFocusedIndex = Math.min(machineFocusedIndex + 1, getVisibleMachineOptions().length - 1);
                updateFocusedMachineOption();
            } else if (e.key === 'ArrowUp') {
                machineFocusedIndex = Math.max(machineFocusedIndex - 1, 0);
                updateFocusedMachineOption();
            }
        }
        if (e.key === 'Escape') closeMachineDropdown();
    }

    function handleMachineSearchKey(e) {
        const visible = getVisibleMachineOptions();
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            machineFocusedIndex = Math.min(machineFocusedIndex + 1, visible.length - 1);
            updateFocusedMachineOption();
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            machineFocusedIndex = Math.max(machineFocusedIndex - 1, 0);
            updateFocusedMachineOption();
        } else if (e.key === 'Enter') {
            e.preventDefault();
            if (machineFocusedIndex >= 0 && visible[machineFocusedIndex]) {
                selectMachineOption(visible[machineFocusedIndex]);
            } else if (visible.length === 1) {
                selectMachineOption(visible[0]);
            }
        } else if (e.key === 'Escape') {
            closeMachineDropdown();
        }
    }

    machineOptionList.addEventListener('click', function(e) {
        const opt = e.target.closest('.select-search-option');
        if (opt) selectMachineOption(opt);
    });

    document.addEventListener('click', function(e) {
        if (machineTrigger && !machineTrigger.closest('.select-search-wrapper').contains(e.target)) {
            closeMachineDropdown();
        }
    });

    window.addEventListener('DOMContentLoaded', () => {
        updateDatetimeRange();
        if (opEl?.value) onOperationChanged();
    });
</script>