    /* ============ POST save ============ */
    async function performSave(nextState) {

        if (nextState === 'STOP' || nextState === 'RESPONSE') {
            if (!validateRequiredFields()) return;
        }

          if (nextState === 'STOP') {
            const machineNo = (machineEl?.value || '').trim();
            if (machineNo) {
                try {
                    const statusRes  = await fetch(`${pathBase}/Status/GetMachineRunStatus?machineNo=${encodeURIComponent(machineNo)}`);
                    const statusJson = await statusRes.json();

                    if (statusJson.currentState === 'STOP') {
                        showToast('⚠ 此设备已呼叫，正在等待技术员！\n(Machine already called — waiting for technician.)', 'error', 3500);
                        return;
                    }

                    if (statusJson.currentState === 'RESPONSE') {
                        showToast('🔧 此设备正在维修中，请等待技术员完成！\n(Machine is being repaired — please wait for technician to finish.)', 'error', 3500);
                        return;
                    }
                } catch(e) { /* ignore */ }
            }
        }


        if (nextState === 'RUN') {
            const machineNo = (machineEl?.value || '').trim();
            if (!machineNo) {
                showToast('请选择设备编号！ (Please select machine/fixture no.!)', 'error', 2400);
                machineTrigger.focus();
                return;
            }
            // Kiểm tra lại một lần nữa trước khi submit
            try {
                const statusRes  = await fetch(`${pathBase}/Status/GetMachineRunStatus?machineNo=${encodeURIComponent(machineNo)}`);
                const statusJson = await statusRes.json();

                // Máy đã được Tech sửa xong (state = RUN) → không cho Prod nhấn Run thêm
                if (statusJson.currentState === 'RUN') {
                    showToast('✅ 设备已恢复运行，无需再次操作！\n(Machine is already running, no action needed!)', 'error', 3500);
                    await checkRunButtonStatus(machineNo);
                    return;
                }

                // Máy đang STOP nhưng Tech chưa ACCEPT → chưa cho Run
                if (statusJson.isStop && !statusJson.techAccepted) {
                    showToast('⏳ 请等待技术员接受请求后再运行！\n(Please wait for technician to accept before running!)', 'error', 3500);
                    return;
                }
            } catch(e) { /* ignore network errors */ }
        }

        // ── Build FormData ──
        const fd = new FormData();
        fd.append('State',        nextState);
        fd.append('Operation',    (opEl?.value || '').trim());
        fd.append('Reason',       (IssCodeEl?.value || '').trim());
        // ✅ FIX: dùng employeeCodeEl thay vì svnCodeEl
        fd.append('SVNCode',      (employeeCodeEl?.value || '').trim().toUpperCase());
        fd.append('EmployeeCode', (employeeCodeEl?.value || '').trim().toUpperCase());
        fd.append('EmployeeName', (employeeNameEl?.value || '').trim());
        fd.append('MachineCode',  (machineEl?.value || '').trim());
        fd.append('Location',     (opValueInput?.value || '').trim());
        fd.append('Effect',       (effectEl?.value || '').trim());
        fd.append('Description',  (descEl?.value || '').trim());
        fd.append('Station',      (document.getElementById('Station')?.value || '').trim());
        fd.append('Action',       (document.getElementById('Action')?.value || '').trim());
        fd.append('RootCause',    (document.getElementById('RootCause')?.value || '').trim());
        fd.append('SpareParts',   (document.getElementById('SpareParts')?.value || '').trim());

        // Datetime is generated server-side as DateTime.UtcNow — do not send from client
        if (estimateEl?.value) fd.append('EstimateTime', estimateEl.value);

        const imgInput = document.getElementById('imageInputDT');
        if (imgInput?.files?.length > 0) fd.append('imageFile', imgInput.files[0]);

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenInput) fd.append('__RequestVerificationToken', tokenInput.value);

        // ── Disable buttons & show loading ──
        const clickedBtn = nextState === 'RUN'      ? btnRun
                         : nextState === 'RESPONSE' ? btnStop
                         : btnCall;

        [btnRun, btnStop, btnCall].forEach(b => { if (b) b.disabled = true; });
        const oldHTML = clickedBtn.innerHTML;
        clickedBtn.innerHTML = '⏳ 保存中...';

        try {
            const res = await fetch(`${pathBase}/Status/CreateDownTime`, { method: 'POST', body: fd });
            if (!res.ok) {
                console.error('Server error:', await res.text());
                showToast('保存时服务器错误。 (Server error when saving.)', 'error', 2600);
                return;
            }
            let data = null;
            try { data = await res.json(); } catch {}

            if (data?.success) {
                showToast(data.message || '停机时间已保存！ (Downtime saved!)');
                resetInputs();
                await onOperationChanged();
            } else {
                showToast(data?.message || '保存失败！ (Save failed!)', 'error', 2400);
            }
        } catch (err) {
            console.error(err);
            showToast('保存过程中出错！ (Error occurred while saving!)', 'error', 2400);
        } finally {
            [btnRun, btnStop, btnCall].forEach(b => { if (b) b.disabled = false; });
            clickedBtn.innerHTML = oldHTML;
        }
    }

    /* ============ Bindings ============ */
    opEl?.addEventListener('change', onOperationChanged);

    btnCall?.addEventListener('click',  () => performSave('STOP'));
    btnStop?.addEventListener('click',  () => performSave('RESPONSE'));
    btnRun?.addEventListener('click',   () => performSave('RUN'));

    /* ============ SignalR — nhận phản hồi từ Kỹ thuật ============ */
    (async function initSignalR() {
        try {
            const signalRScript = document.createElement('script');
            signalRScript.src = 'https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js';
            signalRScript.onload = async function() {
                const conn = new signalR.HubConnectionBuilder()
                    .withUrl(`${pathBase}/downtimeHub`)
                    .withAutomaticReconnect([2000, 5000, 10000])
                    .configureLogging(signalR.LogLevel.Warning)
                    .build();

                // Nhận thông báo phản hồi từ Kỹ thuật
                conn.on("ReceiveTechResponse", (data) => {
                    showTechResponseNotif(data);
                    // Nếu Tech ACCEPT → enable lại nút Run
                    if (data.action === 'ACCEPT') {
                        const curMachine = (machineEl?.value || '').trim();
                        if (!curMachine || curMachine === data.machineCode) {
                            checkRunButtonStatus(data.machineCode || curMachine);
                        }
                    }
                });

                // Nhận thông báo Kỹ thuật đã sửa xong
                conn.on("ReceiveFixComplete", (data) => {
                    showFixCompleteNotif(data);
                    // Khi Tech sửa xong → Run đã được tạo từ Tech side, reset button
                    const curMachine = (machineEl?.value || '').trim();
                    if (!curMachine || curMachine === data.machineCode) {
                        checkRunButtonStatus(data.machineCode || curMachine);
                    }
                });

                try {
                    await conn.start();
                    // Join group riêng theo username của Operator
                    const myUsername = '@(Context.Session.GetString("UserName") ?? "")';
                    if (myUsername) {
                        await conn.invoke("JoinOperatorGroup", myUsername);
                    }
                    // Load thông báo chưa đọc từ DB khi trang mở
                    await loadPendingNotificationsForProd();
                } catch (err) {
                    console.warn("SignalR CreateDownTime connect failed:", err);
                    // Vẫn load notifications ngay cả khi SignalR lỗi
                    await loadPendingNotificationsForProd();
                }
            };
            document.head.appendChild(signalRScript);
        } catch(e) {
            console.warn("SignalR init error:", e);
        }
    })();

    /* ===== Load thông báo chưa đọc từ DB khi Prod vào/refresh trang ===== */
    async function loadPendingNotificationsForProd() {
        try {
            const res = await fetch(`${pathBase}/Status/GetMyNotifications`);
            if (!res.ok) return;
            const json = await res.json();
            if (!json.success || !json.notifications) return;

            // Chỉ hiển thị thông báo chưa đọc, loại FIX_COMPLETE và TECH_RESPONSE
            const unread = json.notifications.filter(n =>
                !n.isRead && (n.notifType === 'FIX_COMPLETE' || n.notifType === 'TECH_RESPONSE')
            );

            // Hiện từng thông báo với delay nhỏ để không chồng chất
            unread.forEach((n, i) => {
                setTimeout(() => {
                    if (n.notifType === 'FIX_COMPLETE') {
                        showFixCompleteNotif({
                            machineCode : n.machineCode,
                            operation   : n.operation,
                            techName    : n.techName,
                            message     : n.body || `✅ Máy ${n.machineCode} (${n.operation}) đã được sửa xong.`,
                            datetime    : n.createdAt
                        });
                    } else if (n.notifType === 'TECH_RESPONSE') {
                        showTechResponseNotif({
                            action      : n.techAction,
                            techName    : n.techName,
                            machineCode : n.machineCode,
                            message     : n.body || n.title,
                            datetime    : n.createdAt
                        });
                    }
                    // Đánh dấu đã đọc
                    fetch(`${pathBase}/Status/MarkNotificationRead`, {
                        method  : 'POST',
                        headers : { 'Content-Type': 'application/json' },
                        body    : JSON.stringify({ id: n.id })
                    }).catch(() => {});
                }, i * 600); // delay 600ms giữa các toast
            });
        } catch(e) {
            console.warn('loadPendingNotificationsForProd error:', e);
        }
    }

    /* ===== Hiển thị thông báo phản hồi từ Kỹ thuật ===== */
    function showTechResponseNotif(data) {
        // Tạo toast đặc biệt cho tech response — khác màu
        const isAccept = data.action === 'ACCEPT';
        const container = document.querySelector('.toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.style.cssText = `
            min-width: 300px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-left: 6px solid ${isAccept ? '#22c55e' : '#f59e0b'};
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: 0 10px 28px rgba(0,0,0,.12);
            font-family: "Segoe UI", system-ui, sans-serif;
            animation: techToastIn .3s ease;
        `;

        toast.innerHTML = `
            <div style="font-weight:700;font-size:14px;margin-bottom:6px;color:${isAccept ? '#166534' : '#92400e'}">
                ${isAccept ? '✅ Technical has accepted!' : '⏳ Technical has viewed'}
            </div>
            <div style="font-size:13px;color:#374151;line-height:1.5;">${data.message || ''}</div>
            <div style="font-size:11px;color:#9ca3af;margin-top:6px;">🕐 ${data.datetime || ''}</div>
            <button onclick="this.closest('div[style]').remove()"
                style="position:absolute;top:8px;right:10px;border:0;background:transparent;font-size:17px;cursor:pointer;color:#9ca3af;line-height:1;">×</button>
        `;
        toast.style.position = 'relative';

        container.appendChild(toast);

        // Phát âm thanh nếu Accept
        if (isAccept) playTechAcceptSound();

        // Tự ẩn sau 8 giây
        setTimeout(() => {
            toast.style.opacity   = '0';
            toast.style.transform = 'translateY(-8px)';
            toast.style.transition = 'all .25s ease';
            setTimeout(() => toast.remove(), 300);
        }, 8000);
    }

    /* ===== Hiển thị thông báo Kỹ thuật đã sửa xong ===== */
    function showFixCompleteNotif(data) {
        const container = document.querySelector('.toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.style.cssText = `
            min-width: 300px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-left: 6px solid #0d6efd;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: 0 10px 28px rgba(0,0,0,.12);
            font-family: "Segoe UI", system-ui, sans-serif;
            animation: techToastIn .3s ease;
            position: relative;
        `;
        toast.innerHTML = `
            <div style="font-weight:700;font-size:14px;margin-bottom:6px;color:#1e40af">
                🔧 Machine Fixed!
            </div>
            <div style="font-size:13px;color:#374151;line-height:1.5;">${data.message || ''}</div>
            <div style="font-size:11px;color:#9ca3af;margin-top:6px;">🕐 ${data.datetime || ''} · Technical: ${data.techName || ''}</div>
            <button onclick="this.closest('div[style]').remove()"
                style="position:absolute;top:8px;right:10px;border:0;background:transparent;font-size:17px;cursor:pointer;color:#9ca3af;line-height:1;">×</button>
        `;
        container.appendChild(toast);

        // Phát âm thanh xác nhận
        try {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            [0, 0.15, 0.30].forEach((offset, i) => {
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain); gain.connect(ctx.destination);
                osc.type = 'sine';
                osc.frequency.value = [523, 659, 784][i];
                gain.gain.setValueAtTime(0.25, ctx.currentTime + offset);
                gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + offset + 0.35);
                osc.start(ctx.currentTime + offset);
                osc.stop(ctx.currentTime + offset + 0.35);
            });
        } catch(e) {}

        setTimeout(() => {
            toast.style.opacity   = '0';
            toast.style.transform = 'translateY(-8px)';
            toast.style.transition = 'all .25s ease';
            setTimeout(() => toast.remove(), 300);
        }, 10000);
    }

    /* ===== Âm thanh khi Tech Accept ===== */
    function playTechAcceptSound() {
        try {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            [0, 0.18, 0.36].forEach((offset, i) => {
                const osc  = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.type            = 'sine';
                osc.frequency.value = [523, 659, 784][i]; // C5 E5 G5 — tiếng vui
                const t = ctx.currentTime + offset;
                gain.gain.setValueAtTime(0.5, t);
                gain.gain.exponentialRampToValueAtTime(0.001, t + 0.3);
                osc.start(t);
                osc.stop(t + 0.35);
            });
        } catch(e) {}
    }

