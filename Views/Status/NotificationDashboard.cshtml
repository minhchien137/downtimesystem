async function reloadByDate() {
    // Clear list và reset counters
    notifList.innerHTML = '';
    cntStop = cntRun = cntTotal = cntAccept = 0;
    updateCounters();
    emptyState = null;
    // Hiện empty state tạm
    const tmp = document.createElement('div');
