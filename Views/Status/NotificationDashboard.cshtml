/* ===== Load thông báo từ DB khi Tech vào/refresh trang ===== */
async function loadPendingFromDB() {
    try {
        const dateVal = document.getElementById('notifDateFilter')?.value || '';
        const url = dateVal
            ? `${pathBase}/Status/GetPendingNotifications?date=${encodeURIComponent(dateVal)}`
            : `${pathBase}/Status/GetPendingNotifications`;

        const res  = await fetch(url);
        if (!res.ok) return;
        const rawList = await res.json();

        if (!rawList || rawList.length === 0) return;

        // Lọc bỏ các card đã bị xóa (lưu trong localStorage)
        const dismissed = getDismissedIds();
        const list = rawList.filter(item => !dismissed.includes(item.id));

        if (list.length === 0) return;

        // Xóa empty state nếu có
        const empty = document.getElementById('emptyState');
        if (empty) empty.remove();

        // Render từng bản ghi — append (cũ nhất xuống dưới, mới nhất lên đầu đã sort từ server)
        list.forEach(item => {
            renderStopCard(item, false); // false = append xuống dưới
            cntTotal++;
            if (!item.techAction) {
                cntStop++;
            } else if (item.techAction === 'ACCEPT') {
                cntAccept++;
            } else if (item.techAction === 'REJECT') {
                cntReject++;
            }
        });

        // Sau khi load xong, đảo ngược thứ tự để mới nhất lên đầu
        const cards = Array.from(notifList.querySelectorAll('.notif-card'));
        cards.reverse().forEach(c => notifList.insertBefore(c, notifList.firstChild));

        updateCounters();
    } catch (err) {
        console.error('loadPendingFromDB error:', err);
    }
}

/* ===== scrollToTechCard — được gọi từ _Layout khi click bell item ===== */
window.scrollToTechCard = function(techRespId) {
    if (!techRespId) return;

    // Chuyển sang tab 通知列表 nếu đang ở tab khác
    const tabNotif = document.getElementById('tabNotif');
    const tabEdit  = document.getElementById('tabEdit');
    if (tabNotif && !tabNotif.classList.contains('active')) {
        tabNotif.classList.add('active');
        if (tabEdit) tabEdit.classList.remove('active');
        document.querySelectorAll('.tech-tab-btn').forEach(b => b.classList.remove('active'));
        const firstBtn = document.querySelector('.tech-tab-btn');
        if (firstBtn) firstBtn.classList.add('active');
    }

    // Tìm card theo data-tech-response-id
    const card = document.querySelector(`.notif-card[data-tech-response-id="${techRespId}"]`);
    if (!card) return;

    // Scroll đến card
    card.scrollIntoView({ behavior: 'smooth', block: 'center' });

    // Highlight card bằng blue glow 2.5 giây
    card.style.transition = 'box-shadow .25s';
    card.style.boxShadow  = '0 0 0 3px #3b82f6, 0 6px 24px rgba(59,130,246,.4)';
    setTimeout(() => { card.style.boxShadow = ''; }, 2500);
};

