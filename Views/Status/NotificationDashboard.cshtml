<script>
"use strict";

const pathBase   = '@Context.Request.PathBase'.replace(/\/$/, '');
const notifList  = document.getElementById('notifList');
let   emptyState = document.getElementById('emptyState'); // FIX: let để có thể gán null
const connBadge  = document.getElementById('connBadge');
const connText   = document.getElementById('connText');

let soundEnabled  = true;
let cntStop  = 0;
let cntRun   = 0;
let cntTotal = 0;
let cntAccept = 0;
let cntReject = 0;
let _rejectCtx = null;
let _pieRespCtx = null;

function closePieResponseModal() {
    document.getElementById('pieResponseModalOverlay').classList.remove('open');
    _pieRespCtx = null;
}

async function submitPieResponse() {
    if (!_pieRespCtx) return;

    const reason = document.getElementById('pieRespReason').value.trim();
    const effect = document.getElementById('pieRespEffect').value.trim();
    if (!reason) {
        document.getElementById('pieRespReason').style.borderColor = '#ef4444';
        teShowToast('⚠ 请选择功能 / Please select Function!', true);
        return;
    }
    if (!effect) {
        document.getElementById('pieRespEffect').style.borderColor = '#ef4444';
        teShowToast('⚠ 请选择影响程度 / Please select Effect!', true);
        return;
    }

    const { btn, card, techResponseId, operatorUsername, machineCode, actionsDiv, techEmployeeName } = _pieRespCtx;
    const estimateTime  = document.getElementById('pieRespEstimate').value.trim();
    const description   = document.getElementById('pieRespDescription').value.trim();

    closePieResponseModal();

    const stopDt = parseDT(card.dataset.stopDatetime);
    const mins   = minutesBetween(stopDt, new Date());
    const responseTimeStr = mins !== null ? formatMinutes(mins) : null;

    card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = true);
    btn.innerHTML = '⏳ 发送中...';

    try {
        const res = await fetch(`${pathBase}/Status/TechnicianRespond`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                techResponseId : parseInt(techResponseId) || 0,
                action         : 'ACCEPT',
                operatorUsername,
                machineCode,
                techEmployeeName,
                reason,
                effect,
                estimateTime,
                description
            })
        });
        const data = await res.json();

        if (data.success) {
            if (actionsDiv) {
                actionsDiv.innerHTML = buildRespondedBadge('ACCEPT', null, null, false, responseTimeStr);
            }
            cntAccept++;
            updateCounters();
        } else {
            card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = false);
            btn.innerHTML = '✅ Response';
            teShowToast('❌ Lỗi server', true);
        }
    } catch (err) {
        console.error('submitPieResponse error:', err);
        card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = false);
        btn.innerHTML = '✅ Response';
    }
}
let audioCtx = null;
let audioUnlocked = false;

// Tab title flash
let titleFlashInterval = null;
const originalTitle = document.title;

const pieEmployees = @Html.Raw(ViewBag.PieEmployeesJson ?? "[]");

/* ===== Unlock AudioContext ngay khi user click/touch lần đầu ===== */
function ensureAudioCtx() {
    if (audioUnlocked && audioCtx) return audioCtx;
    try {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        if (audioCtx.state === 'suspended') audioCtx.resume();
        audioUnlocked = true;
        document.getElementById('audioBanner').style.display = 'none';
    } catch (e) {
        console.warn('AudioContext failed:', e);
    }
    return audioCtx;
}

// Unlock ngay khi load nếu có thể, sau đó unlock lại mỗi lần user tương tác
['click','touchstart','keydown','scroll'].forEach(evt => {
    document.addEventListener(evt, () => ensureAudioCtx(), { once: false, passive: true });
});

function unlockAudio() {
    ensureAudioCtx();
    document.getElementById('audioBanner').style.display = 'none';
}

function toggleSound() {
    soundEnabled = !soundEnabled;
    document.getElementById('btnSound').textContent =
        soundEnabled ? '🔔 声音: 开' : '🔕 声音: 关';
}

/* ===== Âm thanh STOP: còi báo động to, 5 tiếng bip nhanh ===== */
function playStopSound() {
    if (!soundEnabled) return;
    const ctx = ensureAudioCtx();
    if (!ctx) return;

    if (ctx.state === 'suspended') ctx.resume();

    // CompressorNode để âm to hơn
    const compressor = ctx.createDynamicsCompressor();
    compressor.threshold.value = -10;
    compressor.knee.value      = 0;
    compressor.ratio.value     = 20;
    compressor.attack.value    = 0;
    compressor.release.value   = 0.1;
    compressor.connect(ctx.destination);

    // 5 tiếng bíp liên tục, to, tần số cao
    const times = [0, 0.22, 0.44, 0.66, 0.88];
    times.forEach(offset => {
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(compressor);

        osc.type            = 'square';   // square wave → to và rõ hơn sine
        osc.frequency.value = 1050;       // tần số cao nghe rõ hơn

        const t = ctx.currentTime + offset;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(1.0, t + 0.01);  // lên nhanh
        gain.gain.setValueAtTime(1.0, t + 0.14);
        gain.gain.linearRampToValueAtTime(0, t + 0.18);    // tắt

        osc.start(t);
        osc.stop(t + 0.2);
    });
}

/* ===== Âm thanh RUN: 2 tiếng bíp nhẹ xuống tần số ===== */
function playRunSound() {
    if (!soundEnabled) return;
    const ctx = ensureAudioCtx();
    if (!ctx) return;
    if (ctx.state === 'suspended') ctx.resume();

    [0, 0.3].forEach((offset, i) => {
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.type            = 'sine';
        osc.frequency.value = i === 0 ? 660 : 440;
        const t = ctx.currentTime + offset;
        gain.gain.setValueAtTime(0.6, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.25);
        osc.start(t);
        osc.stop(t + 0.3);
    });
}

/* ===== Flash toàn màn hình ===== */
function flashScreen() {
    const overlay = document.getElementById('flashOverlay');
    let count = 0;
    const max = 6; // số lần nháy

    function doFlash() {
        if (count >= max) { overlay.style.display = 'none'; return; }
        overlay.style.display = 'block';
        overlay.style.animation = 'none';
        overlay.offsetHeight; // reflow
        overlay.style.animation = 'flashAnim 0.22s ease';
        count++;
        setTimeout(() => {
            overlay.style.display = 'none';
            setTimeout(doFlash, 80);
        }, 220);
    }
    doFlash();

    // Nháy border body
    document.body.classList.add('flashing');
    setTimeout(() => document.body.classList.remove('flashing'), 2000);
}

/* ===== Nháy title tab ===== */
function startTitleFlash(machineName) {
    if (titleFlashInterval) clearInterval(titleFlashInterval);
    let show = true;
    titleFlashInterval = setInterval(() => {
        document.title = show ? `🛑 停机: ${machineName}` : originalTitle;
        show = !show;
    }, 700);
    // Dừng sau 15 giây
    setTimeout(stopTitleFlash, 15000);
}

function stopTitleFlash() {
    if (titleFlashInterval) { clearInterval(titleFlashInterval); titleFlashInterval = null; }
    document.title = originalTitle;
}

/* ===== Update counters ===== */
function updateCounters() {
    document.getElementById('cntStop').textContent   = cntStop;
    document.getElementById('cntRun').textContent    = cntRun;
    document.getElementById('cntTotal').textContent  = cntTotal;
    document.getElementById('cntAccept').textContent = cntAccept;
}

/* ===== Helper: parse "dd/MM/yyyy HH:mm" → Date ===== */
function parseDT(s) {
    if (!s) return null;
    try {
        const [datePart, timePart] = s.trim().split(' ');
        const [d, m, y] = datePart.split('/');
        const [h, min]  = (timePart || '00:00').split(':');
        return new Date(+y, +m - 1, +d, +h, +min);
    } catch { return null; }
}

function minutesBetween(start, end) {
    if (!start || !end) return null;
    return Math.round((end - start) / 60000);
}

function formatMinutes(mins) {
    if (mins === null || mins === undefined || isNaN(mins)) return '-';
    if (mins < 1) return '< 1 分钟';
    if (mins < 60) return `${mins} 分钟`;
    const h = Math.floor(mins / 60);
    const m = mins % 60;
    return m > 0 ? `${h}h ${m}m` : `${h}h`;
}

/* ===== Render STOP card ===== */
function renderStopCard(data, prepend = true) {
    if (emptyState) { emptyState.remove(); emptyState = null; }

    const effLabel = data.effect === '1' ? '影响生产'
                   : data.effect === '2' ? '不影响生产'
                   : (data.effect || '-');

    const card = document.createElement('div');
    card.className = 'notif-card new-card';
    card.dataset.techResponseId   = data.techResponseId   || data.id || '';
    card.dataset.operatorUsername = data.operatorUsername || '';
    card.dataset.machineCode      = data.machineCode      || '';
    card.dataset.stopDatetime     = data.datetime         || '';  // "dd/MM/yyyy HH:mm"

    // Tính response time nếu đã có respondDatetime (load từ DB)
    let responseTimeStr = null;
    if (data.respondDatetime && data.datetime) {
        const stopDt    = parseDT(data.datetime);
        const respondDt = parseDT(data.respondDatetime);
        const mins = minutesBetween(stopDt, respondDt);
        if (mins !== null) responseTimeStr = formatMinutes(mins);
    }

    // Nếu đã có techAction (load từ DB), render ngay trạng thái đã respond
    const alreadyResponded = data.techAction && data.techAction !== '';
    const pieOptions = pieEmployees.map(e =>
        `<option value="${e.englishName}">${e.englishName} - ${e.chineseName}</option>`
    ).join('');

    const actionsHtml = alreadyResponded
        ? buildRespondedBadge(data.techAction, data.techUsername, data.respondDatetime, !!data.fixComplete, responseTimeStr, !!data.prodRun)
        : `<div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
            <select class="pie-emp-select" style="border:1.5px solid #e5e7eb;border-radius:8px;padding:8px 12px;font-size:13px;outline:none;min-width:200px;cursor:pointer;">
            <option value="">-- 选择PIE员工 (Select PIE) --</option>
            ${pieOptions}
            </select>
            <button class="btn-accept" onclick="respondToOperator(this,'ACCEPT')">✅ Response</button>
            <button class="btn-reject" onclick="openRejectModal(this)">❌ 拒绝 / Reject</button>
        </div>`;

    card.innerHTML = `
        <button class="notif-dismiss" onclick="deleteCard(this)" title="删除通知 / Delete">🗑</button>
        <div class="notif-top">
            <span class="notif-badge badge-stop">🛑 停机 / 呼叫</span>
            <span class="notif-time">${data.datetime || new Date().toLocaleString('zh-CN')}</span>
        </div>
        <div class="notif-machine">${data.machineCode || '(无设备代码)'}</div>
        <div class="notif-op">📍 ${data.operation || '-'} ${data.location ? '· ' + data.location : ''}</div>
        <div class="notif-grid">
            <div class="notif-field">
                <div class="notif-field-label">👤 操作员</div>
                <div class="notif-field-value">${data.employeeName || data.employeeCode || '-'} ${data.employeeCode ? '(' + data.employeeCode + ')' : ''}</div>
            </div>
            ${data.station ? `<div class="notif-field"><div class="notif-field-label">🔩 工位</div><div class="notif-field-value">${data.station}</div></div>` : ''}
            ${data.description ? `<div class="notif-field" style="grid-column:1/-1;"><div class="notif-field-label">📝 详细描述</div><div class="notif-field-value">${data.description}</div></div>` : ''}
            ${data.image ? `<div class="notif-field" style="grid-column:1/-1;">
                <div class="notif-field-label">🖼 图片</div>
                <div style="margin-top:4px;">
                    <a href="${data.image}" target="_blank">
                        <img src="${data.image}" alt="Error image"
                             style="max-height:100px;max-width:220px;border-radius:7px;border:1.5px solid var(--border);object-fit:cover;cursor:pointer;transition:transform .15s;"
                             onmouseover="this.style.transform='scale(1.04)'"
                             onmouseout="this.style.transform='scale(1)'" />
                    </a>
                </div>
            </div>` : ''}
        </div>
        <div class="notif-actions">${actionsHtml}</div>
    `;

    if (prepend) {
        notifList.insertBefore(card, notifList.firstChild);
    } else {
        notifList.appendChild(card);
    }

    // Chỉ highlight nếu là thông báo mới real-time (không phải load từ DB)
    if (prepend) setTimeout(() => card.classList.remove('new-card'), 5000);
    else card.classList.remove('new-card');
}

function buildRespondedBadge(action, techUser, respondTime, fixComplete = false, responseTimeStr = null, prodRun = false) {
    // ── REJECT ──
    if (action === 'REJECT') {
        return `<span class="responded-badge rejected">❌ 已拒绝${techUser ? '，由 ' + techUser : ''}${respondTime ? ' · ' + respondTime : ''}</span>`;
    }

    // ── ACCEPT ──
    const badge = `<span class="responded-badge accepted">✅ 已接受${techUser ? ' 由 ' + techUser : ''}${respondTime ? ' · ' + respondTime : ''}</span>`;
    const respTimeBadge = responseTimeStr
        ? `<span class="response-time-badge">⚡ 响应时间: ${responseTimeStr}</span>`
        : '';
    let responseBtn;
    if (fixComplete) {
        responseBtn = `<span class="responded-badge fix-done">🔧 已发送修复完成通知</span>`;
    } else if (prodRun) {
        responseBtn = `<span class="responded-badge" style="background:#dbeafe;color:#1e40af;">▶ 生产已Run — 无需操作</span>`;
    } else {
        responseBtn = `<button class="btn-fix-complete" onclick="techFixComplete(this)">🔧 响应 — 已修复完成</button>`;
    }

    return `<div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">${badge}${respTimeBadge}${responseBtn}</div>`;
}

/* ===== Tech respond: gửi Accept hoặc Wait ngược về Operator ===== */
async function respondToOperator(btn, action) {
    const card = btn.closest('.notif-card');
    if (!card) return;

    // ── Validate PIE employee ──
    const empSelect = card.querySelector('.pie-emp-select');
    if (empSelect && !empSelect.value) {
        empSelect.style.borderColor = '#ef4444';
        empSelect.style.boxShadow = '0 0 0 3px rgba(239,68,68,0.2)';
        empSelect.focus();
        teShowToast('⚠ 请先选择PIE员工！', true);
        return;
    }
    if (empSelect) {
        empSelect.style.borderColor = '#e5e7eb';
        empSelect.style.boxShadow = '';
    }

    const techResponseId   = card.dataset.techResponseId   || '';
    const operatorUsername = card.dataset.operatorUsername || '';
    const machineCode      = card.dataset.machineCode      || '';
    const actionsDiv       = card.querySelector('.notif-actions');

    // ACCEPT → submit thẳng, không hỏi gì
    if (action === 'ACCEPT') {
        const stopDt = parseDT(card.dataset.stopDatetime);
        const nowDt  = new Date();
        const mins   = minutesBetween(stopDt, nowDt);
        const responseTimeStr = mins !== null ? formatMinutes(mins) : null;

        card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = true);
        btn.innerHTML = '⏳ 发送中...';

        try {
            const res = await fetch(`${pathBase}/Status/TechnicianRespond`, {
                method : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body   : JSON.stringify({
                    techResponseId   : parseInt(techResponseId) || 0,
                    action           : 'ACCEPT',
                    operatorUsername,
                    machineCode,
                    techEmployeeName : empSelect ? empSelect.value : ''
                })
            });
            const data = await res.json();
            if (data.success) {
                if (actionsDiv) actionsDiv.innerHTML = buildRespondedBadge('ACCEPT', null, null, false, responseTimeStr);
                cntAccept++;
                updateCounters();
            } else {
                card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = false);
                btn.innerHTML = '✅ Response';
            }
        } catch (err) {
            console.error('respondToOperator ACCEPT error:', err);
            card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = false);
            btn.innerHTML = '✅ Response';
        }
        return;
    }

    const stopDt = parseDT(card.dataset.stopDatetime);
    const nowDt  = new Date();
    const mins   = minutesBetween(stopDt, nowDt);
    const responseTimeStr = mins !== null ? formatMinutes(mins) : null;

    card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = true);
    btn.innerHTML = '⏳ 发送中...';

    try {
        const res = await fetch(`${pathBase}/Status/TechnicianRespond`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
            techResponseId   : parseInt(techResponseId) || 0,
            action,
            operatorUsername,
            machineCode,
            techEmployeeName : empSelect ? empSelect.value : ''
        })

        });
        const data = await res.json();

        if (data.success) {
            if (actionsDiv) {
                actionsDiv.innerHTML = buildRespondedBadge(action, null, null, false, responseTimeStr);
            }
            if (action === 'ACCEPT') { cntAccept++; }
            updateCounters();
        } else {
            card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = false);
            btn.innerHTML = '✅ Response';
        }
    } catch (err) {
        console.error('respondToOperator error:', err);
        card.querySelectorAll('.btn-accept, .btn-reject, .btn-wait').forEach(b => b.disabled = false);
        btn.innerHTML = '✅ Response';
    }
}

