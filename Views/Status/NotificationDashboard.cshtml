/* ===== deleteCard — xóa card khỏi DOM + lưu vào localStorage ===== */
const DISMISSED_KEY = 'dismissedTechCards_v1';

function getDismissedIds() {
    try { return JSON.parse(localStorage.getItem(DISMISSED_KEY) || '[]'); } catch { return []; }
}

function saveDismissedId(id) {
    const ids = getDismissedIds();
    const numId = parseInt(id);
    if (numId && !ids.includes(numId)) {
        ids.push(numId);
        localStorage.setItem(DISMISSED_KEY, JSON.stringify(ids));
    }
}

async function deleteCard(btn) {
    const card = btn.closest('.notif-card');
    if (!card) return;

    const techRespId = parseInt(card.dataset.techResponseId || '0');
    const isPending  = !card.querySelector('.responded-badge, .fix-done') && !card.classList.contains('run-card');

    if (isPending) {
        const ok = confirm('⚠️ 此通知尚未处理！确定要删除吗？\nThis notification is not handled yet. Delete anyway?');
        if (!ok) return;
    }

    // Xóa card khỏi DOM ngay (optimistic UI)
    card.style.transition = 'opacity .2s, transform .2s';
    card.style.opacity    = '0';
    card.style.transform  = 'translateX(30px)';
    setTimeout(() => {
        card.remove();
        if (notifList.querySelectorAll('.notif-card').length === 0) showEmptyState();
    }, 200);

    // Cập nhật counters
    if (isPending) cntStop  = Math.max(0, cntStop - 1);
    else if (card.classList.contains('run-card')) cntRun = Math.max(0, cntRun - 1);
    cntTotal = Math.max(0, cntTotal - 1);
    updateCounters();

    // Lưu localStorage để filter khi reload (giữ lại để tương thích)
    if (techRespId) saveDismissedId(techRespId);

    // Gọi API xóa notification khỏi SVN_Notifications (server-side)
   // Gọi API xóa notification khỏi SVN_Notifications (server-side)
if (techRespId) {
    try {
        await fetch(`${pathBase}/Status/DeleteTechNotification`, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ techResponseId: techRespId })
        });
    } catch(e) { /* silent fail */ }
}

    // ── Xóa luôn bell items liên quan đến techRespId này ──
    if (techRespId) {
        document.querySelectorAll(`#bellList .bell-notif-item[data-tech-response-id="${techRespId}"]`)
            .forEach(el => el.remove());
        // Nếu bell list trống → hiện empty state
        if (!document.querySelector('#bellList .bell-notif-item')) {
            const bellList = document.getElementById('bellList');
            if (bellList) bellList.innerHTML = '<div class="bell-drop-empty" id="bellEmpty">暂无通知。</div>';
            const bellBadge = document.getElementById('bellBadge');
            if (bellBadge) bellBadge.style.display = 'none';
        }
    }

    // Reload bell để badge count khớp
    if (typeof window.loadNotifications === 'function') window.loadNotifications();
}

