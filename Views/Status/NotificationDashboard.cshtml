function requestBrowserNotification() {
    if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission();
    }
}

function showBrowserNotif(title, body) {
    if ('Notification' in window && Notification.permission === 'granted') {
        new Notification(title, { body, icon: '/favicon.ico' });
    }
}

/* ===== SignalR Connection ===== */
const connection = new signalR.HubConnectionBuilder()
    .withUrl(`${pathBase}/downtimeHub`)
    .withAutomaticReconnect([1000, 2000, 5000, 10000])
    .configureLogging(signalR.LogLevel.Warning)
    .build();

// Nhận thông báo STOP từ server (real-time)
connection.on("ReceiveStopNotification", (data) => {
    cntStop++;
    cntTotal++;
    updateCounters();
    renderStopCard(data, true);  // prepend = true, thêm vào đầu
    playStopSound();
    flashScreen();
    startTitleFlash(data.machineCode || '停机');
    showBrowserNotif(
        `🛑 停机: ${data.machineCode}`,
        `工序: ${data.operation}\n操作员: ${data.employeeName || data.employeeCode}\n原因: ${data.reason}`
    );
});

// Nhận thông báo RUN từ server
connection.on("ReceiveRunNotification", (data) => {
    cntRun++;
    cntTotal++;
    updateCounters();
    renderRunCard(data);
    playRunSound();
    showBrowserNotif(`▶ 恢复运行: ${data.machineCode}`, `设备已重新运行\n${data.operation}`);

    // Nếu Prod đã nhấn Run → disable nút "已修复完成" trên card tương ứng
    if (data.machineCode) {
        document.querySelectorAll('.notif-card').forEach(card => {
            if ((card.dataset.machineCode || '').trim() === data.machineCode.trim()) {
                const fixBtn = card.querySelector('.btn-fix-complete');
                if (fixBtn) {
                    const badge = document.createElement('span');
                    badge.className = 'responded-badge';
                    badge.style.cssText = 'background:#dbeafe;color:#1e40af;';
                    badge.textContent = '▶ 生产已Run — 无需操作';
                    fixBtn.replaceWith(badge);
                }
            }
        });
    }
});

