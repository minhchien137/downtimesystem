@{
    ViewData["Title"] = "🔔 技术员看板 – 实时通知";
}

<style>
    :root {
        --stop-color:  #ef4444;
        --run-color:   #22c55e;
        --resp-color:  #f59e0b;
        --border:      #e5e7eb;
        --text:        #111827;
        --muted:       #6b7280;
        --bg:          #f9fafb;
        --card-bg:     #ffffff;
    }

    * { box-sizing: border-box; }

    body {
        font-family: "Segoe UI", system-ui, -apple-system, Roboto, Arial, sans-serif;
        background: var(--bg);
        margin: 0;
    }

    /* ===== Header ===== */
    .dash-header {
        background: #111;
        border-top: 4px solid #ef4444;
        padding: 16px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .dash-header h1 {
        margin: 0;
        color: #fff;
        font-size: 20px;
        font-weight: 700;
    }

    .dash-header .sub {
        color: #999;
        font-size: 13px;
        margin-top: 3px;
    }

    /* Connection status badge */
    .conn-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 99px;
        font-size: 13px;
        font-weight: 600;
        transition: all .3s;
    }

    .conn-badge.connecting { background: #fef3c7; color: #92400e; }
    .conn-badge.connected  { background: #dcfce7; color: #166534; }
    .conn-badge.disconnected { background: #fee2e2; color: #991b1b; }

    .conn-dot {
        width: 9px; height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .connecting  .conn-dot { background: #f59e0b; animation: pulse 1.2s infinite; }
    .connected   .conn-dot { background: #22c55e; }
    .disconnected .conn-dot { background: #ef4444; }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.3; }
    }

    /* ===== Body layout ===== */
    .dash-body {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px 16px;
    }

    /* ===== Summary counters ===== */
    .summary-row {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 14px;
        margin-bottom: 22px;
    }

    .summary-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .summary-icon {
        font-size: 28px;
        line-height: 1;
    }

    .summary-label {
        font-size: 12px;
        color: var(--muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .summary-value {
        font-size: 28px;
        font-weight: 800;
        line-height: 1.1;
    }

    .summary-value.stop  { color: var(--stop-color); }
    .summary-value.run   { color: var(--run-color); }
    .summary-value.total { color: #6366f1; }
    .summary-value.accept { color: #16a34a; }

    /* ===== Accept / Wait buttons ===== */
    .notif-actions {
        display: flex;
        gap: 10px;
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
        align-items: center;
    }

    .btn-accept {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 10px rgba(34,197,94,.35);
        transition: all .18s;
    }
    .btn-accept:hover  { filter: brightness(1.08); transform: translateY(-1px); }
    .btn-accept:active { transform: translateY(1px); }
    .btn-accept:disabled { opacity: .55; cursor: not-allowed; transform: none; }

    /* ===== Reject Button ===== */
   .btn-reject {
        background: linear-gradient(135deg, #b91c1c, #ef4444);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 10px rgba(239,68,68,.35);
        transition: all .18s;
    }
    .btn-reject:hover   { filter: brightness(1.08); transform: translateY(-1px); }
    .btn-reject:active  { transform: translateY(1px); }
    .btn-reject:disabled { opacity: .55; cursor: not-allowed; transform: none; }


    /* ===== Response — Đã sửa xong button ===== */
    .btn-fix-complete {
        background: linear-gradient(135deg, #0d6efd, #3b82f6);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 10px rgba(13,110,253,.35);
        transition: all .18s;
        margin-top: 6px;
    }
    .btn-fix-complete:hover  { filter: brightness(1.08); transform: translateY(-1px); }
    .btn-fix-complete:active { transform: translateY(1px); }
    .btn-fix-complete:disabled { opacity: .55; cursor: not-allowed; transform: none; }

    .responded-badge.fix-done { background: #dbeafe; color: #1e40af; }

    .response-time-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 8px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        font-size: 12px;
        font-weight: 600;
        color: #15803d;
    }

    .downtime-time-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 8px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        font-size: 12px;
        font-weight: 600;
        color: #b91c1c;
    }

    .responded-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
    }
    .responded-badge.accepted { background: #dcfce7; color: #166534; }
    .responded-badge.waited   { background: #fef3c7; color: #92400e; }
    .responded-badge.rejected { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }

    /* ===== Reject Modal ===== */
    .reject-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.55);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }
    .reject-modal-overlay.open { display: flex; }
 
    .reject-modal {
        background: #fff;
        border-radius: 16px;
        padding: 28px 28px 24px;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        animation: rejectModalIn .18s ease;
    }
    @@keyframes rejectModalIn {
        from { transform: scale(.94); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }
    .reject-modal h3 {
        margin: 0 0 6px;
        font-size: 18px;
        font-weight: 700;
        color: #111;
    }
    .reject-modal .modal-sub {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 18px;
    }
    .reject-modal textarea {
        width: 100%;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        padding: 12px 14px;
        font-size: 14px;
        font-family: inherit;
        resize: vertical;
        min-height: 90px;
        outline: none;
        transition: border-color .18s;
        box-sizing: border-box;
    }
    .reject-modal textarea:focus   { border-color: #ef4444; }
    .reject-modal textarea.invalid { border-color: #ef4444; background: #fff5f5; }
    .reject-modal .char-hint {
        font-size: 11px;
        color: #9ca3af;
        text-align: right;
        margin-top: 4px;
        margin-bottom: 16px;
    }
    .reject-modal .char-hint.warn { color: #ef4444; font-weight: 600; }
    .reject-modal .modal-footer {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }
    .reject-modal .btn-modal-cancel {
        background: #f3f4f6;
        color: #374151;
        border: none;
        border-radius: 8px;
        padding: 10px 22px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
    }
    .reject-modal .btn-modal-cancel:hover { background: #e5e7eb; }
    .reject-modal .btn-modal-submit {
        background: linear-gradient(135deg, #b91c1c, #ef4444);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 22px;
        font-size: 13px;
        font-weight: 700;
        cursor: not-allowed;
        opacity: .4;
        transition: all .15s;
    }
    .reject-modal .btn-modal-submit.active {
        opacity: 1;
        cursor: pointer;
    }
    .reject-modal .btn-modal-submit.active:hover { filter: brightness(1.08); }


    @@media (max-width: 600px) {
        .summary-row { grid-template-columns: 1fr 1fr; }
        .notif-grid  { grid-template-columns: 1fr 1fr; }
    }

    .toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .toolbar-title {
        font-weight: 700;
        font-size: 15px;
        flex: 1;
    }

    .btn-clear {
        background: #e5e7eb;
        border: none;
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
    }

    .btn-clear:hover { background: #d1d5db; }

    /* Sound toggle */
    .btn-sound {
        background: #ede9fe;
        color: #6d28d9;
        border: none;
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
    }

    .btn-sound:hover { background: #ddd6fe; }

    /* ===== Notification list ===== */
    .notif-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .notif-empty {
        text-align: center;
        padding: 60px 20px;
        color: var(--muted);
        font-size: 15px;
    }

    .notif-empty .empty-icon { font-size: 48px; display: block; margin-bottom: 12px; }

    /* Notification card */
    .notif-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-left: 5px solid var(--stop-color);
        border-radius: 12px;
        padding: 16px 18px;
        box-shadow: 0 2px 10px rgba(0,0,0,.05);
        animation: slideIn .3s ease;
        position: relative;
        overflow: hidden;
    }

    .notif-card.run-card  { border-left-color: var(--run-color); }
    .notif-card.new-card  { box-shadow: 0 0 0 3px rgba(239,68,68,.25), 0 4px 16px rgba(0,0,0,.08); }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-10px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .notif-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }

    .notif-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 99px;
        font-size: 12px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .badge-stop { background: #fee2e2; color: #991b1b; }
    .badge-run  { background: #dcfce7; color: #166534; }

    .notif-time {
        font-size: 12px;
        color: var(--muted);
        flex-shrink: 0;
    }

    .notif-machine {
        font-size: 17px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 2px;
    }

    .notif-op {
        font-size: 13px;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .notif-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 8px;
    }

    .notif-field {
        background: #f8fafc;
        border: 1px solid #f1f5f9;
        border-radius: 8px;
        padding: 7px 10px;
    }

    .notif-field-label {
        font-size: 11px;
        color: var(--muted);
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 2px;
    }

    .notif-field-value {
        font-size: 13.5px;
        color: var(--text);
        font-weight: 600;
        word-break: break-word;
    }

    /* Dismiss / Delete button */
    .notif-dismiss {
        position: absolute;
        top: 10px;
        right: 12px;
        background: transparent;
        border: none;
        font-size: 16px;
        color: var(--muted);
        cursor: pointer;
        padding: 2px 5px;
        line-height: 1;
        border-radius: 6px;
        transition: all .15s;
    }

    .notif-dismiss:hover { color: #ef4444; background: #fee2e2; }

    /* Date filter in toolbar */
    .notif-date-filter {
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        padding: 7px 10px;
        font-size: 13px;
        outline: none;
        cursor: pointer;
        font-family: inherit;
        color: #374151;
        transition: border-color .18s;
    }
    .notif-date-filter:focus { border-color: #ef4444; }

    .btn-today {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1.5px solid #bfdbfe;
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
        white-space: nowrap;
    }
    .btn-today:hover { background: #dbeafe; }

    /* Audio permission banner */
    .audio-banner {
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 10px;
        padding: 10px 16px;
        font-size: 13px;
        color: #92400e;
        margin-bottom: 16px;
        display: none;
        align-items: center;
        gap: 10px;
    }

    .audio-banner button {
        background: #f59e0b;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        margin-left: auto;
    }
</style>

<!-- Header -->
<style>
    /* ── Tab navigation ── */
    .tech-tabs {
        display: flex;
        gap: 0;
        background: #1a1a2e;
        padding: 0 24px;
        border-bottom: 2px solid #2d2d44;
    }
    .tech-tab-btn {
        background: none;
        border: none;
        color: #9ca3af;
        padding: 12px 22px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        transition: all .18s;
        display: flex;
        align-items: center;
        gap: 7px;
    }
    .tech-tab-btn:hover { color: #fff; }
    .tech-tab-btn.active { color: #fff; border-bottom-color: #ef4444; }

    /* ── Tech edit table ── */
    .te-wrap {
        display: none;
        padding: 20px 0;
    }
    .te-wrap.active { display: block; }

    .te-toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }
    .te-search {
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 13px;
        outline: none;
        width: 220px;
    }
    .te-search:focus { border-color: #ef4444; }

    .te-filter-select {
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        padding: 7px 10px;
        font-size: 13px;
        outline: none;
        cursor: pointer;
    }

    .btn-te-refresh {
        background: #f1f5f9;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        padding: 7px 14px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
    }
    .btn-te-refresh:hover { background: #e5e7eb; }

    .te-table-wrap {
        overflow-x: auto;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
    }
    .te-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }
    .te-table th {
        background: #111;
        color: #fff;
        padding: 11px 14px;
        text-align: left;
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .04em;
        white-space: nowrap;
    }
    .te-table td {
        padding: 10px 14px;
        border-bottom: 1px solid #f1f5f9;
        color: #374151;
        vertical-align: middle;
    }
    .te-table tr:last-child td { border-bottom: none; }
    .te-table tr:hover td { background: #f8fafc; }

    .te-state-badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 99px;
        font-size: 11px;
        font-weight: 700;
    }
    .state-STOP     { background: #fee2e2; color: #991b1b; }
    .state-RUN      { background: #dcfce7; color: #166534; }
    .state-RESPONSE { background: #fef3c7; color: #92400e; }

    .btn-te-edit {
        background: #eff6ff;
        border: 1.5px solid #bfdbfe;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        color: #1d4ed8;
        cursor: pointer;
        transition: all .15s;
        white-space: nowrap;
    }
    .btn-te-edit:hover { background: #dbeafe; border-color: #93c5fd; }

    .te-empty {
        text-align: center;
        padding: 40px;
        color: #9ca3af;
        font-size: 14px;
    }

    /* ── Edit Modal ── */
    .te-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 9998;
        align-items: center;
        justify-content: center;
    }
    .te-modal-overlay.open { display: flex; }
    .te-modal {
        background: #fff;
        width: min(540px, 94vw);
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        overflow: hidden;
        animation: teModalIn .2s ease;
    }
    @@keyframes teModalIn {
        from { opacity: 0; transform: translateY(-16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .te-modal-header {
        background: #111;
        border-top: 4px solid #ef4444;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .te-modal-header h3 { margin: 0; color: #fff; font-size: 16px; font-weight: 700; }
    .te-modal-header .te-modal-sub { color: #9ca3af; font-size: 12px; margin-top: 3px; }
    .te-modal-close {
        background: none;
        border: none;
        color: #9ca3af;
        font-size: 22px;
        cursor: pointer;
        line-height: 1;
        padding: 0;
    }
    .te-modal-close:hover { color: #fff; }
    .te-modal-body { padding: 20px; }
    .te-modal-info {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 18px;
        font-size: 13px;
        color: #374151;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px 16px;
    }
    .te-modal-info .info-label { color: #6b7280; font-size: 11px; font-weight: 600; text-transform: uppercase; }
    .te-modal-info .info-val   { font-weight: 600; color: #111827; }

    .te-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }
    .te-form-group { display: flex; flex-direction: column; gap: 5px; }
    .te-form-group label { font-size: 12px; font-weight: 700; color: #374151; text-transform: uppercase; letter-spacing: .04em; }
    .te-form-group input, .te-form-group textarea {
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        padding: 9px 12px;
        font-size: 13px;
        outline: none;
        transition: border .15s;
        resize: vertical;
    }
    .te-form-group input:focus, .te-form-group textarea:focus { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,.1); }

    .te-modal-footer {
        padding: 14px 20px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }
    .btn-te-save {
        background: linear-gradient(135deg, #dc2626, #ef4444);
        color: #fff;
        border: none;
        border-radius: 9px;
        padding: 10px 24px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: all .15s;
        box-shadow: 0 3px 10px rgba(239,68,68,.3);
    }
    .btn-te-save:hover { filter: brightness(1.08); }
    .btn-te-save:disabled { opacity: .6; cursor: not-allowed; }
    .btn-te-cancel {
        background: #f1f5f9;
        color: #374151;
        border: 1.5px solid #e5e7eb;
        border-radius: 9px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }
    .btn-te-cancel:hover { background: #e5e7eb; }

    /* Pagination */
    .te-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 14px;
        flex-wrap: wrap;
        gap: 8px;
    }
    .te-page-info { font-size: 13px; color: #6b7280; }
