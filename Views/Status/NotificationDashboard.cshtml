/* ===== Tech bấm Response (Đã sửa xong) — tạo RUN record + notify Prod ===== */
async function techFixComplete(btn) {
    const card = btn.closest('.notif-card');
    if (!card) return;

    const techResponseId   = card.dataset.techResponseId   || '';
    const actionsDiv       = card.querySelector('.notif-actions');

    btn.disabled  = true;
    btn.innerHTML = '⏳ 发送中...';

    try {
        const res = await fetch(`${pathBase}/Status/TechnicianFixComplete`, {
            method : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body   : JSON.stringify({ techResponseId: parseInt(techResponseId) || 0 })
        });
        const data = await res.json();

        if (data.success) {
            // Thay nút bằng badge "Đã gửi"
            btn.replaceWith((() => {
                const s = document.createElement('span');
                s.className   = 'responded-badge fix-done';
                s.textContent = '🔧 已发送修复完成通知';
                return s;
            })());

            // ── PIE điền thông tin kỹ thuật vào STOP record gốc ──
            const techRespId = card.dataset.techResponseId || '';
            if (techRespId) {
                try {
                    const recRes  = await fetch(`${pathBase}/Status/GetStopRecordByTechResponse?techResponseId=${encodeURIComponent(techRespId)}`);
                    const recData = await recRes.json();
                    if (recData.success && recData.data) {
                        openPostRunModal(recData.data.id, recData.data);
                    }
                } catch (e) { console.warn('GetStopRecord failed:', e); }
            }
        } else {
            btn.disabled  = false;
            btn.innerHTML = '🔧 响应 — 已修复完成';
        }
    } catch (err) {
        console.error('techFixComplete error:', err);
        btn.disabled  = false;
        btn.innerHTML = '🔧 响应 — 已修复完成';
    }
}

