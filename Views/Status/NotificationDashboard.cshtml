<!-- Toast -->
<div class="te-toast" id="teToast"></div>

<!-- Flash overlay toàn màn hình khi có STOP -->
<div id="flashOverlay" style="
    display:none;
    position:fixed;
    inset:0;
    background:rgba(239,68,68,0.18);
    z-index:9999;
    pointer-events:none;
    animation: flashAnim 0.12s ease;
"></div>

<style>
@@keyframes flashAnim {
    0%   { opacity: 0; }
    40%  { opacity: 1; }
    100% { opacity: 0; }
}

/* Nháy border toàn trang */
@@keyframes borderPulse {
    0%, 100% { box-shadow: inset 0 0 0 6px rgba(239,68,68,0); }
    50%       { box-shadow: inset 0 0 0 6px rgba(239,68,68,0.7); }
}

body.flashing {
    animation: borderPulse 0.4s ease 4;
}

/* Nháy title tab */
.notif-card.flash-card {
    animation: cardFlash 0.5s ease 3;
}

@@keyframes cardFlash {
    0%, 100% { background: #fff; }
    50%       { background: #fee2e2; }
}
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
"use strict";

const pathBase   = '@Context.Request.PathBase'.replace(/\/$/, '');
const notifList  = document.getElementById('notifList');
let   emptyState = document.getElementById('emptyState'); // FIX: let để có thể gán null
const connBadge  = document.getElementById('connBadge');
const connText   = document.getElementById('connText');

let soundEnabled  = true;
let cntStop  = 0;
let cntRun   = 0;
let cntTotal = 0;
let cntAccept = 0;
let cntWait   = 0;
let audioCtx = null;
let audioUnlocked = false;

// Tab title flash
let titleFlashInterval = null;
const originalTitle = document.title;

/* ===== Unlock AudioContext ngay khi user click/touch lần đầu ===== */
function ensureAudioCtx() {
    if (audioUnlocked && audioCtx) return audioCtx;
    try {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        if (audioCtx.state === 'suspended') audioCtx.resume();
        audioUnlocked = true;
        document.getElementById('audioBanner').style.display = 'none';
    } catch (e) {
        console.warn('AudioContext failed:', e);
    }
    return audioCtx;
}

// Unlock ngay khi load nếu có thể, sau đó unlock lại mỗi lần user tương tác
['click','touchstart','keydown','scroll'].forEach(evt => {
    document.addEventListener(evt, () => ensureAudioCtx(), { once: false, passive: true });
});

function unlockAudio() {
    ensureAudioCtx();
    document.getElementById('audioBanner').style.display = 'none';
}

function toggleSound() {
    soundEnabled = !soundEnabled;
    document.getElementById('btnSound').textContent =
        soundEnabled ? '🔔 声音: 开' : '🔕 声音: 关';
}

/* ===== Âm thanh STOP: còi báo động to, 5 tiếng bip nhanh ===== */
function playStopSound() {
    if (!soundEnabled) return;
    const ctx = ensureAudioCtx();
    if (!ctx) return;

    if (ctx.state === 'suspended') ctx.resume();

    // CompressorNode để âm to hơn
    const compressor = ctx.createDynamicsCompressor();
    compressor.threshold.value = -10;
    compressor.knee.value      = 0;
    compressor.ratio.value     = 20;
    compressor.attack.value    = 0;
    compressor.release.value   = 0.1;
    compressor.connect(ctx.destination);

    // 5 tiếng bíp liên tục, to, tần số cao
    const times = [0, 0.22, 0.44, 0.66, 0.88];
    times.forEach(offset => {
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(compressor);

        osc.type            = 'square';   // square wave → to và rõ hơn sine
        osc.frequency.value = 1050;       // tần số cao nghe rõ hơn

        const t = ctx.currentTime + offset;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(1.0, t + 0.01);  // lên nhanh
        gain.gain.setValueAtTime(1.0, t + 0.14);
        gain.gain.linearRampToValueAtTime(0, t + 0.18);    // tắt

        osc.start(t);
        osc.stop(t + 0.2);
    });
}

/* ===== Âm thanh RUN: 2 tiếng bíp nhẹ xuống tần số ===== */
function playRunSound() {
    if (!soundEnabled) return;
    const ctx = ensureAudioCtx();
    if (!ctx) return;
    if (ctx.state === 'suspended') ctx.resume();

    [0, 0.3].forEach((offset, i) => {
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.type            = 'sine';
        osc.frequency.value = i === 0 ? 660 : 440;
        const t = ctx.currentTime + offset;
        gain.gain.setValueAtTime(0.6, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.25);
        osc.start(t);
        osc.stop(t + 0.3);
    });
}

/* ===== Flash toàn màn hình ===== */
function flashScreen() {
    const overlay = document.getElementById('flashOverlay');
    let count = 0;
    const max = 6; // số lần nháy

    function doFlash() {
        if (count >= max) { overlay.style.display = 'none'; return; }
        overlay.style.display = 'block';
        overlay.style.animation = 'none';
        overlay.offsetHeight; // reflow
        overlay.style.animation = 'flashAnim 0.22s ease';
        count++;
        setTimeout(() => {
            overlay.style.display = 'none';
            setTimeout(doFlash, 80);
        }, 220);
    }
    doFlash();

    // Nháy border body
    document.body.classList.add('flashing');
    setTimeout(() => document.body.classList.remove('flashing'), 2000);
}

/* ===== Nháy title tab ===== */
function startTitleFlash(machineName) {
    if (titleFlashInterval) clearInterval(titleFlashInterval);
    let show = true;
    titleFlashInterval = setInterval(() => {
        document.title = show ? `🛑 停机: ${machineName}` : originalTitle;
        show = !show;
    }, 700);
    // Dừng sau 15 giây
    setTimeout(stopTitleFlash, 15000);
}

function stopTitleFlash() {
    if (titleFlashInterval) { clearInterval(titleFlashInterval); titleFlashInterval = null; }
    document.title = originalTitle;
}

/* ===== Update counters ===== */
function updateCounters() {
    document.getElementById('cntStop').textContent   = cntStop;
    document.getElementById('cntRun').textContent    = cntRun;
    document.getElementById('cntTotal').textContent  = cntTotal;
    document.getElementById('cntAccept').textContent = cntAccept;
    document.getElementById('cntWait').textContent   = cntWait;
}

/* ===== Render STOP card ===== */
function renderStopCard(data, prepend = true) {
    if (emptyState) { emptyState.remove(); emptyState = null; }

    const effLabel = data.effect === '1' ? '影响生产'
                   : data.effect === '2' ? '不影响生产'
                   : (data.effect || '-');

    const card = document.createElement('div');
    card.className = 'notif-card new-card';
    card.dataset.techResponseId   = data.techResponseId   || data.id || '';
    card.dataset.operatorUsername = data.operatorUsername || '';
    card.dataset.machineCode      = data.machineCode      || '';

    // Nếu đã có techAction (load từ DB), render ngay trạng thái đã respond
    const alreadyResponded = data.techAction && data.techAction !== '';
    const actionsHtml = alreadyResponded
        ? buildRespondedBadge(data.techAction, data.techUsername, data.respondDatetime, !!data.fixComplete)
        : `<button class="btn-accept" onclick="respondToOperator(this,'ACCEPT')">✅ 接受 — 正在前往维修</button>
           <button class="btn-wait"   onclick="respondToOperator(this,'WAIT')">⏳ 等待 — 请稍候</button>`;

    card.innerHTML = `
        <div class="notif-top">
            <span class="notif-badge badge-stop">🛑 停机 / 呼叫</span>
            <span class="notif-time">${data.datetime || new Date().toLocaleString('zh-CN')}</span>
        </div>
        <div class="notif-machine">${data.machineCode || '(无设备代码)'}</div>
        <div class="notif-op">📍 ${data.operation || '-'} ${data.location ? '· ' + data.location : ''}</div>
        <div class="notif-grid">
            <div class="notif-field">
                <div class="notif-field-label">👤 操作员</div>
                <div class="notif-field-value">${data.employeeName || data.employeeCode || '-'} ${data.employeeCode ? '(' + data.employeeCode + ')' : ''}</div>
            </div>
            <div class="notif-field">
                <div class="notif-field-label">🔴 故障原因</div>
                <div class="notif-field-value">${data.reason || '-'}</div>
            </div>
            <div class="notif-field">
                <div class="notif-field-label">⚠ 影响程度</div>
                <div class="notif-field-value">${effLabel}</div>
            </div>
            <div class="notif-field">
                <div class="notif-field-label">⏱ 预估时间</div>
                <div class="notif-field-value">${data.estimateTime || '-'}</div>
            </div>
            ${data.station ? `<div class="notif-field"><div class="notif-field-label">🔩 工位</div><div class="notif-field-value">${data.station}</div></div>` : ''}
            ${data.description ? `<div class="notif-field" style="grid-column:1/-1;"><div class="notif-field-label">📝 详细描述</div><div class="notif-field-value">${data.description}</div></div>` : ''}
        </div>
        <div class="notif-actions">${actionsHtml}</div>
    `;

    if (prepend) {
        notifList.insertBefore(card, notifList.firstChild);
    } else {
        notifList.appendChild(card);
    }

    // Chỉ highlight nếu là thông báo mới real-time (không phải load từ DB)
    if (prepend) setTimeout(() => card.classList.remove('new-card'), 5000);
    else card.classList.remove('new-card');
}

function buildRespondedBadge(action, techUser, respondTime, fixComplete = false) {
    const badge = action === 'ACCEPT'
        ? `<span class="responded-badge accepted">✅ 已接受${techUser ? ' 由 ' + techUser : ''}${respondTime ? ' · ' + respondTime : ''}</span>`
        : `<span class="responded-badge waited">⏳ 已等待${techUser ? ' 由 ' + techUser : ''}${respondTime ? ' · ' + respondTime : ''}</span>`;

    const responseBtn = fixComplete
        ? `<span class="responded-badge fix-done">🔧 已发送修复完成通知</span>`
        : `<button class="btn-fix-complete" onclick="techFixComplete(this)">🔧 响应 — 已修复完成</button>`;

    return badge + responseBtn;
}

/* ===== Tech respond: gửi Accept hoặc Wait ngược về Operator ===== */
async function respondToOperator(btn, action) {
    const card = btn.closest('.notif-card');
    if (!card) return;

    const techResponseId   = card.dataset.techResponseId   || '';
    const operatorUsername = card.dataset.operatorUsername || '';
    const machineCode      = card.dataset.machineCode      || '';
    const actionsDiv       = card.querySelector('.notif-actions');

    card.querySelectorAll('.btn-accept, .btn-wait').forEach(b => b.disabled = true);
    btn.innerHTML = '⏳ 发送中...';

    try {
        const res = await fetch(`${pathBase}/Status/TechnicianRespond`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ techResponseId: parseInt(techResponseId) || 0, action, operatorUsername, machineCode })
        });
        const data = await res.json();

        if (data.success) {
            if (actionsDiv) {
                actionsDiv.innerHTML = buildRespondedBadge(action, null, null);
            }
            // Cập nhật counter
            if (action === 'ACCEPT') { cntAccept++; }
            else                     { cntWait++;   }
            updateCounters();
        } else {
            card.querySelectorAll('.btn-accept, .btn-wait').forEach(b => b.disabled = false);
            btn.innerHTML = action === 'ACCEPT' ? '✅ 接受 — 正在前往维修' : '⏳ 等待 — 请稍候';
        }
    } catch (err) {
        console.error('respondToOperator error:', err);
        card.querySelectorAll('.btn-accept, .btn-wait').forEach(b => b.disabled = false);
        btn.innerHTML = action === 'ACCEPT' ? '✅ 接受 — 正在前往维修' : '⏳ 等待 — 请稍候';
    }
}

/* ===== Tech bấm Response (Đã sửa xong) — tạo RUN record + notify Prod ===== */
async function techFixComplete(btn) {
    const card = btn.closest('.notif-card');
    if (!card) return;

    const techResponseId   = card.dataset.techResponseId   || '';
    const actionsDiv       = card.querySelector('.notif-actions');

    btn.disabled  = true;
    btn.innerHTML = '⏳ 发送中...';

    try {
        const res = await fetch(`${pathBase}/Status/TechnicianFixComplete`, {
            method : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body   : JSON.stringify({ techResponseId: parseInt(techResponseId) || 0 })
        });
        const data = await res.json();

        if (data.success) {
            // Thay nút bằng badge "Đã gửi"
            btn.replaceWith((() => {
                const s = document.createElement('span');
                s.className   = 'responded-badge fix-done';
                s.textContent = '🔧 已发送修复完成通知';
                return s;
            })());
        } else {
            btn.disabled  = false;
            btn.innerHTML = '🔧 响应 — 已修复完成';
        }
    } catch (err) {
        console.error('techFixComplete error:', err);
        btn.disabled  = false;
        btn.innerHTML = '🔧 响应 — 已修复完成';
    }
}

/* ===== Render RUN card ===== */
function renderRunCard(data) {
    if (emptyState) emptyState.remove();

    const card = document.createElement('div');
    card.className = 'notif-card run-card';
    card.innerHTML = `
        <button class="notif-dismiss" onclick="dismissCard(this)" title="关闭">×</button>
        <div class="notif-top">
            <span class="notif-badge badge-run">▶ 恢复运行</span>
            <span class="notif-time">${data.datetime || new Date().toLocaleString('zh-CN')}</span>
        </div>
        <div class="notif-machine">${data.machineCode || '-'}</div>
        <div class="notif-op">📍 ${data.operation || '-'}</div>
        <div style="font-size:13px;color:#166534;margin-top:6px;">✅ 设备已恢复正常运行。</div>
    `;

    notifList.insertBefore(card, notifList.firstChild);
}

/* ===== dismissCard — chỉ cho dismiss card đã responded ===== */
function dismissCard(btn) {
    const card = btn.closest('.notif-card');
    const badge = card.querySelector('.responded-badge');
    if (!badge) {
        // Chưa respond → không cho đóng, nhắc Tech xử lý trước
        card.style.outline = '2px solid #ef4444';
        setTimeout(() => card.style.outline = '', 1200);
        return;
    }
    card.remove();
    if (notifList.querySelectorAll('.notif-card').length === 0) showEmptyState();
}

function showEmptyState() {
    const empty = document.createElement('div');
    empty.className = 'notif-empty';
    empty.id = 'emptyState';
    empty.innerHTML = `<span class="empty-icon">🟢</span>等待通知中...<br><small style="font-size:13px;margin-top:6px;display:block;">当操作员按下 <strong>呼叫技术员</strong> 时，通知会立即显示在此处。</small>`;
    notifList.appendChild(empty);
}

function clearAll() {
    // Chỉ xóa các card đã responded
    notifList.querySelectorAll('.notif-card').forEach(card => {
        const badge = card.querySelector('.responded-badge');
        if (badge) card.remove();
    });
    if (notifList.querySelectorAll('.notif-card').length === 0) {
        notifList.innerHTML = '';
        showEmptyState();
        cntStop = cntRun = cntTotal = cntAccept = cntWait = 0;
        updateCounters();
    }
}

/* ===== Browser Notification (nếu user cho phép) ===== */
function requestBrowserNotification() {
    if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission();
    }
}

function showBrowserNotif(title, body) {
    if ('Notification' in window && Notification.permission === 'granted') {
        new Notification(title, { body, icon: '/favicon.ico' });
    }
}

/* ===== SignalR Connection ===== */
const connection = new signalR.HubConnectionBuilder()
    .withUrl(`${pathBase}/downtimeHub`)
    .withAutomaticReconnect([1000, 2000, 5000, 10000])
    .configureLogging(signalR.LogLevel.Warning)
    .build();

// Nhận thông báo STOP từ server (real-time)
connection.on("ReceiveStopNotification", (data) => {
    cntStop++;
    cntTotal++;
    updateCounters();
    renderStopCard(data, true);  // prepend = true, thêm vào đầu
    playStopSound();
    flashScreen();
    startTitleFlash(data.machineCode || '停机');
    showBrowserNotif(
        `🛑 停机: ${data.machineCode}`,
        `工序: ${data.operation}\n操作员: ${data.employeeName || data.employeeCode}\n原因: ${data.reason}`
    );
});

// Nhận thông báo RUN từ server
connection.on("ReceiveRunNotification", (data) => {
    cntRun++;
    cntTotal++;
    updateCounters();
    renderRunCard(data);
    playRunSound();
    showBrowserNotif(`▶ 恢复运行: ${data.machineCode}`, `设备已重新运行\n${data.operation}`);
});

// Connection state handlers
connection.onreconnecting(() => {
    if (connBadge) connBadge.className = 'conn-badge connecting';
    if (connText)  connText.textContent = '重连中...';
});

connection.onreconnected(() => {
    if (connBadge) connBadge.className = 'conn-badge connected';
    if (connText)  connText.textContent = '已连接 ✓';
    connection.invoke("JoinTechnicianGroup").catch(console.error);
});

connection.onclose(() => {
    if (connBadge) connBadge.className = 'conn-badge disconnected';
    if (connText)  connText.textContent = '连接断开 ✗';
});

// Khởi động kết nối
async function startConnection() {
    try {
        await connection.start();
        await connection.invoke("JoinTechnicianGroup");
        if (connBadge) connBadge.className = 'conn-badge connected';
        if (connText)  connText.textContent = '已连接 ✓';
    } catch (err) {
        if (connBadge) connBadge.className = 'conn-badge disconnected';
        if (connText)  connText.textContent = '连接错误 ✗';
        console.error('SignalR error:', err);
        setTimeout(startConnection, 5000);
    }
}

/* ===== Load thông báo từ DB khi Tech vào/refresh trang ===== */
async function loadPendingFromDB() {
    try {
        const res  = await fetch(`${pathBase}/Status/GetPendingNotifications`);
        if (!res.ok) return;
        const list = await res.json();

        if (!list || list.length === 0) return;

        // Xóa empty state nếu có
        const empty = document.getElementById('emptyState');
        if (empty) empty.remove();

        // Render từng bản ghi — append (cũ nhất xuống dưới, mới nhất lên đầu đã sort từ server)
        list.forEach(item => {
            renderStopCard(item, false); // false = append xuống dưới
            cntTotal++;
            if (!item.techAction) {
                cntStop++;
            } else if (item.techAction === 'ACCEPT') {
                cntAccept++;
            } else if (item.techAction === 'WAIT') {
                cntWait++;
            }
        });

        // Sau khi load xong, đảo ngược thứ tự để mới nhất lên đầu
        const cards = Array.from(notifList.querySelectorAll('.notif-card'));
        cards.reverse().forEach(c => notifList.insertBefore(c, notifList.firstChild));

        updateCounters();
    } catch (err) {
        console.error('loadPendingFromDB error:', err);
    }
}

/* ===== Init ===== */
document.addEventListener('DOMContentLoaded', () => {
    loadPendingFromDB();   // ← Load từ DB ngay khi trang mở
    startConnection();
    requestBrowserNotification();

    const banner = document.getElementById('audioBanner');
    banner.style.display = 'flex';
    banner.querySelector('span').textContent =
        '⚠ 请点击右侧按钮以启用报警声音。只需操作一次！';

    document.addEventListener('click', () => {
        ensureAudioCtx();
        if (audioUnlocked) banner.style.display = 'none';
    }, { passive: true });
});

/* ══════════════════════════════════════════════════════════
   TAB SWITCHING
══════════════════════════════════════════════════════════ */
function switchTab(tab, btn) {
    // Toggle tab panels
    document.getElementById('tabNotif').classList.toggle('active', tab === 'notif');
    document.getElementById('tabEdit').classList.toggle('active',  tab === 'edit');

    // Toggle tab buttons
    document.querySelectorAll('.tech-tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Load data khi mở tab edit
    if (tab === 'edit') teLoadRecords(1);
}

/* ══════════════════════════════════════════════════════════
   TECH EDIT RECORDS
══════════════════════════════════════════════════════════ */
let tePage     = 1;
let tePageSize = 15;
let teTotalPages = 1;
let teEditingId  = null;
let teAllRows    = []; // cache để filter client-side

async function teLoadRecords(page) {
    tePage = page || 1;
    const state = document.getElementById('teStateFilter').value;

    const today = new Date();
    const yyyy  = today.getFullYear();
    const mm    = String(today.getMonth() + 1).padStart(2, '0');
    const dd    = String(today.getDate()).padStart(2, '0');
    const fromDate = `${yyyy}-${mm}-${dd}`;

    const url = `${pathBase}/Status/TechGetRecords?page=${tePage}&pageSize=${tePageSize}&state=${encodeURIComponent(state)}&fromDate=${fromDate}`;

    document.getElementById('teTableBody').innerHTML =
        '<tr><td colspan="11" class="te-empty">⏳ Đang tải...</td></tr>';

    try {
        const res  = await fetch(url);
        const data = await res.json();

        teAllRows    = data.records || [];
        teTotalPages = data.totalPages || 1;

        teRenderTable(teAllRows);
        teRenderPagination(data.totalCount);

        document.getElementById('teRecordCount').textContent =
            `Tổng: ${data.totalCount || 0} records`;

    } catch (e) {
        document.getElementById('teTableBody').innerHTML =
            '<tr><td colspan="11" class="te-empty" style="color:#ef4444;">❌ Lỗi tải dữ liệu</td></tr>';
    }
}

function teRenderTable(rows) {
    const tbody = document.getElementById('teTableBody');
    if (!rows || rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="11" class="te-empty">📭 Không có dữ liệu</td></tr>';
        return;
    }

    tbody.innerHTML = rows.map(r => {
        const stateClass = r.state === 'STOP' ? 'state-STOP'
                         : r.state === 'RUN'  ? 'state-RUN'
                         : 'state-RESPONSE';
        const dt = r.datetime ? new Date(r.datetime).toLocaleString('vi-VN', { hour12: false }) : '-';
        const truncate = (s, n) => s && s.length > n ? s.substring(0, n) + '…' : (s || '-');

        return `<tr>
            <td style="font-weight:700;color:#6366f1;">#${r.id}</td>
            <td><span class="te-state-badge ${stateClass}">${r.state || '-'}</span></td>
            <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${r.operation || ''}">${truncate(r.operation, 20)}</td>
            <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${r.machineCode || ''}">${truncate(r.machineCode, 18)}</td>
            <td>${r.employeeName || r.employeeCode || '-'}</td>
            <td style="color:${r.station ? '#0369a1' : '#9ca3af'};">${r.station || '-'}</td>
            <td style="color:${r.action ? '#0369a1' : '#9ca3af'};">${truncate(r.action, 15)}</td>
            <td style="color:${r.rootCause ? '#0369a1' : '#9ca3af'};">${truncate(r.rootCause, 15)}</td>
            <td style="color:${r.spareParts ? '#0369a1' : '#9ca3af'};">${truncate(r.spareParts, 15)}</td>
            <td style="font-size:12px;color:#6b7280;">${dt}</td>
            <td>
                <button class="btn-te-edit" onclick='teOpenModal(${JSON.stringify(r)})'>✏️ Sửa</button>
            </td>
        </tr>`;
    }).join('');
}

function teFilterTable() {
    const q = document.getElementById('teSearch').value.toLowerCase().trim();
    if (!q) { teRenderTable(teAllRows); return; }
    const filtered = teAllRows.filter(r =>
        (r.machineCode  || '').toLowerCase().includes(q) ||
        (r.operation    || '').toLowerCase().includes(q) ||
        (r.employeeName || '').toLowerCase().includes(q) ||
        (r.employeeCode || '').toLowerCase().includes(q) ||
        (r.station      || '').toLowerCase().includes(q)
    );
    teRenderTable(filtered);
}

function teRenderPagination(totalCount) {
    const wrap = document.getElementById('tePagination');
    if (teTotalPages <= 1) { wrap.style.display = 'none'; return; }
    wrap.style.display = 'flex';

    document.getElementById('tePageInfo').textContent =
        `Trang ${tePage} / ${teTotalPages} (${totalCount} records)`;

    const btns = document.getElementById('tePageBtns');
    btns.innerHTML = '';

    function mkBtn(label, p, active, disabled) {
        const b = document.createElement('button');
        b.className = 'te-page-btn' + (active ? ' active' : '');
        b.textContent = label;
        b.disabled = disabled;
        if (!disabled && !active) b.onclick = () => teLoadRecords(p);
        btns.appendChild(b);
    }

    mkBtn('‹', tePage - 1, false, tePage === 1);
    for (let p = Math.max(1, tePage - 2); p <= Math.min(teTotalPages, tePage + 2); p++) {
        mkBtn(p, p, p === tePage, false);
    }
    mkBtn('›', tePage + 1, false, tePage === teTotalPages);
}

/* ── Modal ── */
function teOpenModal(record) {
    teEditingId = record.id;

    // Thông tin read-only
    document.getElementById('teModalInfo').innerHTML = `
        <div><div class="info-label">ID</div><div class="info-val">#${record.id}</div></div>
        <div><div class="info-label">Trạng thái</div><div class="info-val">${record.state || '-'}</div></div>
        <div><div class="info-label">Máy</div><div class="info-val">${record.machineCode || '-'}</div></div>
        <div><div class="info-label">Nhân viên</div><div class="info-val">${record.employeeName || record.employeeCode || '-'}</div></div>
        <div style="grid-column:1/-1;"><div class="info-label">Công đoạn</div><div class="info-val">${record.operation || '-'}</div></div>
    `;
    document.getElementById('teModalSub').textContent =
        `Máy: ${record.machineCode || '-'} · ${record.state || ''} · #${record.id}`;

    // Fill 4 trường
    document.getElementById('teFieldStation').value   = record.station   || '';
    document.getElementById('teFieldAction').value    = record.action    || '';
    document.getElementById('teFieldRootCause').value = record.rootCause || '';
    document.getElementById('teFieldSpareParts').value= record.spareParts|| '';

    document.getElementById('teModalOverlay').classList.add('open');
    document.getElementById('teFieldStation').focus();
}

function closeTeModal() {
    document.getElementById('teModalOverlay').classList.remove('open');
    teEditingId = null;
}

async function teSaveRecord() {
    if (!teEditingId) return;

    const btn = document.getElementById('teSaveBtn');
    btn.disabled  = true;
    btn.textContent = '⏳ Đang lưu...';

    try {
        const res = await fetch(`${pathBase}/Status/TechUpdateRecord`, {
            method : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body   : JSON.stringify({
                id        : teEditingId,
                station   : document.getElementById('teFieldStation').value.trim(),
                action    : document.getElementById('teFieldAction').value.trim(),
                rootCause : document.getElementById('teFieldRootCause').value.trim(),
                spareParts: document.getElementById('teFieldSpareParts').value.trim()
            })
        });
        const data = await res.json();

        if (data.success) {
            closeTeModal();
            teShowToast('✅ Lưu thành công!');
            teLoadRecords(tePage); // Reload bảng
        } else {
            teShowToast('❌ ' + (data.message || 'Lỗi lưu'), true);
        }
    } catch (e) {
        teShowToast('❌ Lỗi kết nối', true);
    } finally {
        btn.disabled    = false;
        btn.textContent = '💾 Lưu';
    }
}

// Đóng modal khi click overlay
document.getElementById('teModalOverlay').addEventListener('click', function(e) {
    if (e.target === this) closeTeModal();
});

// Toast nhỏ
function teShowToast(msg, isError = false) {
    const t = document.getElementById('teToast');
    t.textContent = msg;
    t.className   = 'te-toast show' + (isError ? ' error' : '');
    setTimeout(() => t.classList.remove('show'), 3000);
}
</script>