/* ===== Init ===== */
document.addEventListener('DOMContentLoaded', () => {
    // Set default date = today
    const df = document.getElementById('notifDateFilter');
    if (df) df.value = new Date().toISOString().split('T')[0];

    loadPendingFromDB().then(() => {
        // Sau khi load xong, check URL param ?highlight=xxx để scroll đến đúng card
        const highlightId = new URLSearchParams(window.location.search).get('highlight');
        if (highlightId) {
            setTimeout(() => window.scrollToTechCard(parseInt(highlightId)), 300);
            // Xóa param khỏi URL để tránh re-highlight khi reload
            history.replaceState({}, '', window.location.pathname);
        }
    });

    startConnection();
    requestBrowserNotification();

    const banner = document.getElementById('audioBanner');
    banner.style.display = 'flex';
    banner.querySelector('span').textContent =
        '⚠ 请点击右侧按钮以启用报警声音。只需操作一次！';

    document.addEventListener('click', () => {
        ensureAudioCtx();
        if (audioUnlocked) banner.style.display = 'none';
    }, { passive: true });
});

