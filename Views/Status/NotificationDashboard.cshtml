function openRejectModal(btn) {
    const card = btn.closest('.notif-card');
    if (!card) return;

    _rejectCtx = {
        btn,
        techResponseId   : card.dataset.techResponseId   || '',
        operatorUsername : card.dataset.operatorUsername  || '',
        machineCode      : card.dataset.machineCode       || '',
        operation        : card.dataset.operation         || '',
        stopDatetime     : card.dataset.stopDatetime      || ''
    };

    document.getElementById('rejectModalMachine').textContent = _rejectCtx.machineCode || '—';
    document.getElementById('rejectModalOp').textContent      = _rejectCtx.operation   || '—';

    const ta = document.getElementById('rejectReasonInput');
    ta.value = '';
    ta.classList.remove('invalid');
    document.getElementById('rejectCharHint').textContent = '0 / 300 ký tự';
    document.getElementById('rejectCharHint').classList.remove('warn');
    document.getElementById('rejectSubmitBtn').classList.remove('active');

    document.getElementById('rejectModalOverlay').classList.add('open');
    setTimeout(() => ta.focus(), 120);
}

function closeRejectModal() {
    document.getElementById('rejectModalOverlay').classList.remove('open');
    _rejectCtx = null;
}

function onRejectInput(ta) {
    const len  = ta.value.trim().length;
    const hint = document.getElementById('rejectCharHint');
    const btn  = document.getElementById('rejectSubmitBtn');

    hint.textContent = `${ta.value.length} / 300 ký tự`;
    hint.classList.toggle('warn', ta.value.length > 270);

    if (len > 0) {
    ta.classList.remove('invalid');
    btn.classList.add('active');
} else {
    btn.classList.remove('active');
}

}

async function submitReject() {
    if (!_rejectCtx) return;

    const ta     = document.getElementById('rejectReasonInput');
    const reason = ta.value.trim();

    if (!reason) {
        ta.classList.add('invalid');
        ta.focus();
        return;
    }

    const submitBtn = document.getElementById('rejectSubmitBtn');
    submitBtn.disabled   = true;
    submitBtn.textContent = '⏳ Đang gửi...';

    const stopDt = parseDT(_rejectCtx.stopDatetime);
    const mins   = minutesBetween(stopDt, new Date());
    const responseTimeStr = mins !== null ? formatMinutes(mins) : null;

    try {
        const res = await fetch(`${pathBase}/Status/TechnicianRespond`, {
            method  : 'POST',
            headers : { 'Content-Type': 'application/json' },
            body    : JSON.stringify({
                techResponseId   : parseInt(_rejectCtx.techResponseId) || 0,
                action           : 'REJECT',
                operatorUsername : _rejectCtx.operatorUsername,
                machineCode      : _rejectCtx.machineCode,
                rejectReason     : reason
            })
        });
        const data = await res.json();

        if (data.success) {
            const card = _rejectCtx.btn.closest('.notif-card');
            if (card) {
                const actionsDiv = card.querySelector('.notif-actions');
                if (actionsDiv) {
                    actionsDiv.innerHTML = `
                        <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
                            <span class="responded-badge rejected">❌ 已拒绝</span>
                            ${responseTimeStr ? `<span class="response-time-badge">⚡ 时间: ${responseTimeStr}</span>` : ''}
                            <span style="font-size:12px;color:#6b7280;font-style:italic;">理由: ${reason}</span>
                        </div>`;
                }
            }
            cntReject++;
            updateCounters();
            closeRejectModal();
        } else {
            submitBtn.disabled   = false;
            submitBtn.textContent = '❌ 确认拒绝';
            submitBtn.classList.add('active');
        }
    } catch (err) {
        console.error('submitReject error:', err);
        submitBtn.disabled   = false;
        submitBtn.textContent = '❌ 确认拒绝';
        submitBtn.classList.add('active');
    }
}

