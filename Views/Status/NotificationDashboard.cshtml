function switchTab(tab, btn) {
    // Toggle tab panels
    document.getElementById('tabNotif').classList.toggle('active', tab === 'notif');
    document.getElementById('tabEdit').classList.toggle('active',  tab === 'edit');

    // Toggle tab buttons
    document.querySelectorAll('.tech-tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Load data khi mở tab edit
    if (tab === 'edit') teLoadRecords(1);
}

/* ══════════════════════════════════════════════════════════
   TECH EDIT RECORDS
══════════════════════════════════════════════════════════ */
let tePage     = 1;
let tePageSize = 15;
let teTotalPages = 1;
let teEditingId  = null;
let teAllRows    = []; // cache để filter client-side

async function teLoadRecords(page) {
    tePage = page || 1;
    const state = document.getElementById('teStateFilter').value;

    const today = new Date();
    const yyyy  = today.getFullYear();
    const mm    = String(today.getMonth() + 1).padStart(2, '0');
    const dd    = String(today.getDate()).padStart(2, '0');
    const fromDate = `${yyyy}-${mm}-${dd}`;

    const url = `${pathBase}/Status/TechGetRecords?page=${tePage}&pageSize=${tePageSize}&state=${encodeURIComponent(state)}&fromDate=${fromDate}`;

    document.getElementById('teTableBody').innerHTML =
        '<tr><td colspan="11" class="te-empty">⏳ Đang tải...</td></tr>';

    try {
        const res  = await fetch(url);
        const data = await res.json();

        teAllRows    = data.records || [];
        teTotalPages = data.totalPages || 1;

        teRenderTable(teAllRows);
        teRenderPagination(data.totalCount);

        document.getElementById('teRecordCount').textContent =
            `Tổng: ${data.totalCount || 0} records`;

    } catch (e) {
        document.getElementById('teTableBody').innerHTML =
            '<tr><td colspan="11" class="te-empty" style="color:#ef4444;">❌ Lỗi tải dữ liệu</td></tr>';
    }
}

function teRenderTable(rows) {
    const tbody = document.getElementById('teTableBody');
    if (!rows || rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="11" class="te-empty">📭 Không có dữ liệu</td></tr>';
        return;
    }

    tbody.innerHTML = rows.map(r => {
        const stateClass = r.state === 'STOP' ? 'state-STOP'
                         : r.state === 'RUN'  ? 'state-RUN'
                         : 'state-RESPONSE';
        const dt = r.datetime ? new Date(r.datetime).toLocaleString('vi-VN', { hour12: false }) : '-';
        const truncate = (s, n) => s && s.length > n ? s.substring(0, n) + '…' : (s || '-');

        return `<tr>
            <td style="font-weight:700;color:#6366f1;">#${r.id}</td>
            <td><span class="te-state-badge ${stateClass}">${r.state || '-'}</span></td>
            <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${r.operation || ''}">${truncate(r.operation, 20)}</td>
            <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${r.machineCode || ''}">${truncate(r.machineCode, 18)}</td>
            <td>${r.employeeName || r.employeeCode || '-'}</td>
            <td style="color:${r.station ? '#0369a1' : '#9ca3af'};">${r.station || '-'}</td>
            <td style="color:${r.action ? '#0369a1' : '#9ca3af'};">${truncate(r.action, 15)}</td>
            <td style="color:${r.rootCause ? '#0369a1' : '#9ca3af'};">${truncate(r.rootCause, 15)}</td>
            <td style="color:${r.spareParts ? '#0369a1' : '#9ca3af'};">${truncate(r.spareParts, 15)}</td>
            <td style="font-size:12px;color:#6b7280;">${dt}</td>
            <td>
                <button class="btn-te-edit" onclick='teOpenModal(${JSON.stringify(r)})'>✏️ Sửa</button>
            </td>
        </tr>`;
    }).join('');
}

function teFilterTable() {
    const q = document.getElementById('teSearch').value.toLowerCase().trim();
    if (!q) { teRenderTable(teAllRows); return; }
    const filtered = teAllRows.filter(r =>
        (r.machineCode  || '').toLowerCase().includes(q) ||
        (r.operation    || '').toLowerCase().includes(q) ||
        (r.employeeName || '').toLowerCase().includes(q) ||
        (r.employeeCode || '').toLowerCase().includes(q) ||
        (r.station      || '').toLowerCase().includes(q)
    );
    teRenderTable(filtered);
}

function teRenderPagination(totalCount) {
    const wrap = document.getElementById('tePagination');
    if (teTotalPages <= 1) { wrap.style.display = 'none'; return; }
    wrap.style.display = 'flex';

    document.getElementById('tePageInfo').textContent =
        `Trang ${tePage} / ${teTotalPages} (${totalCount} records)`;

    const btns = document.getElementById('tePageBtns');
    btns.innerHTML = '';

    function mkBtn(label, p, active, disabled) {
        const b = document.createElement('button');
        b.className = 'te-page-btn' + (active ? ' active' : '');
        b.textContent = label;
        b.disabled = disabled;
        if (!disabled && !active) b.onclick = () => teLoadRecords(p);
        btns.appendChild(b);
    }

    mkBtn('‹', tePage - 1, false, tePage === 1);
    for (let p = Math.max(1, tePage - 2); p <= Math.min(teTotalPages, tePage + 2); p++) {
        mkBtn(p, p, p === tePage, false);
    }
    mkBtn('›', tePage + 1, false, tePage === teTotalPages);
}

/* ── Modal ── */
function teOpenModal(record) {
    teEditingId = record.id;

    // Thông tin read-only
    document.getElementById('teModalInfo').innerHTML = `
        <div><div class="info-label">ID</div><div class="info-val">#${record.id}</div></div>
        <div><div class="info-label">Trạng thái</div><div class="info-val">${record.state || '-'}</div></div>
        <div><div class="info-label">Máy</div><div class="info-val">${record.machineCode || '-'}</div></div>
        <div><div class="info-label">Nhân viên</div><div class="info-val">${record.employeeName || record.employeeCode || '-'}</div></div>
        <div style="grid-column:1/-1;"><div class="info-label">Công đoạn</div><div class="info-val">${record.operation || '-'}</div></div>
    `;
    document.getElementById('teModalSub').textContent =
        `Máy: ${record.machineCode || '-'} · ${record.state || ''} · #${record.id}`;

    // Fill 4 trường
    document.getElementById('teFieldStation').value   = record.station   || '';
    document.getElementById('teFieldAction').value    = record.action    || '';
    document.getElementById('teFieldRootCause').value = record.rootCause || '';
    document.getElementById('teFieldSpareParts').value= record.spareParts|| '';

    document.getElementById('teModalOverlay').classList.add('open');
    document.getElementById('teFieldStation').focus();
}

function closeTeModal() {
    document.getElementById('teModalOverlay').classList.remove('open');
    teEditingId = null;
}

async function teSaveRecord() {
    if (!teEditingId) return;

    const btn = document.getElementById('teSaveBtn');
    btn.disabled  = true;
    btn.textContent = '⏳ Đang lưu...';

    try {
        const res = await fetch(`${pathBase}/Status/TechUpdateRecord`, {
            method : 'POST',
            headers: { 'Content-Type': 'application/json' },
            body   : JSON.stringify({
                id        : teEditingId,
                station   : document.getElementById('teFieldStation').value.trim(),
                action    : document.getElementById('teFieldAction').value.trim(),
                rootCause : document.getElementById('teFieldRootCause').value.trim(),
                spareParts: document.getElementById('teFieldSpareParts').value.trim()
            })
        });
        const data = await res.json();

        if (data.success) {
            closeTeModal();
            teShowToast('✅ Lưu thành công!');
            teLoadRecords(tePage); // Reload bảng
        } else {
            teShowToast('❌ ' + (data.message || 'Lỗi lưu'), true);
        }
    } catch (e) {
        teShowToast('❌ Lỗi kết nối', true);
    } finally {
        btn.disabled    = false;
        btn.textContent = '💾 Lưu';
    }
}

// Đóng modal khi click overlay
document.getElementById('teModalOverlay').addEventListener('click', function(e) {
    if (e.target === this) closeTeModal();
});

// Toast nhỏ
function teShowToast(msg, isError = false) {
    const t = document.getElementById('teToast');
    t.textContent = msg;
    t.className   = 'te-toast show' + (isError ? ' error' : '');
    setTimeout(() => t.classList.remove('show'), 3000);
}

// ══════════════════════════════════════════
//  POST-RUN EDIT MODAL — chỉ Technical
// ══════════════════════════════════════════
function openPostRunModal(recordId, existingData) {
    document.getElementById('postRunRecordId').value    = recordId || '';
    document.getElementById('postRunReason').value      = existingData?.reason      || '';
    document.getElementById('postRunEffect').value      = existingData?.effect      || '';
    document.getElementById('postRunDescription').value = '';
    document.getElementById('postRunRootCause').value   = existingData?.rootCause   || '';
    document.getElementById('postRunAction').value      = existingData?.action      || '';
    document.getElementById('postRunSpareParts').value  = existingData?.spareParts  || '';
    document.getElementById('postRunModalOverlay').style.display = 'flex';
    setTimeout(() => document.getElementById('postRunReason').focus(), 120);
}

function closePostRunModal() {
    document.getElementById('postRunModalOverlay').style.display = 'none';
}

async function submitPostRunEdit() {
    const id = parseInt(document.getElementById('postRunRecordId').value) || 0;
    if (!id) { closePostRunModal(); return; }

    const reason = document.getElementById('postRunReason').value.trim();
    const effect = document.getElementById('postRunEffect').value.trim();
    if (!reason) {
        document.getElementById('postRunReason').style.borderColor = '#ef4444';
        teShowToast('⚠ 请选择原因 / Please select Reason!', true);
        return;
    }
    if (!effect) {
        document.getElementById('postRunEffect').style.borderColor = '#ef4444';
        teShowToast('⚠ 请选择影响 / Please select Effect!', true);
        return;
    }

    const btn = document.getElementById('postRunSaveBtn');
    btn.disabled    = true;
    btn.textContent = '⏳ 保存中...';

    try {
        const res  = await fetch(`${pathBase}/Status/PostRunEdit`, {
            method  : 'POST',
            headers : { 'Content-Type': 'application/json' },
            body    : JSON.stringify({
                id,
                reason       : reason || null,
                effect       : effect || null,
                description  : document.getElementById('postRunDescription').value.trim() || null,
                rootCause    : document.getElementById('postRunRootCause').value.trim()   || null,
                action       : document.getElementById('postRunAction').value.trim()      || null,
                spareParts   : document.getElementById('postRunSpareParts').value.trim()  || null,
            })
        });
        if (!res.ok) {
            teShowToast(`❌ HTTP ${res.status}: ${res.statusText}`, true);
            return;
        }
        const data = await res.json();
        if (data.success) {
            teShowToast('✅ 信息已保存！');
            closePostRunModal();
        } else {
            teShowToast('❌ 保存失败！', true);
        }
    } catch (err) {
        teShowToast('❌ 保存出错！', true);
    } finally {
        btn.disabled    = false;
        btn.innerHTML   = '💾 保存 / Save';
    }
}

document.getElementById('postRunModalOverlay')
    ?.addEventListener('click', function(e) { if (e.target === this) closePostRunModal(); });

</script>

<!-- Post-Run Edit Modal -->
<div id="postRunModalOverlay" style="
    display:none;position:fixed;inset:0;z-index:9999;
    background:rgba(0,0,0,.45);backdrop-filter:blur(2px);
    align-items:center;justify-content:center">
    <div style="
        background:#fff;border-radius:14px;padding:28px 28px 22px;
        max-width:500px;width:94%;box-shadow:0 20px 60px rgba(0,0,0,.22);
        animation:postRunIn .18s ease">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
            <h2 style="margin:0;font-size:17px;font-weight:700;color:#111">
                📝 补充信息 / Add Details
            </h2>
            <button onclick="closePostRunModal()"
                    style="background:none;border:none;font-size:20px;cursor:pointer;color:#9ca3af;line-height:1">×</button>
        </div>
        <p style="margin:0 0 16px;font-size:13px;color:#6b7280">
            After repair complete, please fill in the details below.<br>
            维修完成后，请补充以下信息。
        </p>
        <input type="hidden" id="postRunRecordId" />
        <div style="display:flex;flex-direction:column;gap:12px">
            <div>
                <label style="font-size:12.5px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.04em;display:block;margin-bottom:4px">
                    原因 / Reason <span style="color:#ef4444">*</span>
                </label>
                <select id="postRunReason" style="width:100%;border:1.5px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:14px;box-sizing:border-box;background:#fff">
                    <option value="">-- 选择原因 (Select reason) --</option>
                    @foreach (var r in (ViewBag.PieReasonOptions as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>()))
                    {
                        <option value="@r.Reason_Name">@r.Reason_Name (@r.Reason_Code)</option>
                    }
                </select>
            </div>
            <div>
                <label style="font-size:12.5px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.04em;display:block;margin-bottom:4px">
                    影响 / Effect <span style="color:#ef4444">*</span>
                </label>
                <select id="postRunEffect" style="width:100%;border:1.5px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:14px;box-sizing:border-box;background:#fff">
                    <option value="">-- 有没有影响 --</option>
                    <option value="1">影响生产</option>
                    <option value="2">不影响生产</option>
                </select>
            </div>
            <div>
                <label style="font-size:12.5px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.04em;display:block;margin-bottom:4px">
                    异常描述 / Problem Description
                    <span style="font-weight:400;font-size:11px;color:#9ca3af;margin-left:4px">(Prod đã nhập — Tech bổ sung thêm)</span>
                </label>
                <input type="text" id="postRunDescription" placeholder="Thêm mô tả kỹ thuật..."
                       style="width:100%;border:1.5px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:14px;box-sizing:border-box" />
            </div>
            <div>
                <label style="font-size:12.5px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.04em;display:block;margin-bottom:4px">根本原因 / Root Cause</label>
                <input type="text" id="postRunRootCause" placeholder="Enter root cause..."
                       style="width:100%;border:1.5px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:14px;box-sizing:border-box" />
            </div>
            <div>
                <label style="font-size:12.5px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.04em;display:block;margin-bottom:4px">维修动作 / Action Taken</label>
                <input type="text" id="postRunAction" placeholder="Enter action taken..."
                       style="width:100%;border:1.5px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:14px;box-sizing:border-box" />
            </div>
            <div>
                <label style="font-size:12.5px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.04em;display:block;margin-bottom:4px">
                    更换配件 / Spare Parts Used
                    <span style="font-weight:400;font-size:11px;color:#9ca3af;margin-left:4px">(optional)</span>
                </label>
                <input type="text" id="postRunSpareParts" placeholder="Enter spare parts used (or leave blank)..."
                       style="width:100%;border:1.5px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:14px;box-sizing:border-box" />
            </div>
        </div>
        <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:20px">
            <button onclick="closePostRunModal()"
                    style="background:#f3f4f6;color:#374151;border:none;border-radius:9px;padding:9px 20px;font-size:14px;font-weight:600;cursor:pointer">
                跳过 / Skip
            </button>
            <button id="postRunSaveBtn" onclick="submitPostRunEdit()"
                    style="background:#22c55e;color:#fff;border:none;border-radius:9px;padding:9px 24px;font-size:14px;font-weight:700;cursor:pointer">
                💾 保存 / Save
            </button>
        </div>
    </div>
</div>
<style>
@@keyframes postRunIn {
    from { opacity:0;transform:scale(.95) translateY(-8px); }
    to   { opacity:1;transform:scale(1)   translateY(0); }
}
</style>